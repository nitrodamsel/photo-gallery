<%- include('./layouts/base', { title: title, body: `
<div class="search-page">
  <!-- Search Header -->
  <div class="search-header mb-4">
    <div class="row align-items-center">
      <div class="col-md-8">
        <h1 class="h3 mb-1">
          <i class="bi bi-search me-2"></i>Search Images
        </h1>
        <% if (pagination.total > 0) { %>
          <p class="text-muted mb-0">
            Found <strong><%= pagination.total %></strong> result<%= pagination.total !== 1 ? 's' : '' %>
            <% if (searchOptions.q) { %>
              for "<strong><%= searchOptions.q %></strong>"
            <% } %>
          </p>
        <% } %>
      </div>
      <div class="col-md-4 text-md-end">
        <% if (activeFilters.length > 0) { %>
          <a href="/search" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-x-circle me-1"></i>Clear All Filters
          </a>
        <% } %>
      </div>
    </div>

    <!-- Active Filter Summary -->
    <% if (activeFilters.length > 0) { %>
      <div class="active-filters mt-2 d-flex flex-wrap gap-2">
        <% activeFilters.forEach(function(filter) { %>
          <span class="badge bg-primary-subtle text-primary-emphasis border border-primary-subtle">
            <strong><%= filter.label %>:</strong> <%= filter.value %>
          </span>
        <% }); %>
      </div>
    <% } %>
  </div>

  <div class="row g-4">
    <!-- Filter Panel (sidebar) -->
    <div class="col-lg-3">
      <%- include('./partials/filter-panel', { query: query, facets: facets }) %>
    </div>

    <!-- Search Results -->
    <div class="col-lg-9">
      <!-- Inline Search Bar -->
      <div class="search-bar-inline mb-4">
        <form action="/search" method="GET" id="quickSearchForm">
          <!-- Preserve existing filters -->
          <% if (query.tags) {
            const tagList = Array.isArray(query.tags) ? query.tags : [query.tags];
            tagList.forEach(function(tag) { %>
              <input type="hidden" name="tags" value="<%= tag %>">
            <% });
          } %>
          <% if (query.dateFrom) { %><input type="hidden" name="dateFrom" value="<%= query.dateFrom %>"><% } %>
          <% if (query.dateTo) { %><input type="hidden" name="dateTo" value="<%= query.dateTo %>"><% } %>
          <% if (query.cameraMake) { %><input type="hidden" name="cameraMake" value="<%= query.cameraMake %>"><% } %>
          <% if (query.hasGps) { %><input type="hidden" name="hasGps" value="<%= query.hasGps %>"><% } %>
          <% if (query.limit) { %><input type="hidden" name="limit" value="<%= query.limit %>"><% } %>

          <div class="input-group input-group-lg shadow-sm">
            <span class="input-group-text bg-white">
              <i class="bi bi-search text-muted"></i>
            </span>
            <input
              type="text"
              class="form-control border-start-0"
              name="q"
              id="searchInput"
              value="<%= query.q || '' %>"
              placeholder="Search by filename, description, camera model..."
              autocomplete="off"
            >
            <% if (query.q) { %>
              <a href="/search?<%= Object.entries(query).filter(([k]) => k !== 'q' && k !== 'page').map(([k,v]) => Array.isArray(v) ? v.map(val => `${k}=${encodeURIComponent(val)}`).join('&') : `${k}=${encodeURIComponent(v)}`).join('&') %>" class="btn btn-outline-secondary" title="Clear search">
                <i class="bi bi-x-lg"></i>
              </a>
            <% } %>
            <button class="btn btn-primary" type="submit">Search</button>
          </div>
        </form>
      </div>

      <!-- Sort & View Controls -->
      <% if (pagination.total > 0) { %>
        <div class="d-flex justify-content-between align-items-center mb-3">
          <div class="text-muted small">
            Showing <%= (searchOptions.page - 1) * searchOptions.limit + 1 %>–<%= Math.min(searchOptions.page * searchOptions.limit, pagination.total) %>
            of <%= pagination.total %> results
          </div>
          <div class="d-flex gap-2 align-items-center">
            <label class="text-muted small me-1" for="sortSelect">Sort:</label>
            <select class="form-select form-select-sm w-auto" id="sortSelect" onchange="applySortChange(this.value)">
              <option value="relevance" <%= (query.sortBy || 'relevance') === 'relevance' ? 'selected' : '' %>>Relevance</option>
              <option value="date_desc" <%= query.sortBy === 'date_desc' ? 'selected' : '' %>>Newest First</option>
              <option value="date_asc" <%= query.sortBy === 'date_asc' ? 'selected' : '' %>>Oldest First</option>
              <option value="name_asc" <%= query.sortBy === 'name_asc' ? 'selected' : '' %>>Name A–Z</option>
              <option value="name_desc" <%= query.sortBy === 'name_desc' ? 'selected' : '' %>>Name Z–A</option>
            </select>
          </div>
        </div>
      <% } %>

      <!-- Results Grid -->
      <% if (results.length > 0) { %>
        <div class="row g-3" id="resultsGrid">
          <% results.forEach(function(image) { %>
            <div class="col-sm-6 col-md-4 col-xl-3">
              <%- include('./partials/image-card', { image: image }) %>
            </div>
          <% }); %>
        </div>

        <!-- Pagination -->
        <% if (pagination.totalPages > 1) { %>
          <nav class="mt-4" aria-label="Search results pagination">
            <%- include('./partials/pagination', {
              currentPage: pagination.currentPage,
              totalPages: pagination.totalPages,
              buildUrl: function(p) {
                const params = Object.assign({}, query, { page: p });
                return '/search?' + Object.entries(params)
                  .map(([k, v]) => Array.isArray(v)
                    ? v.map(val => encodeURIComponent(k) + '=' + encodeURIComponent(val)).join('&')
                    : encodeURIComponent(k) + '=' + encodeURIComponent(v))
                  .join('&');
              }
            }) %>
          </nav>
        <% } %>

      <% } else { %>
        <!-- No Results State -->
        <div class="no-results text-center py-5">
          <div class="mb-4">
            <i class="bi bi-search display-1 text-muted opacity-50"></i>
          </div>
          <h2 class="h4 text-muted">No images found</h2>
          <% if (activeFilters.length > 0 || searchOptions.q) { %>
            <p class="text-muted">
              Try adjusting your search terms or filters.
            </p>
            <div class="d-flex gap-2 justify-content-center flex-wrap mt-3">
              <% if (searchOptions.q) { %>
                <span class="text-muted">Suggestions:</span>
                <span class="badge bg-light text-dark border">Try broader terms</span>
                <span class="badge bg-light text-dark border">Check your spelling</span>
                <span class="badge bg-light text-dark border">Remove some filters</span>
              <% } %>
            </div>
            <div class="mt-4">
              <a href="/search" class="btn btn-outline-primary me-2">
                <i class="bi bi-x-circle me-1"></i>Clear All Filters
              </a>
              <a href="/gallery" class="btn btn-primary">
                <i class="bi bi-images me-1"></i>Browse All Images
              </a>
            </div>
          <% } else { %>
            <p class="text-muted">
              No images have been uploaded yet.
            </p>
            <a href="/upload" class="btn btn-primary">
              <i class="bi bi-upload me-1"></i>Upload Images
            </a>
          <% } %>
        </div>
      <% } %>
    </div>
  </div>
</div>

<script>
  // Pass current query to client-side search script
  window.__SEARCH_QUERY__ = <%- JSON.stringify(query) %>;
  window.__SEARCH_OPTIONS__ = <%- JSON.stringify(searchOptions) %>;
</script>
<script src="/js/search.js"></script>
` }) %>