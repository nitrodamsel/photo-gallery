<%- include('layouts/base', { title: title || 'Search', body: `
<div class="container-fluid py-4">
  <!-- Search Header -->
  <div class="row mb-4">
    <div class="col-12">
      <h1 class="h3 mb-1">
        <i class="bi bi-search me-2"></i>Search
      </h1>
      <% if (searchOptions.q || searchOptions.tags.length || searchOptions.dateFrom || searchOptions.dateTo || searchOptions.cameraMake || searchOptions.hasGps) { %>
        <p class="text-muted mb-0">
          Found <strong><%= pagination.totalCount %></strong> result<%= pagination.totalCount !== 1 ? 's' : '' %>
          <% if (searchOptions.q) { %>
            for "<strong><%= searchOptions.q %></strong>"
          <% } %>
          <!-- Active filter badges -->
          <span class="ms-2" id="active-filters">
            <% if (searchOptions.dateFrom) { %>
              <span class="badge bg-secondary me-1">From: <%= searchOptions.dateFrom %></span>
            <% } %>
            <% if (searchOptions.dateTo) { %>
              <span class="badge bg-secondary me-1">To: <%= searchOptions.dateTo %></span>
            <% } %>
            <% if (searchOptions.cameraMake) { %>
              <span class="badge bg-secondary me-1">Camera: <%= searchOptions.cameraMake %></span>
            <% } %>
            <% if (searchOptions.hasGps) { %>
              <span class="badge bg-secondary me-1"><i class="bi bi-geo-alt-fill"></i> Has GPS</span>
            <% } %>
            <% if (searchOptions.tags && searchOptions.tags.length > 0) { %>
              <% searchOptions.tags.forEach(function(tag) { %>
                <span class="badge bg-primary me-1"><i class="bi bi-tag"></i> <%= tag %></span>
              <% }); %>
            <% } %>
          </span>
        </p>
      <% } else { %>
        <p class="text-muted mb-0">Enter a search term or use the filters to find images.</p>
      <% } %>
    </div>
  </div>

  <div class="row">
    <!-- Filter Panel -->
    <div class="col-lg-3 col-xl-2 mb-4">
      <%- include('partials/filter-panel', { query: query, facets: facets, searchOptions: searchOptions }) %>
    </div>

    <!-- Results -->
    <div class="col-lg-9 col-xl-10">
      <!-- Quick search bar -->
      <form method="GET" action="/search" class="mb-4" id="quick-search-form">
        <div class="input-group input-group-lg">
          <input
            type="search"
            class="form-control"
            name="q"
            id="search-input"
            value="<%= searchOptions.q || '' %>"
            placeholder="Search filenames, descriptions, camera data..."
            autocomplete="off"
            aria-label="Search"
          >
          <!-- Preserve other filters as hidden inputs -->
          <% if (searchOptions.dateFrom) { %><input type="hidden" name="dateFrom" value="<%= searchOptions.dateFrom %>"><% } %>
          <% if (searchOptions.dateTo) { %><input type="hidden" name="dateTo" value="<%= searchOptions.dateTo %>"><% } %>
          <% if (searchOptions.cameraMake) { %><input type="hidden" name="cameraMake" value="<%= searchOptions.cameraMake %>"><% } %>
          <% if (searchOptions.hasGps) { %><input type="hidden" name="hasGps" value="true"><% } %>
          <% if (searchOptions.tags) { searchOptions.tags.forEach(function(tag) { %><input type="hidden" name="tags" value="<%= tag %>"><% }); } %>
          <button class="btn btn-primary" type="submit">
            <i class="bi bi-search"></i> Search
          </button>
          <% if (searchOptions.q || searchOptions.tags.length || searchOptions.dateFrom || searchOptions.dateTo || searchOptions.cameraMake || searchOptions.hasGps) { %>
            <a href="/search" class="btn btn-outline-secondary">
              <i class="bi bi-x-circle"></i> Clear
            </a>
          <% } %>
        </div>
      </form>

      <!-- Results grid -->
      <div id="results-container">
        <% if (results && results.length > 0) { %>
          <!-- Sort controls -->
          <div class="d-flex justify-content-between align-items-center mb-3">
            <span class="text-muted small">
              Showing <%= (pagination.currentPage - 1) * pagination.limit + 1 %>–<%= Math.min(pagination.currentPage * pagination.limit, pagination.totalCount) %> of <%= pagination.totalCount %>
            </span>
            <div class="d-flex align-items-center gap-2">
              <label class="text-muted small mb-0">Sort:</label>
              <select class="form-select form-select-sm w-auto" id="sort-select">
                <option value="relevance" <%= (searchOptions.sort === 'relevance' || !searchOptions.sort) ? 'selected' : '' %>>Relevance</option>
                <option value="newest" <%= searchOptions.sort === 'newest' ? 'selected' : '' %>>Newest</option>
                <option value="oldest" <%= searchOptions.sort === 'oldest' ? 'selected' : '' %>>Oldest</option>
              </select>
            </div>
          </div>

          <div class="row g-3" id="results-grid">
            <% results.forEach(function(image) { %>
              <div class="col-6 col-md-4 col-xl-3">
                <%- include('partials/image-card', { image: image }) %>
              </div>
            <% }); %>
          </div>

          <!-- Pagination -->
          <% if (pagination.totalPages > 1) { %>
            <%- include('partials/pagination', {
              currentPage: pagination.currentPage,
              totalPages: pagination.totalPages,
              baseUrl: '/search',
              query: query
            }) %>
          <% } %>

        <% } else { %>
          <!-- No results state -->
          <div class="text-center py-5">
            <div class="mb-4">
              <i class="bi bi-search" style="font-size: 4rem; color: #dee2e6;"></i>
            </div>
            <h3 class="h5 text-muted mb-3">No images found</h3>
            <% if (searchOptions.q || searchOptions.tags.length || searchOptions.dateFrom || searchOptions.dateTo || searchOptions.cameraMake || searchOptions.hasGps) { %>
              <p class="text-muted mb-4">
                Try adjusting your search terms or filters.
              </p>
              <div class="d-flex gap-2 justify-content-center flex-wrap mb-4">
                <span class="text-muted small">Suggestions:</span>
                <span class="text-muted small">• Use fewer or shorter keywords</span>
                <span class="text-muted small">• Remove some filters</span>
                <span class="text-muted small">• Try different tag combinations</span>
              </div>
              <a href="/search" class="btn btn-outline-primary me-2">
                <i class="bi bi-x-circle me-1"></i>Clear All Filters
              </a>
              <a href="/gallery" class="btn btn-primary">
                <i class="bi bi-images me-1"></i>Browse All Images
              </a>
            <% } else { %>
              <p class="text-muted mb-4">
                Start by entering a search term above, or browse the gallery.
              </p>
              <a href="/gallery" class="btn btn-primary">
                <i class="bi bi-images me-1"></i>Browse Gallery
              </a>
            <% } %>
          </div>
        <% } %>
      </div>

      <!-- Loading overlay -->
      <div id="search-loading" class="d-none text-center py-5">
        <div class="spinner-border text-primary" role="status">
          <span class="visually-hidden">Searching...</span>
        </div>
        <p class="mt-2 text-muted">Searching...</p>
      </div>
    </div>
  </div>
</div>
` }) %>