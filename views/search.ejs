<%- include('layouts/base', { title: title, body: `
<div class="search-page">
  <!-- Search Header -->
  <div class="search-header mb-4">
    <h1 class="search-title">
      <i class="bi bi-search me-2"></i>Search Images
    </h1>

    <!-- Inline Search Form -->
    <form id="searchForm" action="/search" method="GET" class="search-form mt-3">
      <div class="input-group input-group-lg">
        <input
          type="text"
          id="searchInput"
          name="q"
          class="form-control"
          placeholder="Search by filename, description, camera info..."
          value="${searchOptions.q || ''}"
          autocomplete="off"
          aria-label="Search images"
        />
        <button type="submit" class="btn btn-primary">
          <i class="bi bi-search me-1"></i>Search
        </button>
        ${activeFilterCount > 0 ? `
        <a href="/search" class="btn btn-outline-secondary" title="Clear all filters">
          <i class="bi bi-x-circle me-1"></i>Clear
        </a>
        ` : ''}
      </div>

      <!-- Preserve hidden fields for filters when submitting from search bar -->
      ${searchOptions.tags && searchOptions.tags.map(id => `<input type="hidden" name="tags" value="${id}">`).join('')}
      ${searchOptions.dateFrom ? `<input type="hidden" name="dateFrom" value="${searchOptions.dateFrom}">` : ''}
      ${searchOptions.dateTo ? `<input type="hidden" name="dateTo" value="${searchOptions.dateTo}">` : ''}
      ${searchOptions.cameraMake ? `<input type="hidden" name="cameraMake" value="${searchOptions.cameraMake}">` : ''}
      ${searchOptions.hasGps ? `<input type="hidden" name="hasGps" value="true">` : ''}
      ${searchOptions.sortBy && searchOptions.sortBy !== 'relevance' ? `<input type="hidden" name="sortBy" value="${searchOptions.sortBy}">` : ''}
    </form>
  </div>

  <div class="row g-4">
    <!-- Filter Panel Sidebar -->
    <div class="col-lg-3">
      <%- include('partials/filter-panel', { searchOptions, facets, query }) %>
    </div>

    <!-- Results Area -->
    <div class="col-lg-9">
      <!-- Results Summary & Sort -->
      <div class="results-header d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <div class="results-count">
          <% if (searchOptions.q || activeFilterCount > 0) { %>
            <span class="fw-semibold"><%= count.toLocaleString() %></span>
            <%= count === 1 ? 'result' : 'results' %>
            <% if (searchOptions.q) { %>
              for <em>"<%= searchOptions.q %>"</em>
            <% } %>
          <% } else { %>
            <span class="fw-semibold"><%= count.toLocaleString() %></span> images
          <% } %>
        </div>

        <!-- Sort control -->
        <div class="sort-control d-flex align-items-center gap-2">
          <label class="form-label mb-0 text-muted small">Sort:</label>
          <select class="form-select form-select-sm w-auto" id="sortSelect" onchange="applySortChange(this.value)">
            <option value="relevance" <%= searchOptions.sortBy === 'relevance' ? 'selected' : '' %>>Relevance</option>
            <option value="date_desc" <%= searchOptions.sortBy === 'date_desc' ? 'selected' : '' %>>Newest First</option>
            <option value="date_asc" <%= searchOptions.sortBy === 'date_asc' ? 'selected' : '' %>>Oldest First</option>
            <option value="name" <%= searchOptions.sortBy === 'name' ? 'selected' : '' %>>Name A–Z</option>
          </select>
        </div>
      </div>

      <!-- Active Filters Summary -->
      <% if (activeFilters && activeFilters.length > 0) { %>
      <div class="active-filters mb-3 d-flex flex-wrap gap-2 align-items-center">
        <span class="text-muted small">Active filters:</span>
        <% activeFilters.forEach(function(filter) { %>
          <span class="badge bg-primary-subtle text-primary-emphasis border border-primary-subtle filter-badge">
            <%= filter.label %>
          </span>
        <% }); %>
        <a href="/search" class="btn btn-sm btn-outline-secondary ms-1">
          <i class="bi bi-x-circle me-1"></i>Clear all
        </a>
      </div>
      <% } %>

      <!-- Search Results Grid -->
      <div id="resultsGrid">
        <% if (results && results.length > 0) { %>
          <div class="row g-3" id="imageGrid">
            <% results.forEach(function(image) { %>
              <div class="col-6 col-md-4 col-xl-3">
                <%- include('partials/image-card', { image }) %>
              </div>
            <% }); %>
          </div>

          <!-- Pagination -->
          <% if (totalPages > 1) { %>
            <nav aria-label="Search results pagination" class="mt-4">
              <ul class="pagination justify-content-center">
                <li class="page-item <%= currentPage <= 1 ? 'disabled' : '' %>">
                  <a class="page-link" href="?<%= paginationBase %>&page=<%= currentPage - 1 %>">
                    <i class="bi bi-chevron-left"></i> Previous
                  </a>
                </li>

                <%
                  const startPage = Math.max(1, currentPage - 2);
                  const endPage = Math.min(totalPages, currentPage + 2);
                %>

                <% if (startPage > 1) { %>
                  <li class="page-item">
                    <a class="page-link" href="?<%= paginationBase %>&page=1">1</a>
                  </li>
                  <% if (startPage > 2) { %>
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                  <% } %>
                <% } %>

                <% for (let p = startPage; p <= endPage; p++) { %>
                  <li class="page-item <%= p === currentPage ? 'active' : '' %>">
                    <a class="page-link" href="?<%= paginationBase %>&page=<%= p %>"><%= p %></a>
                  </li>
                <% } %>

                <% if (endPage < totalPages) { %>
                  <% if (endPage < totalPages - 1) { %>
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                  <% } %>
                  <li class="page-item">
                    <a class="page-link" href="?<%= paginationBase %>&page=<%= totalPages %>"><%= totalPages %></a>
                  </li>
                <% } %>

                <li class="page-item <%= currentPage >= totalPages ? 'disabled' : '' %>">
                  <a class="page-link" href="?<%= paginationBase %>&page=<%= currentPage + 1 %>">
                    Next <i class="bi bi-chevron-right"></i>
                  </a>
                </li>
              </ul>
              <p class="text-center text-muted small mt-2">
                Page <%= currentPage %> of <%= totalPages %>
              </p>
            </nav>
          <% } %>

        <% } else { %>
          <!-- No Results State -->
          <div class="no-results text-center py-5">
            <div class="no-results-icon mb-3">
              <i class="bi bi-image-alt" style="font-size: 4rem; color: var(--bs-secondary);"></i>
            </div>
            <h3 class="text-muted">No images found</h3>
            <% if (searchOptions.q || activeFilterCount > 0) { %>
              <p class="text-muted mb-4">
                No images match your current search or filters. Try:
              </p>
              <ul class="list-unstyled text-muted mb-4">
                <li><i class="bi bi-check2 me-1"></i> Using different or fewer keywords</li>
                <li><i class="bi bi-check2 me-1"></i> Removing some active filters</li>
                <li><i class="bi bi-check2 me-1"></i> Checking for typos</li>
                <li><i class="bi bi-check2 me-1"></i> Broadening your date range</li>
              </ul>
              <div class="d-flex gap-2 justify-content-center">
                <a href="/search" class="btn btn-primary">
                  <i class="bi bi-arrow-counterclockwise me-1"></i>Clear All Filters
                </a>
                <a href="/gallery" class="btn btn-outline-secondary">
                  <i class="bi bi-images me-1"></i>Browse Gallery
                </a>
              </div>
            <% } else { %>
              <p class="text-muted mb-4">Your gallery is empty. Start by uploading some images.</p>
              <a href="/upload" class="btn btn-primary">
                <i class="bi bi-cloud-upload me-1"></i>Upload Images
              </a>
            <% } %>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<style>
.search-page .search-title {
  font-size: 1.75rem;
  font-weight: 700;
}

.filter-badge {
  font-size: 0.8rem;
  font-weight: 500;
}

.no-results {
  background: var(--bs-tertiary-bg);
  border-radius: 1rem;
  padding: 3rem 2rem;
}

.results-header {
  border-bottom: 1px solid var(--bs-border-color);
  padding-bottom: 0.75rem;
}

/* Highlighted search terms in image names */
.search-highlight {
  background-color: rgba(255, 220, 0, 0.4);
  border-radius: 2px;
  padding: 0 2px;
}

/* Live search loading state */
#resultsGrid.loading {
  opacity: 0.5;
  pointer-events: none;
  transition: opacity 0.2s;
}

#resultsGrid.loading::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 2rem;
  height: 2rem;
  margin: -1rem 0 0 -1rem;
  border: 3px solid var(--bs-border-color);
  border-top-color: var(--bs-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
</style>

<script>
// Make searchOptions and currentQuery available to the search JS module
window.__SEARCH_OPTIONS__ = <%- JSON.stringify(searchOptions) %>;
window.__FACETS__ = <%- JSON.stringify(facets) %>;
</script>
` }) %>