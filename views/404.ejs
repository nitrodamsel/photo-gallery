<%- include('layouts/base', { title: '404 — Page Not Found', body: `
<div class="error-page">
  <div class="container">
    <div class="error-content">
      <div class="error-illustration">
        <svg xmlns="http://www.w3.org/2000/svg" width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          <line x1="11" y1="8" x2="11" y2="12"></line>
          <line x1="11" y1="16" x2="11.01" y2="16"></line>
        </svg>
      </div>
      <h1 class="error-code">404</h1>
      <h2 class="error-title">Page Not Found</h2>
      <p class="error-message">
        <%= locals.message || "The page you're looking for doesn't exist or has been moved." %>
      </p>
      <div class="error-actions">
        <a href="/gallery" class="btn btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          Back to Gallery
        </a>
        <a href="/" class="btn btn-secondary">Go Home</a>
      </div>
    </div>
  </div>
</div>
` }) %>