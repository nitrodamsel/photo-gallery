<%
const exifData = image.exif_data || {};
const hasGps = image.gps_latitude != null && image.gps_longitude != null;
const cameraModel = image.camera_model || '';
const cameraMake = image.camera_make || '';
const cameraInfo = [cameraMake, cameraModel].filter(Boolean).join(' ');
const altText = [image.original_filename, cameraInfo].filter(Boolean).join(' — ');

// Build thumbnail URLs
const storedFilename = image.stored_filename || '';
const ext = storedFilename.includes('.') ? storedFilename.substring(storedFilename.lastIndexOf('.')) : '.jpg';
const base = storedFilename.replace(ext, '');
const thumb1200 = `/thumbnails/${base}_1200${ext}`;
const thumb400 = `/thumbnails/${base}_400${ext}`;
%>
<%- include('layouts/base', { title: title, body: `
<div class="detail-page">

  <nav class="detail-nav breadcrumb">
    <a href="/gallery">&larr; Back to Gallery</a>
    <% if (image.original_filename) { %>
      <span class="breadcrumb-sep">/</span>
      <span class="breadcrumb-current"><%= image.original_filename %></span>
    <% } %>
  </nav>

  <div class="detail-layout">

    <!-- Left column: image -->
    <div class="detail-image-col">
      <div class="detail-image-wrap lightbox-trigger" data-src="<%= thumb1200 %>">
        <img
          src="<%= thumb1200 %>"
          alt="<%= altText %>"
          class="detail-image"
          onerror="this.onerror=null;this.src='<%= thumb400 %>'"
        />
        <div class="lightbox-hint" aria-hidden="true">🔍 Click to enlarge</div>
      </div>

      <!-- Prev / Next navigation -->
      <div class="prev-next-nav">
        <% if (prevImage) { %>
          <a href="/gallery/<%= prevImage.id %>" class="btn btn-outline prev-btn">
            &larr; Previous
          </a>
        <% } else { %>
          <span class="btn btn-outline prev-btn disabled" aria-disabled="true">&larr; Previous</span>
        <% } %>

        <a href="/gallery" class="btn btn-outline">All Photos</a>

        <% if (nextImage) { %>
          <a href="/gallery/<%= nextImage.id %>" class="btn btn-outline next-btn">
            Next &rarr;
          </a>
        <% } else { %>
          <span class="btn btn-outline next-btn disabled" aria-disabled="true">Next &rarr;</span>
        <% } %>
      </div>
    </div>

    <!-- Right column: metadata -->
    <div class="detail-meta-col">

      <h1 class="detail-filename"><%= image.original_filename || 'Untitled' %></h1>

      <!-- Tags section -->
      <section class="meta-section tags-section" aria-label="Image tags">
        <h2 class="meta-section-title">Tags</h2>
        <div class="tags-list">
          <% if (image.tags && image.tags.length > 0) { %>
            <% image.tags.forEach(function(tag) { %>
              <span class="tag-badge">
                <a href="/gallery?tag=<%= tag.slug %>" class="tag-link"><%= tag.name %></a>
                <button
                  class="tag-remove-btn"
                  data-image-id="<%= image.id %>"
                  data-tag-id="<%= tag.id %>"
                  aria-label="Remove tag <%= tag.name %>"
                  title="Remove tag"
                >&times;</button>
              </span>
            <% }); %>
          <% } else { %>
            <span class="no-tags">No tags yet</span>
          <% } %>
          <!-- Add tag UI scaffold -->
          <div class="add-tag-form" style="margin-top: 0.5rem;">
            <input
              type="text"
              id="new-tag-input"
              class="tag-input"
              placeholder="Add a tag…"
              aria-label="Add new tag"
              autocomplete="off"
            />
            <button class="btn btn-sm btn-primary" id="add-tag-btn" data-image-id="<%= image.id %>">Add</button>
          </div>
        </div>
      </section>

      <!-- File Info section -->
      <section class="meta-section file-info-section" aria-label="File information">
        <h2 class="meta-section-title">File Info</h2>
        <dl class="info-list">
          <% if (image.file_size) { %>
          <div class="info-row">
            <dt>File Size</dt>
            <dd><%= (image.file_size / (1024 * 1024)).toFixed(2) %> MB</dd>
          </div>
          <% } %>
          <% if (image.width && image.height) { %>
          <div class="info-row">
            <dt>Dimensions</dt>
            <dd><%= image.width %> &times; <%= image.height %> px</dd>
          </div>
          <% } %>
          <% if (image.mime_type) { %>
          <div class="info-row">
            <dt>Type</dt>
            <dd><%= image.mime_type %></dd>
          </div>
          <% } %>
          <% if (image.created_at) { %>
          <div class="info-row">
            <dt>Uploaded</dt>
            <dd><%= new Date(image.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></dd>
          </div>
          <% } %>
          <% if (image.date_taken) { %>
          <div class="info-row">
            <dt>Date Taken</dt>
            <dd><%= new Date(image.date_taken).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></dd>
          </div>
          <% } %>
        </dl>
      </section>

      <!-- EXIF Data section -->
      <section class="meta-section exif-section" aria-label="EXIF metadata">
        <h2 class="meta-section-title">
          <button class="accordion-toggle" aria-expanded="true" aria-controls="exif-panel">
            EXIF Data <span class="accordion-icon">▾</span>
          </button>
        </h2>
        <div id="exif-panel" class="accordion-panel">
          <%- include('partials/exif-table', { image: image, exifData: exifData }) %>
        </div>
      </section>

      <!-- GPS Map section -->
      <% if (hasGps) { %>
      <section class="meta-section map-section" aria-label="GPS location">
        <h2 class="meta-section-title">Location</h2>
        <%- include('partials/map', {
          lat: image.gps_latitude,
          lng: image.gps_longitude
        }) %>
      </section>
      <% } %>

    </div>
  </div>
</div>

<!-- Lightbox overlay -->
<div class="lightbox-overlay" id="lightbox" role="dialog" aria-modal="true" aria-label="Image lightbox" hidden>
  <button class="lightbox-close" id="lightbox-close" aria-label="Close lightbox">&times;</button>
  <img class="lightbox-img" id="lightbox-img" src="" alt="<%= altText %>" />
</div>
` }) %>