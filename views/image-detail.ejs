<div class="container mt-4">
  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/">Home</a></li>
      <li class="breadcrumb-item"><a href="/gallery">Gallery</a></li>
      <li class="breadcrumb-item active"><%= image.title || image.originalName || 'Image' %></li>
    </ol>
  </nav>

  <div class="alert-container"></div>

  <div class="row">
    <!-- Image Display -->
    <div class="col-lg-8">
      <div class="card shadow-sm mb-3">
        <div class="card-body p-2">
          <img src="/uploads/<%= image.filename %>" 
               alt="<%= image.title || image.originalName %>"
               class="img-fluid rounded w-100"
               style="max-height: 70vh; object-fit: contain; background: #f8f9fa;">
        </div>
      </div>

      <!-- Image Actions -->
      <div class="d-flex gap-2 mb-3">
        <a href="/uploads/<%= image.filename %>" download="<%= image.originalName %>" class="btn btn-outline-primary btn-sm">
          <i class="bi bi-download me-1"></i>Download
        </a>
        <a href="/gallery" class="btn btn-outline-secondary btn-sm">
          <i class="bi bi-arrow-left me-1"></i>Back to Gallery
        </a>
        <button type="button" class="btn btn-outline-danger btn-sm ms-auto" 
          onclick="confirmDelete(<%= image.id %>)">
          <i class="bi bi-trash me-1"></i>Delete
        </button>
      </div>

      <!-- EXIF Data -->
      <% if (typeof exifData !== 'undefined' && exifData) { %>
      <div class="card shadow-sm mb-3">
        <div class="card-header" data-bs-toggle="collapse" data-bs-target="#exifCollapse" 
             style="cursor: pointer;">
          <h6 class="mb-0 d-flex justify-content-between align-items-center">
            <span><i class="bi bi-info-circle me-1"></i>EXIF Data</span>
            <i class="bi bi-chevron-down"></i>
          </h6>
        </div>
        <div class="collapse" id="exifCollapse">
          <div class="card-body p-0">
            <%- include('partials/exif-table', { exifData: exifData }) %>
          </div>
        </div>
      </div>
      <% } %>

      <!-- Map (if GPS data available) -->
      <% if (typeof exifData !== 'undefined' && exifData && exifData.gps && exifData.gps.latitude && exifData.gps.longitude) { %>
      <div class="card shadow-sm mb-3">
        <div class="card-header">
          <h6 class="mb-0"><i class="bi bi-geo-alt me-1"></i>Location</h6>
        </div>
        <div class="card-body p-0">
          <%- include('partials/map', { lat: exifData.gps.latitude, lng: exifData.gps.longitude }) %>
        </div>
      </div>
      <% } %>
    </div>

    <!-- Sidebar: Image Info & Tags -->
    <div class="col-lg-4">
      <!-- Image Info -->
      <div class="card shadow-sm mb-3">
        <div class="card-header">
          <h6 class="mb-0"><i class="bi bi-image me-1"></i>Image Info</h6>
        </div>
        <div class="card-body">
          <% if (image.title) { %>
          <h5 class="card-title"><%= image.title %></h5>
          <% } %>
          <% if (image.description) { %>
          <p class="card-text text-muted small"><%= image.description %></p>
          <% } %>
          <dl class="row small mb-0">
            <dt class="col-sm-5 text-muted">Filename</dt>
            <dd class="col-sm-7 text-truncate" title="<%= image.originalName %>"><%= image.originalName || 'N/A' %></dd>

            <% if (image.fileSize) { %>
            <dt class="col-sm-5 text-muted">Size</dt>
            <dd class="col-sm-7"><%= Math.round(image.fileSize / 1024) %> KB</dd>
            <% } %>

            <% if (image.mimeType) { %>
            <dt class="col-sm-5 text-muted">Type</dt>
            <dd class="col-sm-7"><%= image.mimeType %></dd>
            <% } %>

            <% if (image.width && image.height) { %>
            <dt class="col-sm-5 text-muted">Dimensions</dt>
            <dd class="col-sm-7"><%= image.width %> × <%= image.height %>px</dd>
            <% } %>

            <dt class="col-sm-5 text-muted">Uploaded</dt>
            <dd class="col-sm-7"><%= new Date(image.createdAt).toLocaleDateString() %></dd>
          </dl>
        </div>
      </div>

      <!-- Tags -->
      <div class="card shadow-sm">
        <div class="card-header">
          <h6 class="mb-0"><i class="bi bi-tags me-1"></i>Tags</h6>
        </div>
        <div class="card-body">
          <!-- Tag Display -->
          <div id="tagsContainer" data-image-id="<%= image.id %>" class="mb-3 min-height-30">
            <% if (typeof image.Tags !== 'undefined' && image.Tags && image.Tags.length > 0) { %>
              <% image.Tags.forEach(function(tag) { %>
              <span class="badge me-1 mb-1 tag-badge d-inline-flex align-items-center" 
                    style="background-color: <%= tag.color || '#6c757d' %>; font-size: 0.85em;"
                    data-tag-id="<%= tag.id %>">
                <a href="/gallery?tag=<%= tag.slug %>" 
                   class="text-white text-decoration-none me-1"><%= tag.name %></a>
                <button type="button" 
                  class="btn-close btn-close-white btn-remove-tag" 
                  style="font-size: 0.6em; padding: 0; margin-left: 2px;"
                  data-image-id="<%= image.id %>" 
                  data-tag-id="<%= tag.id %>"
                  aria-label="Remove tag <%= tag.name %>"></button>
              </span>
              <% }) %>
            <% } else { %>
              <span class="text-muted small">No tags yet.</span>
            <% } %>
          </div>

          <!-- Add Tag Form -->
          <form id="addTagForm" class="mt-2">
            <div class="input-group input-group-sm">
              <input type="text" 
                     id="tagInput" 
                     class="form-control" 
                     placeholder="Add a tag..." 
                     list="tagSuggestions"
                     minlength="2" 
                     maxlength="30"
                     autocomplete="off">
              <datalist id="tagSuggestions"></datalist>
              <button type="submit" class="btn btn-outline-primary" id="addTagBtn">
                <i class="bi bi-plus-lg"></i>
              </button>
            </div>
            <div id="tagFeedback" class="small mt-1"></div>
          </form>
          <div class="form-text small mt-1">
            2–30 chars, letters, numbers, hyphens, spaces
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="/js/tagging.js"></script>
<script>
function confirmDelete(imageId) {
  if (confirm('Are you sure you want to delete this image? This cannot be undone.')) {
    fetch(`/gallery/images/${imageId}`, { method: 'DELETE' })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          window.location.href = '/gallery';
        } else {
          alert('Failed to delete image: ' + (data.error || 'Unknown error'));
        }
      })
      .catch(() => alert('Network error. Please try again.'));
  }
}
</script>