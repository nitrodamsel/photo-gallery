<%- include('layouts/base', { title: image.originalName || 'Image Detail', body: `
<div class="detail-page" data-image-id="${image.id}">

  <!-- Breadcrumb -->
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/gallery">← Gallery</a>
    <span aria-hidden="true"> / </span>
    <span>${image.originalName || 'Image'}</span>
  </nav>

  <div class="detail-layout">

    <!-- Main Image Column -->
    <div class="detail-main">

      <div class="detail-image-wrap">
        <img
          id="main-image"
          src="/uploads/${image.filename}"
          alt="${image.description || image.originalName || 'Image'}"
          class="detail-image"
          style="transform: rotate(${image.rotation || 0}deg)${image.flipH ? ' scaleX(-1)' : ''};"
        />
      </div>

      <!-- Description -->
      <p
        id="image-description"
        class="detail-description"
        style="${image.description ? '' : 'display:none;'}"
      >${image.description || ''}</p>

      <!-- Tags -->
      <div class="detail-tags">
        <% if (image.Tags && image.Tags.length > 0) { %>
          <% image.Tags.forEach(tag => { %>
            <a href="/gallery?tag=<%= encodeURIComponent(tag.name) %>" class="tag-badge"><%= tag.name %></a>
          <% }); %>
        <% } else { %>
          <span class="detail-no-tags">No tags yet</span>
        <% } %>
      </div>

      <!-- Quick tag add -->
      <div class="detail-tag-add">
        <%- include('partials/tag-cloud', { image }) %>
      </div>

      <!-- Action Buttons -->
      <div class="detail-actions">
        <button id="btn-open-editor" class="btn btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px;vertical-align:middle;">
            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
          </svg>
          Edit Image
        </button>
        <a href="/uploads/${image.filename}" download class="btn btn-secondary">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px;vertical-align:middle;">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="7 10 12 15 17 10"></polyline>
            <line x1="12" y1="15" x2="12" y2="3"></line>
          </svg>
          Download
        </a>
      </div>

    </div>

    <!-- Sidebar: EXIF & Info -->
    <aside class="detail-sidebar">
      <div class="detail-info-card">
        <h3 class="detail-info-title">Image Info</h3>
        <dl class="detail-info-list">
          <dt>Filename</dt>
          <dd>${image.originalName || image.filename}</dd>
          <% if (image.width && image.height) { %>
            <dt>Dimensions</dt>
            <dd>${image.width} × ${image.height} px</dd>
          <% } %>
          <% if (image.fileSize) { %>
            <dt>File Size</dt>
            <dd>${(image.fileSize / 1024 / 1024).toFixed(2)} MB</dd>
          <% } %>
          <% if (image.mimeType) { %>
            <dt>Type</dt>
            <dd>${image.mimeType}</dd>
          <% } %>
          <dt>Uploaded</dt>
          <dd>${new Date(image.createdAt).toLocaleDateString()}</dd>
          <% if (image.rotation && image.rotation !== 0) { %>
            <dt>Rotation</dt>
            <dd>${image.rotation}°</dd>
          <% } %>
        </dl>
      </div>

      <!-- Manual EXIF Section -->
      <% 
        let manualExifData = {};
        if (image.manualExif) {
          try {
            manualExifData = typeof image.manualExif === 'string' ? JSON.parse(image.manualExif) : image.manualExif;
          } catch(e) {}
        }
        const hasManualExif = Object.keys(manualExifData).length > 0;
      %>
      <% if (hasManualExif) { %>
        <div class="detail-info-card" id="manual-exif-section">
          <h3 class="detail-info-title">Additional Info</h3>
          <dl class="detail-info-list">
            <% if (manualExifData.caption) { %>
              <dt>Caption</dt>
              <dd id="exif-caption">${manualExifData.caption}</dd>
            <% } %>
            <% if (manualExifData.locationName) { %>
              <dt>Location</dt>
              <dd id="exif-location">${manualExifData.locationName}</dd>
            <% } %>
            <% if (manualExifData.dateTaken) { %>
              <dt>Date Taken</dt>
              <dd id="exif-date-taken">${new Date(manualExifData.dateTaken).toLocaleString()}</dd>
            <% } %>
            <% if (manualExifData.camera) { %>
              <dt>Camera</dt>
              <dd id="exif-camera">${manualExifData.camera}</dd>
            <% } %>
          </dl>
        </div>
      <% } %>

      <!-- EXIF Data from file -->
      <%- include('partials/exif-table', { exif: image.exifData }) %>

      <!-- Map if GPS data available -->
      <% 
        let hasGps = false;
        let lat = null, lng = null;
        if (image.exifData) {
          const exifObj = typeof image.exifData === 'string' ? JSON.parse(image.exifData) : image.exifData;
          if (exifObj && exifObj.GPSLatitude && exifObj.GPSLongitude) {
            hasGps = true;
            lat = exifObj.GPSLatitude;
            lng = exifObj.GPSLongitude;
          }
        }
      %>
      <% if (hasGps) { %>
        <%- include('partials/map', { lat, lng }) %>
      <% } %>

    </aside>

  </div>

  <!-- Edit Panel (slide-in) -->
  <%- include('partials/edit-panel', { image }) %>

</div>

<script src="/js/imageEditor.js"></script>
`) %>