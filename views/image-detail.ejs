<%- contentFor('body') %>
<%
  // Parse EXIF data safely
  let exifData = {};
  try {
    if (image.exifData) {
      exifData = typeof image.exifData === 'string' ? JSON.parse(image.exifData) : image.exifData;
    }
  } catch(e) {}

  // Parse manual EXIF
  let manualExif = {};
  try {
    if (image.manualExif) {
      manualExif = typeof image.manualExif === 'string' ? JSON.parse(image.manualExif) : image.manualExif;
    }
  } catch(e) {}

  const currentRotation = image.rotation || 0;
%>

<section class="section image-detail-container">
  <div class="container">

    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="breadcrumbs">
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/gallery">Gallery</a></li>
        <li class="is-active"><a href="#" aria-current="page"><%= image.originalName || image.filename %></a></li>
      </ul>
    </nav>

    <!-- Action Bar -->
    <div class="level mb-4">
      <div class="level-left">
        <div class="level-item">
          <h1 class="title is-4 mb-0"><%= image.originalName || image.filename %></h1>
        </div>
      </div>
      <div class="level-right">
        <div class="level-item">
          <div class="buttons">
            <a href="/gallery" class="button is-light">
              <span class="icon"><i class="fas fa-arrow-left"></i></span>
              <span>Back to Gallery</span>
            </a>
            <button id="edit-toggle-btn" class="button is-info">
              <span class="icon"><i class="fas fa-edit"></i></span>
              <span>Edit Image</span>
            </button>
          </div>
        </div>
      </div>
    </div>

    <div class="columns is-variable is-6">
      <!-- Main Image Column -->
      <div class="column is-7">
        <!-- Image Display -->
        <div class="image-display-wrapper card">
          <div class="card-image">
            <figure class="image-figure">
              <img
                id="main-image"
                src="/uploads/<%= image.filename %>"
                alt="<%= image.originalName || image.filename %>"
                style="transform: rotate(<%= currentRotation %>deg); transition: transform 0.3s ease; max-width: 100%; display: block; margin: auto;"
              />
            </figure>
          </div>
          <div class="card-content py-2 px-3">
            <div class="is-flex is-justify-content-space-between is-align-items-center">
              <span class="is-size-7 has-text-grey">
                <% if (image.width && image.height) { %>
                  <%= image.width %> × <%= image.height %>px
                <% } %>
                <% if (image.fileSize) { %>
                  · <%= (image.fileSize / 1024 / 1024).toFixed(2) %> MB
                <% } %>
              </span>
              <a href="/uploads/<%= image.filename %>" download class="button is-small is-light">
                <span class="icon is-small"><i class="fas fa-download"></i></span>
                <span>Download</span>
              </a>
            </div>
          </div>
        </div>

        <!-- Description -->
        <% if (image.description) { %>
          <div class="box mt-4">
            <p id="image-description-display" class="content"><%= image.description %></p>
          </div>
        <% } else { %>
          <div class="box mt-4 is-hidden" id="image-description-display-wrapper">
            <p id="image-description-display" class="content"></p>
          </div>
        <% } %>

        <!-- Manual EXIF Overrides Display -->
        <% if (manualExif && Object.keys(manualExif).length > 0) { %>
          <div class="box mt-4">
            <h4 class="title is-6 mb-3">
              <span class="icon is-small"><i class="fas fa-pen"></i></span>
              Manual Metadata
            </h4>
            <% if (manualExif.caption) { %>
              <div class="manual-exif-row mb-2">
                <span class="has-text-grey-dark is-size-7 mr-2">Caption:</span>
                <span id="manual-caption-display"><%= manualExif.caption %></span>
              </div>
            <% } else { %>
              <div class="manual-exif-row mb-2 is-hidden">
                <span class="has-text-grey-dark is-size-7 mr-2">Caption:</span>
                <span id="manual-caption-display"></span>
              </div>
            <% } %>
            <% if (manualExif.locationName) { %>
              <div class="manual-exif-row mb-2">
                <span class="has-text-grey-dark is-size-7 mr-2">Location:</span>
                <span id="manual-location-display"><%= manualExif.locationName %></span>
              </div>
            <% } else { %>
              <div class="manual-exif-row mb-2 is-hidden">
                <span class="has-text-grey-dark is-size-7 mr-2">Location:</span>
                <span id="manual-location-display"></span>
              </div>
            <% } %>
            <% if (manualExif.dateTaken) { %>
              <div class="manual-exif-row">
                <span class="has-text-grey-dark is-size-7 mr-2">Date Taken:</span>
                <span id="manual-date-taken-display"><%= manualExif.dateTaken %></span>
              </div>
            <% } else { %>
              <div class="manual-exif-row is-hidden">
                <span class="has-text-grey-dark is-size-7 mr-2">Date Taken:</span>
                <span id="manual-date-taken-display"></span>
              </div>
            <% } %>
          </div>
        <% } else { %>
          <div class="box mt-4" id="manual-exif-section" style="display:none;">
            <h4 class="title is-6 mb-3">Manual Metadata</h4>
            <div class="manual-exif-row mb-2 is-hidden">
              <span class="has-text-grey-dark is-size-7 mr-2">Caption:</span>
              <span id="manual-caption-display"></span>
            </div>
            <div class="manual-exif-row mb-2 is-hidden">
              <span class="has-text-grey-dark is-size-7 mr-2">Location:</span>
              <span id="manual-location-display"></span>
            </div>
            <div class="manual-exif-row is-hidden">
              <span class="has-text-grey-dark is-size-7 mr-2">Date Taken:</span>
              <span id="manual-date-taken-display"></span>
            </div>
          </div>
        <% } %>

      </div><!-- /.column.is-7 -->

      <!-- Sidebar Column -->
      <div class="column is-5">

        <!-- Tags -->
        <div class="box">
          <h4 class="title is-6 mb-3">
            <span class="icon is-small"><i class="fas fa-tags"></i></span>
            Tags
          </h4>
          <div id="image-tags" class="tags">
            <% if (image.Tags && image.Tags.length > 0) { %>
              <% image.Tags.forEach(tag => { %>
                <span class="tag is-info is-light">
                  <a href="/gallery?tag=<%= tag.name %>" class="has-text-info"><%= tag.name %></a>
                </span>
              <% }); %>
            <% } else { %>
              <span class="has-text-grey-light is-size-7">No tags yet</span>
            <% } %>
          </div>
          <!-- Tag management partial -->
          <%- include('./partials/tag-cloud', { image: image, tags: tags || [] }) %>
        </div>

        <!-- EXIF Data -->
        <% if (exifData && Object.keys(exifData).length > 0) { %>
          <div class="box">
            <h4 class="title is-6 mb-3">
              <span class="icon is-small"><i class="fas fa-camera"></i></span>
              EXIF Data
            </h4>
            <%- include('./partials/exif-table', { exifData: exifData }) %>
          </div>
        <% } %>

        <!-- Image Info -->
        <div class="box">
          <h4 class="title is-6 mb-3">
            <span class="icon is-small"><i class="fas fa-info-circle"></i></span>
            Image Info
          </h4>
          <table class="table is-narrow is-fullwidth is-size-7">
            <tbody>
              <% if (image.originalName) { %>
                <tr>
                  <td class="has-text-grey-dark">Filename</td>
                  <td><%= image.originalName %></td>
                </tr>
              <% } %>
              <% if (image.mimeType) { %>
                <tr>
                  <td class="has-text-grey-dark">Type</td>
                  <td><%= image.mimeType %></td>
                </tr>
              <% } %>
              <% if (image.width && image.height) { %>
                <tr>
                  <td class="has-text-grey-dark">Dimensions</td>
                  <td><%= image.width %> × <%= image.height %>px</td>
                </tr>
              <% } %>
              <% if (image.fileSize) { %>
                <tr>
                  <td class="has-text-grey-dark">File Size</td>
                  <td><%= (image.fileSize / 1024 / 1024).toFixed(2) %> MB</td>
                </tr>
              <% } %>
              <% if (image.rotation) { %>
                <tr>
                  <td class="has-text-grey-dark">Rotation</td>
                  <td><%= image.rotation %>°</td>
                </tr>
              <% } %>
              <% if (image.createdAt) { %>
                <tr>
                  <td class="has-text-grey-dark">Uploaded</td>
                  <td><%= new Date(image.createdAt).toLocaleDateString() %></td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <!-- Map (if coordinates available) -->
        <% if (exifData && exifData.gps && exifData.gps.latitude && exifData.gps.longitude) { %>
          <%- include('./partials/map', { lat: exifData.gps.latitude, lng: exifData.gps.longitude }) %>
        <% } %>

      </div><!-- /.column.is-5 -->
    </div><!-- /.columns -->

    <!-- Edit Panel (slide-in) -->
    <%- include('./partials/edit-panel', { image: image }) %>

  </div><!-- /.container -->
</section>

<script src="/js/imageEditor.js"></script>