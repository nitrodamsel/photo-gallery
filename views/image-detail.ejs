<%- include('layouts/base', { title: image.originalName || 'Image Detail', body: `

<section class="section">
  <div class="container">

    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="breadcrumbs">
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/gallery">Gallery</a></li>
        <li class="is-active"><a href="#" aria-current="page">${image.originalName || 'Image'}</a></li>
      </ul>
    </nav>

    <div id="image-detail-container" data-image-id="${image.id}">

      <!-- Top toolbar -->
      <div class="level mb-4">
        <div class="level-left">
          <div class="level-item">
            <h1 class="title is-4">${image.originalName || 'Image Detail'}</h1>
          </div>
        </div>
        <div class="level-right">
          <div class="level-item">
            <button id="edit-panel-toggle" class="button is-info" type="button">
              <span class="icon"><i class="fas fa-edit"></i></span>
              <span>Edit Image</span>
            </button>
          </div>
          <div class="level-item">
            <a href="/gallery" class="button is-light">
              <span class="icon"><i class="fas fa-arrow-left"></i></span>
              <span>Back to Gallery</span>
            </a>
          </div>
        </div>
      </div>

      <div class="columns">

        <!-- Main Image Column -->
        <div class="column is-7">
          <div class="image-preview-container has-text-centered">
            <figure class="image">
              <img
                id="main-image-preview"
                src="/uploads/${image.filename}"
                alt="${image.originalName || 'Image'}"
                style="max-width:100%; height:auto; transition: transform 0.3s ease; transform: rotate(${image.rotation || 0}deg);"
              />
            </figure>
          </div>

          <!-- Description Display -->
          <div class="mt-4">
            <% if (image.description) { %>
              <p id="image-description-display" class="content">${image.description}</p>
            <% } else { %>
              <p id="image-description-display" class="content has-text-grey-light"><em>No description</em></p>
            <% } %>
          </div>

          <!-- Manual EXIF Overrides Display -->
          <% const manualExif = image.manualExif || {}; %>
          <% if (manualExif.caption || manualExif.locationName || manualExif.dateTaken) { %>
            <div class="box mt-3">
              <h5 class="title is-6">Manual Metadata</h5>
              <% if (manualExif.caption) { %>
                <p><strong>Caption:</strong> <span id="manual-caption-display">${manualExif.caption}</span></p>
              <% } %>
              <% if (manualExif.locationName) { %>
                <p><strong>Location:</strong> <span id="manual-location-display">${manualExif.locationName}</span></p>
              <% } %>
              <% if (manualExif.dateTaken) { %>
                <p><strong>Date Taken:</strong> <span id="manual-date-display">${manualExif.dateTaken}</span></p>
              <% } %>
            </div>
          <% } else { %>
            <div id="manual-caption-display" class="is-hidden"></div>
            <div id="manual-location-display" class="is-hidden"></div>
            <div id="manual-date-display" class="is-hidden"></div>
          <% } %>
        </div>

        <!-- Sidebar Column -->
        <div class="column is-5">

          <!-- Edit Panel (initially hidden) -->
          <%- include('partials/edit-panel', { image }) %>

          <!-- Image Metadata -->
          <div class="box">
            <h4 class="title is-5">Image Info</h4>
            <table class="table is-fullwidth is-bordered is-striped is-narrow">
              <tbody>
                <tr>
                  <th>Filename</th>
                  <td>${image.originalName || image.filename}</td>
                </tr>
                <% if (image.width && image.height) { %>
                <tr>
                  <th>Dimensions</th>
                  <td>${image.width} × ${image.height}px</td>
                </tr>
                <% } %>
                <% if (image.fileSize) { %>
                <tr>
                  <th>File Size</th>
                  <td>${(image.fileSize / 1024).toFixed(1)} KB</td>
                </tr>
                <% } %>
                <% if (image.mimeType) { %>
                <tr>
                  <th>Type</th>
                  <td>${image.mimeType}</td>
                </tr>
                <% } %>
                <% if (image.rotation) { %>
                <tr>
                  <th>Rotation</th>
                  <td>${image.rotation}°</td>
                </tr>
                <% } %>
                <tr>
                  <th>Uploaded</th>
                  <td>${new Date(image.createdAt).toLocaleDateString()}</td>
                </tr>
              </tbody>
            </table>
          </div>

          <!-- Tags -->
          <div class="box">
            <h4 class="title is-5">Tags</h4>
            <% if (tags && tags.length > 0) { %>
              <div class="tags">
                <% tags.forEach(tag => { %>
                  <a href="/gallery?tag=${tag.name}" class="tag is-info is-medium">${tag.name}</a>
                <% }) %>
              </div>
            <% } else { %>
              <p class="has-text-grey-light"><em>No tags</em></p>
            <% } %>
            <%- include('partials/tag-cloud', { tags: tags || [] }) %>
          </div>

          <!-- EXIF Data -->
          <% if (image.exifData && Object.keys(image.exifData).length > 0) { %>
            <div class="box">
              <h4 class="title is-5">EXIF Data</h4>
              <%- include('partials/exif-table', { exifData: image.exifData }) %>
            </div>
          <% } %>

          <!-- Map (if GPS data available) -->
          <% if (image.latitude && image.longitude) { %>
            <%- include('partials/map', { image }) %>
          <% } %>

        </div>
      </div>
    </div>
  </div>
</section>

` }) %>