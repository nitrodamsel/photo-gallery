<%- include('layouts/base', { title: image.originalName || image.filename, body: `
<section class="section">
  <div class="container" id="image-detail-container" data-image-id="${image.id}">

    <!-- Breadcrumb -->
    <nav class="breadcrumb mb-4" aria-label="breadcrumbs">
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/gallery">Gallery</a></li>
        <li class="is-active"><a href="#" aria-current="page">${image.originalName || image.filename}</a></li>
      </ul>
    </nav>

    <!-- Page Header -->
    <div class="level mb-4">
      <div class="level-left">
        <div class="level-item">
          <h1 class="title is-4 mb-0">${image.originalName || image.filename}</h1>
        </div>
      </div>
      <div class="level-right">
        <div class="level-item">
          <div class="buttons">
            <button id="edit-toggle-btn" class="button is-primary is-light">
              ✏️ Edit
            </button>
            <a href="/gallery" class="button is-light">
              <span class="icon"><i class="fas fa-arrow-left"></i></span>
              <span>Back to Gallery</span>
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="columns">

      <!-- Main Image Column -->
      <div class="column is-8">
        <div class="card">
          <div class="card-image">
            <figure class="image" style="text-align: center; background: #1a1a1a; min-height: 300px; display: flex; align-items: center; justify-content: center;">
              <img
                id="main-image"
                src="/uploads/${image.filename}"
                alt="${image.originalName || image.filename}"
                style="max-width: 100%; max-height: 75vh; object-fit: contain; cursor: zoom-in;"
                onclick="this.style.maxHeight = this.style.maxHeight === 'none' ? '75vh' : 'none';"
              >
            </figure>
          </div>
          <div class="card-content">
            <div class="content">
              <p id="image-description-display" style="${image.description ? '' : 'display:none;'}">
                ${image.description || ''}
              </p>
              <p class="has-text-grey is-size-7">
                Uploaded: ${new Date(image.createdAt).toLocaleString()}
                ${image.fileSize ? ` &bull; ${(image.fileSize / 1024 / 1024).toFixed(2)} MB` : ''}
                ${image.width && image.height ? ` &bull; ${image.width} &times; ${image.height}px` : ''}
                ${image.mimeType ? ` &bull; ${image.mimeType}` : ''}
              </p>
            </div>
          </div>
        </div>

        <!-- Navigation between images -->
        <div class="level mt-3">
          <div class="level-left">
            ${typeof prevImage !== 'undefined' && prevImage ? `<a href="/gallery/${prevImage.id}" class="button is-light">← Previous</a>` : '<span></span>'}
          </div>
          <div class="level-right">
            ${typeof nextImage !== 'undefined' && nextImage ? `<a href="/gallery/${nextImage.id}" class="button is-light">Next →</a>` : '<span></span>'}
          </div>
        </div>
      </div>

      <!-- Sidebar Column -->
      <div class="column is-4">

        <!-- Tags -->
        <div class="card mb-4">
          <div class="card-header">
            <p class="card-header-title">Tags</p>
          </div>
          <div class="card-content">
            <div class="tags" id="image-tags-container">
              ${(image.Tags && image.Tags.length > 0)
                ? image.Tags.map(tag => `<span class="tag is-info is-light"><a href="/gallery?tag=${encodeURIComponent(tag.name)}" class="has-text-info">${tag.name}</a></span>`).join('')
                : '<span class="has-text-grey is-size-7">No tags yet</span>'
              }
            </div>
            <div class="field has-addons mt-3" id="add-tag-form">
              <div class="control is-expanded">
                <input class="input is-small" type="text" id="new-tag-input" placeholder="Add tag...">
              </div>
              <div class="control">
                <button class="button is-small is-info" id="add-tag-btn">Add</button>
              </div>
            </div>
          </div>
        </div>

        <!-- Manual EXIF Overrides Display -->
        <% const hasManualExif = image.manualExif && Object.keys(image.manualExif).some(k => image.manualExif[k]); %>
        <% if (hasManualExif) { %>
        <div class="card mb-4">
          <div class="card-header">
            <p class="card-header-title">
              <span class="icon mr-1"><i class="fas fa-pen"></i></span>
              Manual Info
            </p>
          </div>
          <div class="card-content p-4">
            <table class="table is-fullwidth is-size-7">
              <tbody>
                <% if (image.manualExif.caption) { %>
                <tr>
                  <th class="has-text-grey" style="white-space: nowrap; width: 40%;">Caption</th>
                  <td id="display-caption"><%= image.manualExif.caption %></td>
                </tr>
                <% } %>
                <% if (image.manualExif.location) { %>
                <tr>
                  <th class="has-text-grey" style="white-space: nowrap;">Location</th>
                  <td id="display-location"><%= image.manualExif.location %></td>
                </tr>
                <% } %>
                <% if (image.manualExif.dateTaken) { %>
                <tr>
                  <th class="has-text-grey" style="white-space: nowrap;">Date Taken</th>
                  <td id="display-date-taken"><%= image.manualExif.dateTaken %></td>
                </tr>
                <% } %>
                <% if (image.manualExif.camera) { %>
                <tr>
                  <th class="has-text-grey" style="white-space: nowrap;">Camera</th>
                  <td id="display-camera"><%= image.manualExif.camera %></td>
                </tr>
                <% } %>
                <% if (image.manualExif.lens) { %>
                <tr>
                  <th class="has-text-grey" style="white-space: nowrap;">Lens</th>
                  <td id="display-lens"><%= image.manualExif.lens %></td>
                </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
        <% } else { %>
        <!-- Hidden elements for JS updates -->
        <span id="display-caption" style="display:none"></span>
        <span id="display-location" style="display:none"></span>
        <span id="display-date-taken" style="display:none"></span>
        <span id="display-camera" style="display:none"></span>
        <span id="display-lens" style="display:none"></span>
        <% } %>

        <!-- EXIF Data -->
        <%- include('partials/exif-table', { image }) %>

        <!-- Map (if GPS data) -->
        <% if (image.latitude && image.longitude) { %>
          <%- include('partials/map', { image }) %>
        <% } %>

      </div>
    </div>

  </div><!-- /.container -->
</section>

<!-- Edit Panel (slide-in) -->
<%- include('partials/edit-panel', { image }) %>

<!-- Scripts -->
<script src="/js/imageEditor.js"></script>
<script src="/js/tagging.js"></script>
` }) %>