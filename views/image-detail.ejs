<%- include('layouts/base', { title: title, body: `
<div class="image-detail-page">
  <div class="container">

    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/gallery">Gallery</a>
      <span class="breadcrumb-sep">›</span>
      <span class="breadcrumb-current"><%= image.original_filename || ('Image #' + image.id) %></span>
    </nav>

    <!-- Prev/Next Navigation -->
    <div class="image-nav">
      <% if (prev) { %>
        <a href="/gallery/<%= prev.id %>" class="nav-btn nav-prev" aria-label="Previous image">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
          Previous
        </a>
      <% } else { %>
        <span class="nav-btn nav-prev disabled">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
          Previous
        </span>
      <% } %>

      <a href="/gallery" class="nav-btn nav-gallery">All Photos</a>

      <% if (next) { %>
        <a href="/gallery/<%= next.id %>" class="nav-btn nav-next" aria-label="Next image">
          Next
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </a>
      <% } else { %>
        <span class="nav-btn nav-next disabled">
          Next
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </span>
      <% } %>
    </div>

    <div class="detail-layout">
      <!-- Left column: Image -->
      <div class="detail-image-col">
        <div class="detail-image-wrapper" id="lightbox-trigger" data-src="<%= image.thumbnailUrl %>">
          <img
            src="<%= image.thumbnailUrl %>"
            alt="<%= (image.original_filename || 'Photo') + (image.exif_data && image.exif_data.camera ? ' taken with ' + image.exif_data.camera : '') %>"
            class="detail-image"
            loading="lazy"
          />
          <div class="lightbox-overlay">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/></svg>
          </div>
        </div>
      </div>

      <!-- Right column: Metadata -->
      <div class="detail-meta-col">

        <!-- File title -->
        <div class="detail-title-section">
          <h1 class="detail-filename"><%= image.original_filename || ('Image #' + image.id) %></h1>
          <% if (image.created_at) { %>
            <p class="detail-upload-date">Uploaded <%= new Date(image.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></p>
          <% } %>
        </div>

        <!-- Tags -->
        <div class="detail-section">
          <h2 class="section-title">Tags</h2>
          <div class="tag-list">
            <% if (image.tags && image.tags.length > 0) { %>
              <% image.tags.forEach(function(tag) { %>
                <a href="/gallery?tag=<%= tag.slug %>" class="tag-badge">
                  <%= tag.name %>
                </a>
              <% }); %>
            <% } else { %>
              <span class="no-tags">No tags assigned</span>
            <% } %>
          </div>
        </div>

        <!-- File Info -->
        <div class="detail-section">
          <h2 class="section-title">File Info</h2>
          <dl class="info-list">
            <% if (image.file_size) { %>
              <div class="info-row">
                <dt>File Size</dt>
                <dd><%= formatFileSize(image.file_size) %></dd>
              </div>
            <% } %>
            <% if (image.width && image.height) { %>
              <div class="info-row">
                <dt>Dimensions</dt>
                <dd><%= image.width %> × <%= image.height %> px</dd>
              </div>
            <% } %>
            <% if (image.mime_type) { %>
              <div class="info-row">
                <dt>Type</dt>
                <dd><%= image.mime_type %></dd>
              </div>
            <% } %>
            <% if (image.created_at) { %>
              <div class="info-row">
                <dt>Uploaded</dt>
                <dd><%= new Date(image.created_at).toLocaleString() %></dd>
              </div>
            <% } %>
          </dl>
        </div>

        <!-- EXIF Data Accordion -->
        <% if (image.exif_data && Object.keys(image.exif_data).length > 0) { %>
          <div class="detail-section">
            <details class="exif-accordion" open>
              <summary class="section-title exif-summary">
                EXIF Data
                <svg class="accordion-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </summary>
              <%- include('partials/exif-table', { exif: image.exif_data }) %>
            </details>
          </div>
        <% } %>

        <!-- GPS Map -->
        <% if (image.latitude && image.longitude) { %>
          <div class="detail-section">
            <h2 class="section-title">Location</h2>
            <%- include('partials/map', { lat: image.latitude, lng: image.longitude }) %>
          </div>
        <% } %>

      </div>
    </div>

  </div>
</div>

<!-- Lightbox Modal -->
<div class="lightbox-modal" id="lightbox-modal" role="dialog" aria-modal="true" aria-label="Image lightbox" hidden>
  <button class="lightbox-close" id="lightbox-close" aria-label="Close lightbox">
    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
  </button>
  <img id="lightbox-img" src="" alt="" class="lightbox-img" />
</div>

<script>
(function() {
  const trigger = document.getElementById('lightbox-trigger');
  const modal = document.getElementById('lightbox-modal');
  const closeBtn = document.getElementById('lightbox-close');
  const lightboxImg = document.getElementById('lightbox-img');

  if (trigger && modal) {
    trigger.addEventListener('click', function() {
      lightboxImg.src = trigger.dataset.src;
      lightboxImg.alt = document.querySelector('.detail-image').alt;
      modal.hidden = false;
      document.body.style.overflow = 'hidden';
      closeBtn.focus();
    });

    closeBtn.addEventListener('click', closeLightbox);
    modal.addEventListener('click', function(e) {
      if (e.target === modal) closeLightbox();
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && !modal.hidden) closeLightbox();
    });

    function closeLightbox() {
      modal.hidden = true;
      document.body.style.overflow = '';
      trigger.focus();
    }
  }
})();
</script>
` }) %>