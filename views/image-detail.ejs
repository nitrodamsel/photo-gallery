<%- include('layouts/base', { title: title || 'Image Detail', activePage: 'gallery', body: `
<div class="container py-4">
  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/">Home</a></li>
      <li class="breadcrumb-item"><a href="/gallery">Gallery</a></li>
      <li class="breadcrumb-item active" aria-current="page">${image.originalName || image.filename}</li>
    </ol>
  </nav>

  <div class="row g-4">
    <!-- Image -->
    <div class="col-lg-8">
      <div class="card shadow-sm">
        <div class="text-center bg-dark rounded-top" style="max-height:600px;overflow:hidden;">
          <img src="/uploads/${image.filename}"
            class="img-fluid"
            style="max-height:600px;object-fit:contain;"
            alt="${image.originalName || image.filename}">
        </div>
        <div class="card-body">
          <h1 class="h4 card-title">${image.originalName || image.filename}</h1>

          <!-- Tags Section -->
          <div class="mb-3">
            <h6 class="text-muted mb-2"><i class="bi bi-tags me-1"></i>Tags</h6>
            <div id="tagContainer" class="d-flex flex-wrap align-items-center gap-1 mb-2">
              ${(image.Tags || []).map(tag => `
                <span class="badge me-1 mb-1 tag-badge d-inline-flex align-items-center"
                  style="background-color:${tag.color || '#6c757d'};font-size:0.85rem;"
                  data-tag-id="${tag.id}">
                  <a href="/gallery?tag=${tag.slug}" class="text-white text-decoration-none me-1">${tag.name}</a>
                  <button type="button"
                    class="btn-close btn-close-white btn-sm ms-1 tag-remove-btn"
                    aria-label="Remove tag"
                    style="font-size:0.6rem;filter:brightness(2);"
                    onclick="removeTag(${image.id}, ${tag.id})">
                  </button>
                </span>
              `).join('')}

              <!-- Add tag form -->
              <span class="tag-add-form">
                <form id="tagAddForm" class="d-inline-flex align-items-center gap-1">
                  <input type="text" id="tagInput" class="form-control form-control-sm"
                    list="tagSuggestions"
                    placeholder="Add tag..."
                    style="width:140px;"
                    minlength="2" maxlength="30"
                    autocomplete="off">
                  <datalist id="tagSuggestions"></datalist>
                  <button type="submit" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-plus-lg"></i>
                  </button>
                </form>
              </span>
            </div>
            <div id="tagAlert" class="d-none"></div>
          </div>

          <!-- Description if available -->
          ${image.description ? `<p class="card-text text-muted">${image.description}</p>` : ''}
        </div>
      </div>
    </div>

    <!-- Sidebar: Metadata -->
    <div class="col-lg-4">
      <!-- File Info -->
      <div class="card shadow-sm mb-3">
        <div class="card-header">
          <h5 class="mb-0"><i class="bi bi-info-circle me-2"></i>File Info</h5>
        </div>
        <div class="card-body p-0">
          <table class="table table-sm mb-0">
            <tbody>
              <tr>
                <td class="text-muted">Filename</td>
                <td class="text-break small">${image.filename}</td>
              </tr>
              ${image.fileSize ? `
              <tr>
                <td class="text-muted">Size</td>
                <td>${formatFileSize(image.fileSize)}</td>
              </tr>` : ''}
              ${image.mimeType ? `
              <tr>
                <td class="text-muted">Type</td>
                <td>${image.mimeType}</td>
              </tr>` : ''}
              ${image.width && image.height ? `
              <tr>
                <td class="text-muted">Dimensions</td>
                <td>${image.width} × ${image.height}</td>
              </tr>` : ''}
              <tr>
                <td class="text-muted">Uploaded</td>
                <td>${new Date(image.createdAt).toLocaleDateString()}</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- EXIF Data -->
      ${typeof exifData !== 'undefined' && exifData ? `
      <div class="card shadow-sm mb-3">
        <div class="card-header">
          <h5 class="mb-0"><i class="bi bi-camera me-2"></i>EXIF Data</h5>
        </div>
        <div class="card-body p-0">
          <%- include('partials/exif-table', { exifData }) %>
        </div>
      </div>` : ''}

      <!-- Map -->
      ${typeof hasGps !== 'undefined' && hasGps ? `
      <div class="card shadow-sm mb-3">
        <div class="card-header">
          <h5 class="mb-0"><i class="bi bi-geo-alt me-2"></i>Location</h5>
        </div>
        <div class="card-body p-0">
          <%- include('partials/map', { lat, lng }) %>
        </div>
      </div>` : ''}

      <!-- Actions -->
      <div class="card shadow-sm">
        <div class="card-body">
          <div class="d-grid gap-2">
            <a href="/uploads/${image.filename}" class="btn btn-outline-primary" download>
              <i class="bi bi-download me-2"></i>Download
            </a>
            <a href="/gallery" class="btn btn-outline-secondary">
              <i class="bi bi-arrow-left me-2"></i>Back to Gallery
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="/js/tagging.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    initImageTagging(${image.id});
  });

  function formatFileSize(bytes) {
    if (!bytes) return 'Unknown';
    const k = 1024;
    const sizes = ['B', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(1)) + ' ' + sizes[i];
  }
</script>
` }) %>