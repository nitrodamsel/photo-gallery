<div class="image-detail-page">

  <!-- Prev / Next navigation -->
  <nav class="detail-nav" aria-label="Image navigation">
    <% if (typeof prevImage !== 'undefined' && prevImage) { %>
      <a href="/gallery/<%= prevImage.id %>" class="nav-btn nav-prev" aria-label="Previous image">
        &#8592; Previous
      </a>
    <% } else { %>
      <span class="nav-btn nav-prev disabled" aria-disabled="true">&#8592; Previous</span>
    <% } %>

    <a href="/gallery" class="nav-btn nav-gallery">Back to Gallery</a>

    <% if (typeof nextImage !== 'undefined' && nextImage) { %>
      <a href="/gallery/<%= nextImage.id %>" class="nav-btn nav-next" aria-label="Next image">
        Next &#8594;
      </a>
    <% } else { %>
      <span class="nav-btn nav-next disabled" aria-disabled="true">Next &#8594;</span>
    <% } %>
  </nav>

  <div class="detail-layout">

    <!-- Left column: image -->
    <div class="detail-image-col">
      <% 
        var ext = image.original_filename ? image.original_filename.split('.').pop() : 'jpg';
        var base = image.stored_filename ? image.stored_filename.replace(/\.[^.]+$/, '') : (image.original_filename ? image.original_filename.replace(/\.[^.]+$/, '') : 'image');
        var thumb1200 = '/uploads/thumbnails/' + base + '_1200.' + ext;
        var thumbFull = '/uploads/' + (image.stored_filename || image.original_filename);
        var altText = (image.original_filename || 'Image') + (image.camera_make ? ' — ' + image.camera_make + (image.camera_model ? ' ' + image.camera_model : '') : '');
      %>
      <a href="<%= thumbFull %>" class="lightbox-trigger" 
         data-lightbox="image-<%= image.id %>" 
         data-title="<%= altText %>">
        <img 
          src="<%= thumb1200 %>" 
          alt="<%= altText %>"
          class="detail-image"
          onerror="this.src='/uploads/<%= image.stored_filename || image.original_filename %>'"
        />
        <span class="lightbox-hint" aria-hidden="true">Click to enlarge</span>
      </a>
    </div>

    <!-- Right column: metadata -->
    <div class="detail-meta-col">

      <!-- Image title -->
      <h1 class="detail-title"><%= image.original_filename || ('Image #' + image.id) %></h1>

      <!-- Tags section -->
      <section class="detail-section tags-section" aria-labelledby="tags-heading">
        <h2 id="tags-heading" class="section-heading">Tags</h2>
        <div class="tag-list">
          <% if (image.tags && image.tags.length > 0) { %>
            <% image.tags.forEach(function(tag) { %>
              <span class="tag-item">
                <a href="/gallery?tag=<%= tag.slug %>" class="tag-badge"><%= tag.name %></a>
                <button 
                  class="tag-remove" 
                  data-image-id="<%= image.id %>" 
                  data-tag-id="<%= tag.id %>"
                  aria-label="Remove tag <%= tag.name %>"
                  title="Remove tag"
                >&#10005;</button>
              </span>
            <% }) %>
          <% } else { %>
            <span class="no-tags">No tags assigned.</span>
          <% } %>
          <!-- Add tag UI scaffold -->
          <div class="add-tag-form" style="margin-top: 0.5rem;">
            <input 
              type="text" 
              id="new-tag-input" 
              placeholder="Add a tag..." 
              class="tag-input"
              aria-label="New tag name"
              data-image-id="<%= image.id %>"
            />
            <button class="btn btn-sm btn-secondary" id="add-tag-btn">Add</button>
          </div>
        </div>
      </section>

      <!-- EXIF Data accordion -->
      <section class="detail-section exif-section" aria-labelledby="exif-heading">
        <h2 id="exif-heading" class="section-heading accordion-toggle" 
            role="button" tabindex="0" aria-expanded="true" aria-controls="exif-content">
          EXIF Data
          <span class="accordion-icon" aria-hidden="true">&#9660;</span>
        </h2>
        <div id="exif-content" class="accordion-content">
          <%- include('partials/exif-table', { image: image }) %>
        </div>
      </section>

      <!-- GPS Map -->
      <% if (image.gps_latitude && image.gps_longitude) { %>
        <section class="detail-section map-section" aria-labelledby="map-heading">
          <h2 id="map-heading" class="section-heading">Location</h2>
          <%- include('partials/map', { 
            lat: image.gps_latitude, 
            lng: image.gps_longitude,
            label: image.original_filename || ('Image #' + image.id)
          }) %>
        </section>
      <% } %>

      <!-- File info -->
      <section class="detail-section file-info-section" aria-labelledby="fileinfo-heading">
        <h2 id="fileinfo-heading" class="section-heading">File Information</h2>
        <dl class="file-info-list">
          <% if (image.file_size) { %>
            <dt>File Size</dt>
            <dd><%= formatFileSize(image.file_size) %></dd>
          <% } %>
          <% if (image.image_width && image.image_height) { %>
            <dt>Dimensions</dt>
            <dd><%= image.image_width %> &times; <%= image.image_height %> px</dd>
          <% } %>
          <% if (image.mime_type) { %>
            <dt>Type</dt>
            <dd><%= image.mime_type %></dd>
          <% } %>
          <% if (image.created_at) { %>
            <dt>Upload Date</dt>
            <dd><%= new Date(image.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></dd>
          <% } %>
          <% if (image.date_taken) { %>
            <dt>Date Taken</dt>
            <dd><%= new Date(image.date_taken).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></dd>
          <% } %>
        </dl>
      </section>

    </div><!-- end detail-meta-col -->
  </div><!-- end detail-layout -->
</div><!-- end image-detail-page -->

<script>
// Accordion toggle
document.querySelectorAll('.accordion-toggle').forEach(function(toggle) {
  toggle.addEventListener('click', function() {
    var expanded = this.getAttribute('aria-expanded') === 'true';
    this.setAttribute('aria-expanded', !expanded);
    var contentId = this.getAttribute('aria-controls');
    var content = document.getElementById(contentId);
    if (content) {
      content.style.display = expanded ? 'none' : 'block';
    }
    var icon = this.querySelector('.accordion-icon');
    if (icon) icon.textContent = expanded ? '▶' : '▼';
  });
  toggle.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      this.click();
    }
  });
});

// Tag remove buttons (scaffold - would need API endpoint)
document.querySelectorAll('.tag-remove').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var imageId = this.dataset.imageId;
    var tagId = this.dataset.tagId;
    if (confirm('Remove this tag?')) {
      fetch('/api/images/' + imageId + '/tags/' + tagId, { method: 'DELETE' })
        .then(function(res) {
          if (res.ok) location.reload();
          else alert('Failed to remove tag.');
        })
        .catch(function() { alert('Failed to remove tag.'); });
    }
  });
});

// Add tag (scaffold)
document.getElementById('add-tag-btn').addEventListener('click', function() {
  var input = document.getElementById('new-tag-input');
  var imageId = input.dataset.imageId;
  var tagName = input.value.trim();
  if (!tagName) return;
  fetch('/api/images/' + imageId + '/tags', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ name: tagName }),
  })
    .then(function(res) {
      if (res.ok) location.reload();
      else alert('Failed to add tag.');
    })
    .catch(function() { alert('Failed to add tag.'); });
});
</script>