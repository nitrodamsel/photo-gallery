<%- include('layouts/base', { title: image.originalName || 'Image Detail', body: `

<div class="image-detail-page">

  <!-- Breadcrumb & Actions Bar -->
  <div class="detail-header">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/gallery" class="breadcrumb__link">← Gallery</a>
      <span class="breadcrumb__sep">/</span>
      <span class="breadcrumb__current" id="imageTitle">${image.originalName || 'Image'}</span>
    </nav>

    <div class="detail-header__actions">
      <a href="/uploads/${image.filename}" download class="btn btn--secondary">
        ⬇ Download
      </a>
      <button id="editToggleBtn" class="btn btn--primary">✏️ Edit</button>
    </div>
  </div>

  <!-- Main Content -->
  <div class="detail-layout">

    <!-- Image Preview -->
    <div class="detail-image-wrapper">
      <img
        id="imagePreview"
        src="/uploads/${image.filename}"
        alt="${image.description || image.originalName || 'Image'}"
        class="detail-image"
        style="transform: rotate(${image.rotation || 0}deg);"
      >
    </div>

    <!-- Sidebar -->
    <div class="detail-sidebar">

      <!-- Description -->
      <% if (image.description) { %>
        <div class="detail-section">
          <h3 class="detail-section__title">Description</h3>
          <p id="imageDescription" class="detail-description"><%= image.description %></p>
        </div>
      <% } else { %>
        <p id="imageDescription" class="detail-description" style="display:none;"></p>
      <% } %>

      <!-- Tags -->
      <div class="detail-section">
        <h3 class="detail-section__title">Tags</h3>
        <% if (image.Tags && image.Tags.length > 0) { %>
          <div class="tag-list">
            <% image.Tags.forEach(tag => { %>
              <a href="/gallery?tag=<%= tag.id %>" class="tag-badge"><%= tag.name %></a>
            <% }); %>
          </div>
        <% } else { %>
          <p class="text-muted">No tags yet.</p>
        <% } %>
      </div>

      <!-- EXIF Data -->
      <% if (locals.exifData && Object.keys(exifData).length > 0) { %>
        <div class="detail-section">
          <h3 class="detail-section__title">EXIF Data</h3>
          <%- include('partials/exif-table', { exifData, image }) %>
        </div>
      <% } %>

      <!-- Image Info -->
      <div class="detail-section">
        <h3 class="detail-section__title">File Info</h3>
        <table class="info-table">
          <tbody>
            <tr>
              <th>Filename</th>
              <td><%= image.originalName || image.filename %></td>
            </tr>
            <% if (image.width && image.height) { %>
            <tr>
              <th>Dimensions</th>
              <td><%= image.width %> × <%= image.height %> px</td>
            </tr>
            <% } %>
            <% if (image.fileSize) { %>
            <tr>
              <th>File Size</th>
              <td><%= (image.fileSize / 1024 / 1024).toFixed(2) %> MB</td>
            </tr>
            <% } %>
            <% if (image.mimeType) { %>
            <tr>
              <th>Type</th>
              <td><%= image.mimeType %></td>
            </tr>
            <% } %>
            <% if (image.rotation) { %>
            <tr>
              <th>Rotation</th>
              <td><%= image.rotation %>°</td>
            </tr>
            <% } %>
            <tr>
              <th>Uploaded</th>
              <td><%= new Date(image.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></td>
            </tr>
          </tbody>
        </table>
      </div>

    </div>
  </div>

  <!-- Edit Panel (slide-in) -->
  <%- include('partials/edit-panel', { image }) %>

</div>

` }) %>