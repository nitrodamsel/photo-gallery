<%- include('layouts/base', { title: image.originalName || 'Image Detail', body: `
<div class="container mt-4">
  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/">Home</a></li>
      <li class="breadcrumb-item"><a href="/gallery">Gallery</a></li>
      <li class="breadcrumb-item active" aria-current="page">${escapeHtml(image.originalName || 'Image')}</li>
    </ol>
  </nav>

  <div class="row g-4">
    <!-- Image Panel -->
    <div class="col-lg-8">
      <div class="card shadow-sm">
        <div class="card-body p-2 text-center bg-dark">
          <img
            src="/uploads/${image.storedName || image.filename}"
            alt="${escapeHtml(image.originalName || 'Image')}"
            class="img-fluid rounded"
            style="max-height:70vh;object-fit:contain;"
          />
        </div>
      </div>
    </div>

    <!-- Info Panel -->
    <div class="col-lg-4">
      <!-- Tags Section -->
      <div class="card shadow-sm mb-3">
        <div class="card-header">
          <h6 class="mb-0"><i class="bi bi-tags-fill me-2"></i>Tags</h6>
        </div>
        <div class="card-body">
          <!-- Tag List -->
          <div id="tag-list-container" class="mb-3">
            ${(image.Tags && image.Tags.length > 0)
              ? image.Tags.map(tag => \`
                <span class="badge me-1 mb-1 tag-badge d-inline-flex align-items-center"
                      style="background-color:\${tag.color || '#6c757d'};font-size:0.9rem;">
                  <a href="/gallery?tag=\${encodeURIComponent(tag.name)}"
                     class="text-white text-decoration-none me-1">
                    \${escapeHtml(tag.name)}
                  </a>
                  <button
                    type="button"
                    class="btn-close btn-close-white ms-1"
                    style="font-size:0.6rem;"
                    aria-label="Remove tag"
                    onclick="removeTag(${image.id}, \${tag.id})"
                  ></button>
                </span>
              \`).join('')
              : '<span class="text-muted fst-italic">No tags yet.</span>'
            }
          </div>

          <!-- Add Tag Form -->
          <form id="tagForm" class="mt-2">
            <div class="input-group input-group-sm">
              <input
                type="text"
                id="tagInput"
                class="form-control"
                placeholder="Add a tag..."
                list="tagSuggestions"
                maxlength="30"
                autocomplete="off"
              />
              <datalist id="tagSuggestions"></datalist>
              <button type="submit" id="addTagBtn" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> Add
              </button>
            </div>
            <div id="tagError" class="text-danger small mt-1 d-none"></div>
            <div class="form-text">2–30 chars, letters, numbers, hyphens, spaces.</div>
          </form>
        </div>
      </div>

      <!-- Image Metadata -->
      <div class="card shadow-sm mb-3">
        <div class="card-header">
          <h6 class="mb-0"><i class="bi bi-info-circle me-2"></i>Details</h6>
        </div>
        <div class="card-body small">
          <table class="table table-sm table-borderless mb-0">
            <tbody>
              <tr>
                <th class="text-muted ps-0" style="width:40%">Filename</th>
                <td class="text-truncate" style="max-width:150px;" title="${escapeHtml(image.originalName || '')}">${escapeHtml(image.originalName || 'N/A')}</td>
              </tr>
              <tr>
                <th class="text-muted ps-0">Size</th>
                <td>${image.fileSize ? formatBytes(image.fileSize) : 'N/A'}</td>
              </tr>
              <tr>
                <th class="text-muted ps-0">MIME Type</th>
                <td>${escapeHtml(image.mimeType || 'N/A')}</td>
              </tr>
              ${image.width && image.height ? \`
              <tr>
                <th class="text-muted ps-0">Dimensions</th>
                <td>\${image.width} × \${image.height}</td>
              </tr>\` : ''}
              <tr>
                <th class="text-muted ps-0">Uploaded</th>
                <td>${image.createdAt ? new Date(image.createdAt).toLocaleDateString() : 'N/A'}</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- EXIF Data -->
      ${image.exifData ? `
      <div class="card shadow-sm mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h6 class="mb-0"><i class="bi bi-camera me-2"></i>EXIF Data</h6>
          <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="collapse" data-bs-target="#exifCollapse">
            Toggle
          </button>
        </div>
        <div class="collapse" id="exifCollapse">
          <div class="card-body p-0">
            <%- include('partials/exif-table', { exifData: image.exifData }) %>
          </div>
        </div>
      </div>` : ''}

      <!-- Map -->
      ${(image.latitude && image.longitude) ? `
      <div class="card shadow-sm mb-3">
        <div class="card-header">
          <h6 class="mb-0"><i class="bi bi-geo-alt me-2"></i>Location</h6>
        </div>
        <div class="card-body p-0">
          <%- include('partials/map', { lat: image.latitude, lng: image.longitude }) %>
        </div>
      </div>` : ''}

      <!-- Actions -->
      <div class="card shadow-sm">
        <div class="card-body d-flex gap-2 flex-wrap">
          <a href="/uploads/${image.storedName || image.filename}"
             download="${escapeHtml(image.originalName || 'image')}"
             class="btn btn-outline-primary btn-sm flex-fill">
            <i class="bi bi-download me-1"></i>Download
          </a>
          <a href="/gallery" class="btn btn-outline-secondary btn-sm flex-fill">
            <i class="bi bi-arrow-left me-1"></i>Back
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="/js/tagging.js"></script>
<script>
  function escapeHtml(str) {
    if (!str) return '';
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }
  function formatBytes(bytes) {
    if (!bytes || bytes === 0) return '0 B';
    const k = 1024;
    const sizes = ['B', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(1)) + ' ' + sizes[i];
  }
  document.addEventListener('DOMContentLoaded', function() {
    initImageTagging(${image.id});
  });
</script>
` }) %>