<%- include('layouts/base', { title: image.manualExif && image.manualExif.caption ? image.manualExif.caption : (image.originalName || image.filename), body: `

<div class="container image-detail-container" data-image-id="${image.id}">

  <!-- Breadcrumb -->
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span class="breadcrumb-sep" aria-hidden="true">›</span>
    <a href="/gallery">Gallery</a>
    <span class="breadcrumb-sep" aria-hidden="true">›</span>
    <span aria-current="page">${image.originalName || image.filename}</span>
  </nav>

  <!-- Header row -->
  <div class="image-detail-header">
    <div class="image-detail-header-left">
      <h1 class="image-detail-title">
        ${image.manualExif && image.manualExif.caption ? image.manualExif.caption : (image.originalName || image.filename)}
      </h1>
      ${image.description ? `<p class="image-detail-description">${image.description}</p>` : '<p class="image-detail-description"></p>'}
    </div>
    <div class="image-detail-header-actions">
      <button type="button" id="open-edit-panel-btn" class="btn btn-primary btn-sm">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
          <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
        </svg>
        Edit
      </button>
      <a href="/gallery" class="btn btn-outline btn-sm">← Back to Gallery</a>
    </div>
  </div>

  <!-- Main image -->
  <div class="image-detail-main">
    <img
      src="/uploads/${image.filename}"
      alt="${image.manualExif && image.manualExif.caption ? image.manualExif.caption : (image.originalName || image.filename)}"
      class="image-detail-img"
      style="transform: rotate(${image.rotation || 0}deg);"
      loading="lazy"
    >
  </div>

  <!-- Details grid -->
  <div class="image-detail-grid">

    <!-- Tags -->
    <section class="image-detail-section">
      <h2 class="section-title">Tags</h2>
      <div class="image-detail-tags">
        ${image.tags && image.tags.length > 0
          ? image.tags.map(tag => `<a href="/gallery?tag=${tag.id}" class="tag-badge">${tag.name}</a>`).join('')
          : '<span class="text-muted">No tags yet</span>'
        }
      </div>
    </section>

    <!-- EXIF / Metadata -->
    <section class="image-detail-section">
      <h2 class="section-title">Image Info</h2>
      <%- include('partials/exif-table', { image: image }) %>
    </section>

    <!-- Map (if GPS data) -->
    ${image.exifData && image.exifData.gps ? `
    <section class="image-detail-section image-detail-section--full">
      <h2 class="section-title">Location</h2>
      <%- include('partials/map', { image: image }) %>
    </section>
    ` : ''}

  </div>

  <!-- Navigation -->
  <div class="image-detail-nav">
    ${locals.prevImage ? `
    <a href="/gallery/${locals.prevImage.id}" class="btn btn-outline image-detail-nav-btn">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
      Previous
    </a>
    ` : '<span></span>'}
    ${locals.nextImage ? `
    <a href="/gallery/${locals.nextImage.id}" class="btn btn-outline image-detail-nav-btn">
      Next
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </a>
    ` : '<span></span>'}
  </div>

</div>

<!-- Edit panel -->
<%- include('partials/edit-panel', { image: image }) %>

` }) %>