<%- include('layouts/base', { title: 'Gallery', body: `
<div style="padding: 2rem 0 4rem;">
  <div class="container">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:2rem;">
      <h1 style="margin:0;font-size:1.75rem;font-weight:700;">Photo Gallery</h1>
      <a href="/api/upload" style="
        background: #6366f1;
        color: #fff;
        padding: 0.5rem 1.25rem;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
      ">+ Upload</a>
    </div>

    <div id="gallery-grid" style="
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 1rem;
    ">
      <div style="
        grid-column: 1 / -1;
        text-align: center;
        padding: 4rem 2rem;
        color: #94a3b8;
        border: 2px dashed #e2e8f0;
        border-radius: 12px;
      ">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="48" height="48" style="margin-bottom:1rem;opacity:0.4;">
          <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
        </svg>
        <p style="margin:0;font-size:1.1rem;font-weight:500;">No images yet</p>
        <p style="margin:0.25rem 0 1.5rem;font-size:0.9rem;">Upload your first image to get started.</p>
        <a href="/api/upload" style="
          background: #6366f1;
          color: #fff;
          padding: 0.5rem 1.25rem;
          border-radius: 8px;
          text-decoration: none;
          font-weight: 600;
          font-size: 0.9rem;
        ">Upload Image</a>
      </div>
    </div>
  </div>
</div>
` }) %>