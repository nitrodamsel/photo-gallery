<%- include('layouts/base', { title: title || 'Home', activePage: 'home', body: `
<div class="container py-5">
  <div class="row align-items-center mb-5">
    <div class="col-md-8">
      <h1 class="display-4 fw-bold mb-3">
        <i class="bi bi-images text-primary me-3"></i>Photo Gallery
      </h1>
      <p class="lead text-muted">
        Organize and browse your photos with tags, EXIF data, and more.
      </p>
      <div class="d-flex gap-3 mt-4">
        <a href="/gallery" class="btn btn-primary btn-lg">
          <i class="bi bi-grid me-2"></i>Browse Gallery
        </a>
        <a href="/upload" class="btn btn-outline-primary btn-lg">
          <i class="bi bi-cloud-upload me-2"></i>Upload
        </a>
      </div>
    </div>
  </div>

  <div class="row g-4">
    <!-- Stats Cards -->
    ${typeof stats !== 'undefined' && stats ? `
    <div class="col-md-4">
      <div class="card text-center shadow-sm h-100">
        <div class="card-body py-4">
          <div class="display-5 fw-bold text-primary">${stats.imageCount || 0}</div>
          <div class="text-muted mt-1">Photos</div>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card text-center shadow-sm h-100">
        <div class="card-body py-4">
          <div class="display-5 fw-bold text-success">${stats.tagCount || 0}</div>
          <div class="text-muted mt-1">Tags</div>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card text-center shadow-sm h-100">
        <div class="card-body py-4">
          <div class="display-5 fw-bold text-info">${stats.recentCount || 0}</div>
          <div class="text-muted mt-1">Uploaded This Week</div>
        </div>
      </div>
    </div>
    ` : ''}

    <!-- Tag Cloud -->
    ${typeof popularTags !== 'undefined' && popularTags && popularTags.length > 0 ? `
    <div class="col-12">
      <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h5 class="mb-0"><i class="bi bi-tags me-2"></i>Popular Tags</h5>
          <a href="/tags" class="btn btn-outline-secondary btn-sm">Manage Tags</a>
        </div>
        <div class="card-body">
          <%- include('partials/tag-cloud', { tags: popularTags }) %>
        </div>
      </div>
    </div>
    ` : ''}

    <!-- Recent Images -->
    ${typeof recentImages !== 'undefined' && recentImages && recentImages.length > 0 ? `
    <div class="col-12">
      <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Recent Uploads</h5>
          <a href="/gallery" class="btn btn-outline-primary btn-sm">View All</a>
        </div>
        <div class="card-body">
          <div class="row g-3">
            ${recentImages.slice(0, 8).map(image => `
            <div class="col-6 col-md-3">
              <%- include('partials/image-card', { image }) %>
            </div>
            `).join('')}
          </div>
        </div>
      </div>
    </div>
    ` : ''}
  </div>
</div>
` }) %>