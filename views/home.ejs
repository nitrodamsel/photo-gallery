<!-- Hero Section -->
<div class="hero-section text-center py-5 mb-5">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="hero-icon mb-4">
          <i class="bi bi-images display-1 text-primary"></i>
        </div>
        <h1 class="display-4 fw-bold mb-3">Welcome to Photo Gallery</h1>
        <p class="lead text-muted mb-4">
          <%= description %>
        </p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
          <a href="/upload" class="btn btn-primary btn-lg px-4">
            <i class="bi bi-cloud-upload me-2"></i>Upload Photos
          </a>
          <a href="/gallery" class="btn btn-outline-secondary btn-lg px-4">
            <i class="bi bi-grid-3x3-gap me-2"></i>Browse Gallery
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Features Section -->
<div class="container mb-5">
  <div class="row g-4 justify-content-center">
    <div class="col-12 text-center mb-2">
      <h2 class="fw-semibold">Everything You Need</h2>
      <p class="text-muted">Powerful features to manage your photo collection</p>
    </div>

    <% features.forEach(function(feature) { %>
    <div class="col-sm-6 col-lg-3">
      <div class="card feature-card h-100 border-0 shadow-sm text-center p-3">
        <div class="card-body">
          <div class="feature-icon mb-3">
            <span class="fs-1"><%= feature.icon %></span>
          </div>
          <h5 class="card-title fw-semibold"><%= feature.title %></h5>
          <p class="card-text text-muted small"><%= feature.description %></p>
        </div>
      </div>
    </div>
    <% }); %>
  </div>
</div>

<!-- Status / Health Badge -->
<div class="container mb-4">
  <div class="row justify-content-center">
    <div class="col-auto">
      <div class="d-flex align-items-center gap-2 bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-4 py-2">
        <span class="status-dot bg-success rounded-circle d-inline-block"></span>
        <span class="small fw-medium">Server is running &mdash; <a href="/health" class="text-success text-decoration-none fw-semibold">View Health Status</a></span>
      </div>
    </div>
  </div>
</div>