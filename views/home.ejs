<%
// Simple layout simulation — embed base.ejs structure inline
// (EJS does not have native layout support; we include directly)
%>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="A personal photo gallery with tagging and EXIF data support." />
  <meta name="theme-color" content="#6366f1" />

  <title><%= title %> | Photo Gallery</title>

  <!-- Bootstrap 5 CSS -->
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
    crossorigin="anonymous"
  />

  <!-- Bootstrap Icons -->
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
  />

  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/main.css" />
</head>
<body>

  <%- include('partials/navbar') %>

  <main class="main-content">

    <!-- ── Hero Section ───────────────────────────────────────────────── -->
    <section class="hero-section text-white text-center py-5">
      <div class="container py-4">
        <div class="row justify-content-center">
          <div class="col-lg-8">
            <div class="hero-icon mb-4">
              <i class="bi bi-images display-1"></i>
            </div>
            <h1 class="display-4 fw-bold mb-3"><%= heroTitle %></h1>
            <p class="lead mb-4 opacity-90"><%= heroSubtitle %></p>
            <div class="d-flex flex-wrap gap-3 justify-content-center">
              <a href="/upload" class="btn btn-light btn-lg px-4 fw-semibold">
                <i class="bi bi-cloud-upload me-2"></i>Upload Photos
              </a>
              <a href="/gallery" class="btn btn-outline-light btn-lg px-4">
                <i class="bi bi-grid-3x3-gap me-2"></i>Browse Gallery
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Stats Bar ──────────────────────────────────────────────────── -->
    <section class="stats-bar py-3 bg-white border-bottom shadow-sm">
      <div class="container">
        <div class="row text-center g-3">
          <div class="col-4">
            <div class="stat-item">
              <div class="stat-value fw-bold fs-3 text-primary"><%= stats.photos %></div>
              <div class="stat-label text-muted small text-uppercase fw-semibold">Photos</div>
            </div>
          </div>
          <div class="col-4">
            <div class="stat-item">
              <div class="stat-value fw-bold fs-3 text-primary"><%= stats.tags %></div>
              <div class="stat-label text-muted small text-uppercase fw-semibold">Tags</div>
            </div>
          </div>
          <div class="col-4">
            <div class="stat-item">
              <div class="stat-value fw-bold fs-3 text-primary"><%= stats.uploads %></div>
              <div class="stat-label text-muted small text-uppercase fw-semibold">Uploads</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Features Section ──────────────────────────────────────────── -->
    <section class="features-section py-5 bg-light">
      <div class="container">
        <div class="text-center mb-5">
          <h2 class="fw-bold h1">Everything You Need</h2>
          <p class="text-muted lead">A powerful yet simple photo management experience.</p>
        </div>

        <div class="row g-4">
          <% features.forEach(function(feature) { %>
          <div class="col-sm-6 col-lg-3">
            <div class="feature-card card h-100 border-0 shadow-sm text-center p-4">
              <div class="feature-icon mb-3">
                <span class="display-4"><%= feature.icon %></span>
              </div>
              <div class="card-body p-0">
                <h3 class="card-title h5 fw-bold mb-2"><%= feature.title %></h3>
                <p class="card-text text-muted small"><%= feature.description %></p>
              </div>
            </div>
          </div>
          <% }); %>
        </div>
      </div>
    </section>

    <!-- ── Getting Started Section ───────────────────────────────────── -->
    <section class="getting-started-section py-5">
      <div class="container">
        <div class="row align-items-center g-5">
          <div class="col-lg-6">
            <h2 class="fw-bold h1 mb-4">Get Started in Seconds</h2>
            <div class="steps">
              <div class="step d-flex gap-3 mb-4">
                <div class="step-number">
                  <span class="badge bg-primary rounded-circle fs-6 p-2" style="width:2.2rem;height:2.2rem;display:inline-flex;align-items:center;justify-content:center;">1</span>
                </div>
                <div>
                  <h4 class="fw-semibold mb-1">Upload Your Photos</h4>
                  <p class="text-muted mb-0">Drag and drop or click to select images from your device.</p>
                </div>
              </div>
              <div class="step d-flex gap-3 mb-4">
                <div class="step-number">
                  <span class="badge bg-primary rounded-circle fs-6 p-2" style="width:2.2rem;height:2.2rem;display:inline-flex;align-items:center;justify-content:center;">2</span>
                </div>
                <div>
                  <h4 class="fw-semibold mb-1">Add Tags</h4>
                  <p class="text-muted mb-0">Organise your photos with descriptive tags for easy filtering.</p>
                </div>
              </div>
              <div class="step d-flex gap-3">
                <div class="step-number">
                  <span class="badge bg-primary rounded-circle fs-6 p-2" style="width:2.2rem;height:2.2rem;display:inline-flex;align-items:center;justify-content:center;">3</span>
                </div>
                <div>
                  <h4 class="fw-semibold mb-1">Explore Your Gallery</h4>
                  <p class="text-muted mb-0">Browse, filter, and enjoy your photos in a beautiful grid layout.</p>
                </div>
              </div>
            </div>
            <a href="/upload" class="btn btn-primary btn-lg mt-4 px-4">
              <i class="bi bi-rocket-takeoff me-2"></i>Start Now
            </a>
          </div>
          <div class="col-lg-6">
            <div class="placeholder-gallery">
              <div class="row g-2">
                <div class="col-6">
                  <div class="placeholder-photo placeholder-photo--tall bg-primary bg-opacity-10 rounded-3 d-flex align-items-center justify-content-center">
                    <i class="bi bi-image text-primary fs-1 opacity-50"></i>
                  </div>
                </div>
                <div class="col-6">
                  <div class="row g-2">
                    <div class="col-12">
                      <div class="placeholder-photo placeholder-photo--short bg-success bg-opacity-10 rounded-3 d-flex align-items-center justify-content-center">
                        <i class="bi bi-image text-success fs-2 opacity-50"></i>
                      </div>
                    </div>
                    <div class="col-12">
                      <div class="placeholder-photo placeholder-photo--short bg-warning bg-opacity-10 rounded-3 d-flex align-items-center justify-content-center">
                        <i class="bi bi-image text-warning fs-2 opacity-50"></i>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <!-- Footer -->
  <footer class="footer py-4 bg-dark text-white">
    <div class="container text-center">
      <span class="opacity-75 small">
        &copy; <%= new Date().getFullYear() %> Photo Gallery &mdash; Built with Express &amp; EJS
      </span>
    </div>
  </footer>

  <!-- Bootstrap 5 JS -->
  <script
    src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
    integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmOFTRF7iNTWFTOZ5V+HLSEZ8kB"
    crossorigin="anonymous"
  ></script>

  <!-- Custom JS -->
  <script src="/js/main.js"></script>
</body>
</html>