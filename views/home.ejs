<%- include('layouts/base', { body: `

<!-- ── Hero Section ──────────────────────────────────────────────────────── -->
<section class="hero-section">
  <div class="container">
    <div class="row justify-content-center text-center">
      <div class="col-lg-8">
        <div class="hero-badge mb-4">
          <span class="badge-pill">✨ Phase 1 — Foundation</span>
        </div>
        <h1 class="hero-title">${heroTitle}</h1>
        <p class="hero-subtitle">${heroSubtitle}</p>
        <div class="hero-actions d-flex gap-3 justify-content-center flex-wrap">
          <a href="/gallery" class="btn btn-primary btn-lg px-5">
            <i class="bi bi-images me-2"></i>Browse Gallery
          </a>
          <a href="/upload" class="btn btn-outline-primary btn-lg px-5">
            <i class="bi bi-cloud-upload me-2"></i>Upload Photos
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── Stats Bar ──────────────────────────────────────────────────────────── -->
<section class="stats-bar">
  <div class="container">
    <div class="row g-0 text-center">
      <div class="col-4">
        <div class="stat-item">
          <span class="stat-number">${stats.photos}</span>
          <span class="stat-label">Photos</span>
        </div>
      </div>
      <div class="col-4">
        <div class="stat-item stat-divider">
          <span class="stat-number">${stats.tags}</span>
          <span class="stat-label">Tags</span>
        </div>
      </div>
      <div class="col-4">
        <div class="stat-item">
          <span class="stat-number">${stats.uploads}</span>
          <span class="stat-label">Uploads</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── Features Section ───────────────────────────────────────────────────── -->
<section class="features-section">
  <div class="container">
    <div class="section-header text-center mb-5">
      <h2 class="section-title">Everything You Need</h2>
      <p class="section-subtitle text-muted">A complete toolkit for managing your personal photo collection.</p>
    </div>
    <div class="row g-4">
      ${features.map(f => `
      <div class="col-sm-6 col-lg-3">
        <div class="feature-card h-100">
          <div class="feature-icon">${f.icon}</div>
          <h3 class="feature-title">${f.title}</h3>
          <p class="feature-desc text-muted">${f.description}</p>
        </div>
      </div>
      `).join('')}
    </div>
  </div>
</section>

<!-- ── CTA Section ────────────────────────────────────────────────────────── -->
<section class="cta-section">
  <div class="container">
    <div class="cta-card text-center">
      <h2 class="cta-title">Ready to Get Started?</h2>
      <p class="cta-subtitle">Upload your first photo and start building your gallery today.</p>
      <a href="/upload" class="btn btn-white btn-lg px-5">
        <i class="bi bi-rocket-takeoff me-2"></i>Get Started
      </a>
    </div>
  </div>
</section>

` }) %>