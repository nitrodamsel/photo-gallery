<div class="container mt-4">
  <div class="row">
    <!-- Main Content -->
    <div class="col-lg-8">
      <div class="jumbotron bg-light p-5 rounded mb-4">
        <h1 class="display-4"><i class="bi bi-camera2 me-2"></i>Photo Gallery</h1>
        <p class="lead">Welcome to your personal photo gallery. Upload, organize, and browse your images with ease.</p>
        <hr class="my-4">
        <div class="d-flex gap-2 flex-wrap">
          <a class="btn btn-primary btn-lg" href="/gallery" role="button">
            <i class="bi bi-images me-1"></i>Browse Gallery
          </a>
          <a class="btn btn-success btn-lg" href="/upload" role="button">
            <i class="bi bi-cloud-upload me-1"></i>Upload Images
          </a>
          <a class="btn btn-outline-secondary btn-lg" href="/tags" role="button">
            <i class="bi bi-tags me-1"></i>Manage Tags
          </a>
        </div>
      </div>
    </div>

    <!-- Sidebar -->
    <div class="col-lg-4">
      <div class="card mb-3">
        <div class="card-header">
          <h5 class="mb-0"><i class="bi bi-cloud-fill me-2"></i>Tag Cloud</h5>
        </div>
        <div class="card-body">
          <%- include('partials/tag-cloud', { tags: tags || [] }) %>
          <% if (tags && tags.length > 0) { %>
            <div class="mt-2">
              <a href="/tags" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-gear me-1"></i>Manage Tags
              </a>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>