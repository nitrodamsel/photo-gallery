<%- include('layouts/base', { body: `

<!-- ── Hero Section ─────────────────────────────────────────────────────── -->
<section class="hero-section text-white text-center py-5">
  <div class="container py-4">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="hero-emoji mb-3">📸</div>
        <h1 class="display-4 fw-bold mb-3">Your Photos, Beautifully Organized</h1>
        <p class="lead mb-4 opacity-90">
          Upload, tag, and explore your photo collection with automatic EXIF extraction,
          smart thumbnails, and powerful search — all in one place.
        </p>
        <div class="d-flex flex-wrap gap-3 justify-content-center">
          <a href="/upload" class="btn btn-light btn-lg px-4 fw-semibold">
            <i class="bi bi-cloud-upload me-2"></i>Upload Photos
          </a>
          <a href="/gallery" class="btn btn-outline-light btn-lg px-4">
            <i class="bi bi-images me-2"></i>Browse Gallery
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── Stats Bar ─────────────────────────────────────────────────────────── -->
<section class="stats-bar py-4 bg-dark text-white">
  <div class="container">
    <div class="row text-center g-3">
      <div class="col-4">
        <div class="fs-2 fw-bold text-primary"><%= stats.photos %></div>
        <div class="small text-muted text-uppercase tracking-wide">Photos</div>
      </div>
      <div class="col-4">
        <div class="fs-2 fw-bold text-primary"><%= stats.tags %></div>
        <div class="small text-muted text-uppercase tracking-wide">Tags</div>
      </div>
      <div class="col-4">
        <div class="fs-2 fw-bold text-primary"><%= stats.uploads %></div>
        <div class="small text-muted text-uppercase tracking-wide">Uploads</div>
      </div>
    </div>
  </div>
</section>

<!-- ── Features Grid ─────────────────────────────────────────────────────── -->
<section class="features-section py-5">
  <div class="container py-3">
    <div class="text-center mb-5">
      <h2 class="fw-bold">Everything You Need</h2>
      <p class="text-muted lead">
        A full-featured photo management experience, built for speed and simplicity.
      </p>
    </div>

    <div class="row g-4">
      <% features.forEach(function(feature) { %>
      <div class="col-md-6 col-lg-4">
        <div class="feature-card card h-100 border-0 shadow-sm p-4">
          <div class="feature-icon mb-3"><%= feature.icon %></div>
          <h5 class="fw-bold mb-2"><%= feature.heading %></h5>
          <p class="text-muted mb-0"><%= feature.body %></p>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
</section>

<!-- ── CTA Section ───────────────────────────────────────────────────────── -->
<section class="cta-section py-5 bg-primary text-white text-center">
  <div class="container py-3">
    <h2 class="fw-bold mb-3">Ready to Get Started?</h2>
    <p class="lead mb-4 opacity-90">
      Upload your first photo and experience the magic of organized memories.
    </p>
    <a href="/upload" class="btn btn-light btn-lg px-5 fw-semibold">
      <i class="bi bi-arrow-right-circle me-2"></i>Get Started — It&apos;s Free
    </a>
  </div>
</section>

` }) %>