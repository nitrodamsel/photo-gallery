<%
  layout = 'layouts/base';
%>
<%- include('layouts/base', { body: `
<!-- Hero Section -->
<section class="hero-section text-white text-center">
  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="hero-icon mb-4">
          <i class="bi bi-camera2" style="font-size: 4rem; color: var(--accent-color);"></i>
        </div>
        <h1 class="display-4 fw-bold mb-3">${heroHeadline}</h1>
        <p class="lead mb-4 text-light">${heroSubtitle}</p>
        <div class="d-flex flex-wrap justify-content-center gap-3">
          <a href="/upload" class="btn btn-primary btn-lg px-4">
            <i class="bi bi-cloud-upload me-2"></i>Upload Photos
          </a>
          <a href="/gallery" class="btn btn-outline-light btn-lg px-4">
            <i class="bi bi-images me-2"></i>Browse Gallery
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Features Section -->
<section class="features-section py-5">
  <div class="container">
    <h2 class="text-center fw-bold mb-2">Everything You Need</h2>
    <p class="text-center text-muted mb-5">A full-featured photo gallery right in your browser.</p>
    <div class="row g-4">
      ${features.map(f => `
      <div class="col-sm-6 col-lg-3">
        <div class="feature-card card h-100 border-0 shadow-sm text-center p-4">
          <div class="feature-icon mb-3">${f.icon}</div>
          <h5 class="fw-semibold mb-2">${f.title}</h5>
          <p class="text-muted small mb-0">${f.description}</p>
        </div>
      </div>
      `).join('')}
    </div>
  </div>
</section>

<!-- CTA Section -->
<section class="cta-section py-5 bg-light">
  <div class="container text-center">
    <h2 class="fw-bold mb-3">Ready to get started?</h2>
    <p class="text-muted mb-4">Upload your first photo and let PhotoGallery do the rest.</p>
    <a href="/upload" class="btn btn-primary btn-lg px-5">
      <i class="bi bi-plus-circle me-2"></i>Get Started
    </a>
  </div>
</section>
` }) %>