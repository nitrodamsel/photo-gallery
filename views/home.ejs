<%- include('layouts/base', { body: `
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="container">
      <div class="row justify-content-center text-center">
        <div class="col-lg-8">
          <div class="hero-icon mb-4">📷</div>
          <h1 class="hero-title display-4 fw-bold mb-3">${title}</h1>
          <p class="hero-tagline lead mb-5">${tagline}</p>
          <div class="d-flex flex-wrap justify-content-center gap-3">
            <a href="/upload" class="btn btn-primary btn-lg px-5">
              <i class="bi bi-cloud-upload-fill me-2"></i>Upload Photos
            </a>
            <a href="/gallery" class="btn btn-outline-secondary btn-lg px-5">
              <i class="bi bi-grid-3x3-gap-fill me-2"></i>View Gallery
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="stats-section py-4">
    <div class="container">
      <div class="row g-3 justify-content-center text-center">
        <div class="col-6 col-md-3">
          <div class="stat-card p-3">
            <div class="stat-number display-6 fw-bold text-primary">${stats.photos}</div>
            <div class="stat-label text-muted small text-uppercase fw-semibold">Photos</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="stat-card p-3">
            <div class="stat-number display-6 fw-bold text-primary">${stats.tags}</div>
            <div class="stat-label text-muted small text-uppercase fw-semibold">Tags</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="stat-card p-3">
            <div class="stat-number display-6 fw-bold text-primary">${stats.uploads}</div>
            <div class="stat-label text-muted small text-uppercase fw-semibold">Uploads</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="features-section py-5">
    <div class="container">
      <div class="text-center mb-5">
        <h2 class="fw-bold">Everything you need</h2>
        <p class="text-muted lead">A powerful yet simple photo management experience.</p>
      </div>
      <div class="row g-4">
        ${features.map(f => `
          <div class="col-sm-6 col-lg-3">
            <div class="feature-card card h-100 border-0 text-center p-4">
              <div class="feature-icon mb-3">${f.icon}</div>
              <h5 class="fw-bold mb-2">${f.title}</h5>
              <p class="text-muted small mb-0">${f.description}</p>
            </div>
          </div>
        `).join('')}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section py-5">
    <div class="container">
      <div class="cta-card text-center p-5 rounded-4">
        <h2 class="fw-bold mb-3">Ready to get started?</h2>
        <p class="text-muted lead mb-4">Upload your first photo and start building your gallery today.</p>
        <a href="/upload" class="btn btn-primary btn-lg px-5">
          <i class="bi bi-rocket-takeoff-fill me-2"></i>Get Started
        </a>
      </div>
    </div>
  </section>
`) %>