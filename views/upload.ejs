<div class="container mt-4" style="max-width: 800px;">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-upload me-2"></i>Upload Photos</h1>
    <a href="/gallery" class="btn btn-outline-secondary">
      <i class="bi bi-arrow-left me-1"></i>Back to Gallery
    </a>
  </div>

  <!-- Upload Form -->
  <form id="uploadForm" enctype="multipart/form-data" novalidate>

    <!-- Drop Zone -->
    <div id="dropZone" class="mb-4">
      <div id="dropZoneContent" class="text-center">
        <i class="bi bi-cloud-upload fs-1 text-muted d-block mb-3"></i>
        <h5 class="text-muted">Drag & Drop photos here</h5>
        <p class="text-muted small mb-3">or click to browse files</p>
        <button type="button" id="selectFilesBtn" class="btn btn-outline-primary">
          <i class="bi bi-folder2-open me-1"></i>Select Files
        </button>
        <p class="text-muted small mt-3 mb-0">
          Supported: JPEG, PNG, GIF, WebP, TIFF
        </p>
      </div>
    </div>

    <input type="file" id="fileInput" name="image" accept="image/*" multiple class="d-none">

    <!-- Preview Container -->
    <div id="previewContainer" class="d-flex flex-wrap mb-3 d-none"></div>

    <!-- Progress Bar -->
    <div id="progressContainer" class="mb-3 d-none">
      <div class="d-flex justify-content-between mb-1">
        <small class="text-muted" id="progressText">Uploading...</small>
      </div>
      <div class="progress" style="height: 20px;">
        <div id="uploadProgressBar" class="progress-bar progress-bar-striped progress-bar-animated" 
             role="progressbar" style="width: 0%;" 
             aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">0%</div>
      </div>
    </div>

    <!-- Upload Results -->
    <div id="uploadResults" class="mb-3"></div>

    <!-- Optional Metadata -->
    <div class="card shadow-sm mb-3">
      <div class="card-header" data-bs-toggle="collapse" data-bs-target="#metadataCollapse" style="cursor: pointer;">
        <h6 class="mb-0 d-flex justify-content-between align-items-center">
          <span><i class="bi bi-pencil me-1"></i>Optional Metadata</span>
          <i class="bi bi-chevron-down"></i>
        </h6>
      </div>
      <div class="collapse" id="metadataCollapse">
        <div class="card-body">
          <div class="mb-3">
            <label for="titleInput" class="form-label">Title</label>
            <input type="text" class="form-control" id="titleInput" name="title" 
                   placeholder="Photo title" maxlength="255">
          </div>
          <div class="mb-3">
            <label for="descriptionInput" class="form-label">Description</label>
            <textarea class="form-control" id="descriptionInput" name="description" 
                      rows="2" placeholder="Photo description" maxlength="1000"></textarea>
          </div>
          <div class="mb-3">
            <label for="tagsInput" class="form-label">Tags</label>
            <input type="text" class="form-control" id="tagsInput" name="tags" 
                   placeholder="e.g. nature, travel, 2024 (comma-separated)" list="tagSuggestions">
            <datalist id="tagSuggestions"></datalist>
            <div class="form-text">Separate multiple tags with commas</div>
          </div>
          <div class="form-check">
            <input class="form-check-input" type="checkbox" id="isPublicInput" name="isPublic" checked>
            <label class="form-check-label" for="isPublicInput">Make public</label>
          </div>
        </div>
      </div>
    </div>
  </form>
</div>

<script src="/js/upload.js"></script>
<script>
// Init tag autocomplete for upload page tags input
document.addEventListener('DOMContentLoaded', function() {
  const tagsInput = document.getElementById('tagsInput');
  const tagSuggestions = document.getElementById('tagSuggestions');
  if (tagsInput && tagSuggestions) {
    let debounce;
    tagsInput.addEventListener('input', function() {
      clearTimeout(debounce);
      const val = this.value;
      const lastComma = val.lastIndexOf(',');
      const query = (lastComma >= 0 ? val.slice(lastComma + 1) : val).trim();
      if (query.length < 1) { tagSuggestions.innerHTML = ''; return; }
      debounce = setTimeout(async () => {
        try {
          const res = await fetch(`/api/tags?q=${encodeURIComponent(query)}`);
          const tags = await res.json();
          tagSuggestions.innerHTML = '';
          tags.forEach(tag => {
            const opt = document.createElement('option');
            // Preserve everything before the last comma
            const prefix = lastComma >= 0 ? val.slice(0, lastComma + 1) + ' ' : '';
            opt.value = prefix + tag.name;
            tagSuggestions.appendChild(opt);
          });
        } catch(e) {}
      }, 250);
    });
  }
});
</script>