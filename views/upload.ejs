<%- include('layouts/base', { title: title, activePage: 'upload', body: `
<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-8">

      <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2 mb-0">
          <i class="bi bi-cloud-upload text-primary me-2"></i>Upload Images
        </h1>
        <a href="/gallery" class="btn btn-outline-secondary btn-sm">
          <i class="bi bi-arrow-left me-1"></i>Back to Gallery
        </a>
      </div>

      <!-- Upload Messages -->
      <div id="uploadMessages" class="mb-3"></div>

      <!-- Success Thumbnails -->
      <div id="successThumbs" class="mb-3 d-none"></div>

      <!-- Upload Form -->
      <div class="card shadow-sm">
        <div class="card-body">

          <!-- Drop Zone -->
          <div id="dropZone" class="mb-4" role="button" tabindex="0" aria-label="Drop files here or click to browse">
            <div class="drop-zone-icon">
              <i class="bi bi-cloud-upload-fill"></i>
            </div>
            <h5 class="text-muted mb-2">Drag &amp; drop images here</h5>
            <p class="text-muted small mb-3">or</p>
            <button type="button" class="btn btn-outline-primary" id="browseBtn">
              <i class="bi bi-folder2-open me-1"></i>Browse Files
            </button>
            <p class="text-muted small mt-3 mb-0">
              Supports: JPEG, PNG, GIF, WebP, TIFF &bull; Max 50MB per file
            </p>
            <input type="file" id="fileInput" accept="image/*" multiple class="d-none" />
          </div>

          <!-- Preview -->
          <div id="previewContainer" class="mb-3"></div>

          <!-- Progress Bar -->
          <div id="progressContainer" class="mb-3 d-none">
            <div id="progressText" class="small text-muted mb-1">Uploading...</div>
            <div class="progress" style="height: 20px;">
              <div
                id="uploadProgressBar"
                class="progress-bar progress-bar-striped progress-bar-animated"
                role="progressbar"
                style="width: 0%"
                aria-valuenow="0"
                aria-valuemin="0"
                aria-valuemax="100"
              >0%</div>
            </div>
          </div>

          <!-- Additional Metadata Form -->
          <form id="uploadForm" class="mt-4 pt-3 border-top">
            <h6 class="text-muted mb-3">
              <i class="bi bi-info-circle me-1"></i>Optional Metadata
              <span class="badge bg-light text-muted ms-1 fw-normal">Applied to next upload</span>
            </h6>
            <div class="row g-3">
              <div class="col-md-6">
                <label for="uploadTitle" class="form-label">Title</label>
                <input type="text" class="form-control" id="uploadTitle" name="title" placeholder="Image title..." maxlength="255" />
              </div>
              <div class="col-md-6">
                <label for="uploadTags" class="form-label">Tags</label>
                <input
                  type="text"
                  class="form-control"
                  id="uploadTags"
                  name="tags"
                  placeholder="nature, black-and-white, portrait..."
                  list="uploadTagSuggestions"
                  autocomplete="off"
                />
                <datalist id="uploadTagSuggestions"></datalist>
                <div class="form-text">Comma-separated tag names.</div>
              </div>
              <div class="col-12">
                <label for="uploadDescription" class="form-label">Description</label>
                <textarea class="form-control" id="uploadDescription" name="description" rows="2" placeholder="Describe this image..." maxlength="1000"></textarea>
              </div>
            </div>
          </form>

        </div>
      </div>

    </div>
  </div>
</div>

<script src="/js/upload.js"></script>
<script>
  // Autocomplete for upload tags field
  const uploadTagInput = document.getElementById('uploadTags');
  if (uploadTagInput) {
    let debounce;
    uploadTagInput.addEventListener('input', function() {
      clearTimeout(debounce);
      const parts = this.value.split(',');
      const last = parts[parts.length - 1].trim();
      if (last.length < 1) return;
      debounce = setTimeout(async () => {
        try {
          const res = await fetch('/api/tags?q=' + encodeURIComponent(last));
          if (!res.ok) return;
          const tags = await res.json();
          const dl = document.getElementById('uploadTagSuggestions');
          dl.innerHTML = '';
          tags.forEach(tag => {
            const opt = document.createElement('option');
            // Replace the last segment with the tag name
            const prefix = parts.slice(0, -1).join(', ');
            opt.value = (prefix ? prefix + ', ' : '') + tag.name;
            dl.appendChild(opt);
          });
        } catch {}
      }, 200);
    });
  }
</script>
`) %>