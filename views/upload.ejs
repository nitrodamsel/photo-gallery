<%- include('layouts/base', { title: title || 'Upload Image', body: `
<div class="upload-page">
  <div class="container">
    <div class="page-header">
      <h1>Upload Image</h1>
      <p class="subtitle">Supported formats: JPEG, PNG, WebP, TIFF, HEIC &bull; Max size: 20 MB</p>
    </div>

    <% if (locals.error) { %>
      <div class="alert alert-error">
        <span class="alert-icon">&#9888;</span>
        <%= error %>
      </div>
    <% } %>

    <% if (locals.success) { %>
      <div class="alert alert-success">
        <span class="alert-icon">&#10003;</span>
        <%= success %>
      </div>
    <% } %>

    <div class="upload-card">
      <!-- Drag & Drop Zone -->
      <div class="drop-zone" id="dropZone" role="button" tabindex="0"
           aria-label="Drop image here or click to browse">
        <div class="drop-zone__content" id="dropZoneContent">
          <div class="drop-zone__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
                 stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
              <circle cx="8.5" cy="8.5" r="1.5"/>
              <polyline points="21 15 16 10 5 21"/>
            </svg>
          </div>
          <p class="drop-zone__text">
            <strong>Drag &amp; drop your image here</strong><br>
            or <span class="drop-zone__browse">browse to upload</span>
          </p>
          <p class="drop-zone__hint">JPEG &bull; PNG &bull; WebP &bull; TIFF &bull; HEIC</p>
        </div>

        <!-- Image Preview -->
        <div class="preview-container" id="previewContainer" style="display:none;">
          <img id="imagePreview" src="" alt="Preview" class="image-preview" />
          <button type="button" class="preview-remove" id="removePreview"
                  aria-label="Remove selected image">
            &times;
          </button>
          <div class="preview-info" id="previewInfo"></div>
        </div>
      </div>

      <!-- Actual form -->
      <form id="uploadForm" method="POST" action="/api/upload"
            enctype="multipart/form-data" novalidate>

        <input type="file" id="fileInput" name="image" accept="image/*"
               style="display:none;" aria-hidden="true" />

        <div class="form-fields">
          <div class="form-group">
            <label for="imageTitle" class="form-label">Title <span class="optional">(optional)</span></label>
            <input type="text" id="imageTitle" name="title" class="form-control"
                   placeholder="Enter a title for this image" maxlength="255" />
          </div>

          <div class="form-group">
            <label for="imageDescription" class="form-label">Description <span class="optional">(optional)</span></label>
            <textarea id="imageDescription" name="description" class="form-control"
                      rows="3" placeholder="Describe this image..." maxlength="2000"></textarea>
          </div>

          <div class="form-group">
            <label for="imageTags" class="form-label">Tags <span class="optional">(optional, comma-separated)</span></label>
            <input type="text" id="imageTags" name="tags" class="form-control"
                   placeholder="e.g. nature, landscape, travel" />
          </div>
        </div>

        <!-- Progress Bar (wired up in Phase 5) -->
        <div class="progress-container" id="progressContainer" style="display:none;">
          <div class="progress-bar" id="progressBar" role="progressbar"
               aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"
               style="width: 0%;">
          </div>
          <span class="progress-label" id="progressLabel">Uploading... 0%</span>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary" id="submitBtn" disabled>
            <span class="btn-icon">&#8679;</span>
            Upload Image
          </button>
          <a href="/" class="btn btn-secondary">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>

<style>
  .upload-page {
    padding: 2rem 0;
  }

  .page-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .page-header h1 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-text, #1a1a2e);
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: var(--color-text-muted, #6b7280);
    font-size: 0.95rem;
  }

  .alert {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border-radius: 8px;
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }

  .alert-error {
    background: #fef2f2;
    border: 1px solid #fecaca;
    color: #dc2626;
  }

  .alert-success {
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    color: #16a34a;
  }

  .alert-icon {
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  .upload-card {
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    padding: 2rem;
    max-width: 680px;
    margin: 0 auto;
  }

  .drop-zone {
    border: 2px dashed #d1d5db;
    border-radius: 12px;
    padding: 2.5rem 1.5rem;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
    background: #fafafa;
    margin-bottom: 1.5rem;
    position: relative;
    outline: none;
  }

  .drop-zone:focus,
  .drop-zone.drag-over {
    border-color: #6366f1;
    background: #f5f3ff;
  }

  .drop-zone__icon {
    color: #9ca3af;
    margin-bottom: 1rem;
  }

  .drop-zone.drag-over .drop-zone__icon {
    color: #6366f1;
  }

  .drop-zone__text {
    color: #374151;
    margin-bottom: 0.5rem;
    line-height: 1.6;
  }

  .drop-zone__browse {
    color: #6366f1;
    font-weight: 600;
    text-decoration: underline;
    cursor: pointer;
  }

  .drop-zone__hint {
    color: #9ca3af;
    font-size: 0.85rem;
    letter-spacing: 0.03em;
  }

  .preview-container {
    position: relative;
  }

  .image-preview {
    max-width: 100%;
    max-height: 320px;
    border-radius: 8px;
    object-fit: contain;
    display: block;
    margin: 0 auto;
  }

  .preview-remove {
    position: absolute;
    top: -0.5rem;
    right: -0.5rem;
    background: #ef4444;
    color: #fff;
    border: none;
    border-radius: 50%;
    width: 28px;
    height: 28px;
    font-size: 1.1rem;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }

  .preview-remove:hover {
    background: #dc2626;
  }

  .preview-info {
    margin-top: 0.75rem;
    font-size: 0.85rem;
    color: #6b7280;
    text-align: center;
  }

  .form-fields {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-label {
    font-weight: 500;
    font-size: 0.9rem;
    color: #374151;
  }

  .optional {
    font-weight: 400;
    color: #9ca3af;
    font-size: 0.82rem;
  }

  .form-control {
    padding: 0.6rem 0.85rem;
    border: 1.5px solid #e5e7eb;
    border-radius: 8px;
    font-size: 0.95rem;
    color: #1f2937;
    transition: border-color 0.2s;
    background: #fff;
    font-family: inherit;
    width: 100%;
    box-sizing: border-box;
  }

  .form-control:focus {
    outline: none;
    border-color: #6366f1;
    box-shadow: 0 0 0 3px rgba(99,102,241,0.12);
  }

  textarea.form-control {
    resize: vertical;
    min-height: 80px;
  }

  .progress-container {
    margin-bottom: 1.25rem;
    background: #f3f4f6;
    border-radius: 99px;
    height: 10px;
    overflow: hidden;
    position: relative;
  }

  .progress-bar {
    height: 100%;
    background: linear-gradient(90deg, #6366f1, #8b5cf6);
    border-radius: 99px;
    transition: width 0.3s ease;
  }

  .progress-label {
    display: block;
    text-align: center;
    font-size: 0.82rem;
    color: #6b7280;
    margin-top: 0.4rem;
  }

  .form-actions {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.4rem;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 600;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.2s, opacity 0.2s, box-shadow 0.2s;
  }

  .btn-primary {
    background: #6366f1;
    color: #fff;
  }

  .btn-primary:hover:not(:disabled) {
    background: #4f46e5;
    box-shadow: 0 4px 12px rgba(99,102,241,0.3);
  }

  .btn-primary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .btn-secondary {
    background: #f3f4f6;
    color: #374151;
  }

  .btn-secondary:hover {
    background: #e5e7eb;
  }

  .btn-icon {
    font-size: 1.1rem;
  }
</style>

<script>
(function () {
  const dropZone = document.getElementById('dropZone');
  const fileInput = document.getElementById('fileInput');
  const uploadForm = document.getElementById('uploadForm');
  const submitBtn = document.getElementById('submitBtn');
  const previewContainer = document.getElementById('previewContainer');
  const dropZoneContent = document.getElementById('dropZoneContent');
  const imagePreview = document.getElementById('imagePreview');
  const previewInfo = document.getElementById('previewInfo');
  const removePreview = document.getElementById('removePreview');
  const progressContainer = document.getElementById('progressContainer');
  const progressBar = document.getElementById('progressBar');
  const progressLabel = document.getElementById('progressLabel');

  const ALLOWED_TYPES = ['image/jpeg', 'image/png', 'image/webp', 'image/tiff', 'image/heic', 'image/heif'];
  const MAX_SIZE_MB = 20;

  // ── Open file picker when drop zone is clicked ──
  dropZone.addEventListener('click', (e) => {
    if (e.target !== removePreview) {
      fileInput.click();
    }
  });

  dropZone.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      fileInput.click();
    }
  });

  // ── Drag & Drop events ──
  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('drag-over');
  });

  dropZone.addEventListener('dragleave', (e) => {
    if (!dropZone.contains(e.relatedTarget)) {
      dropZone.classList.remove('drag-over');
    }
  });

  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('drag-over');
    const files = e.dataTransfer.files;
    if (files.length > 0) {
      handleFile(files[0]);
    }
  });

  // ── File input change ──
  fileInput.addEventListener('change', () => {
    if (fileInput.files.length > 0) {
      handleFile(fileInput.files[0]);
    }
  });

  // ── Remove preview / reset ──
  removePreview.addEventListener('click', (e) => {
    e.stopPropagation();
    resetUpload();
  });

  // ── Handle the selected file ──
  function handleFile(file) {
    // Client-side validation
    if (!ALLOWED_TYPES.includes(file.type)) {
      showError('Invalid file type. Please upload a JPEG, PNG, WebP, TIFF, or HEIC image.');
      return;
    }

    if (file.size > MAX_SIZE_MB * 1024 * 1024) {
      showError('File is too large. Maximum size is ' + MAX_SIZE_MB + ' MB.');
      return;
    }

    // Transfer file to the real input (for form fallback)
    const dataTransfer = new DataTransfer();
    dataTransfer.items.add(file);
    fileInput.files = dataTransfer.files;

    // Show preview
    const reader = new FileReader();
    reader.onload = (e) => {
      imagePreview.src = e.target.result;
      const sizeMB = (file.size / 1024 / 1024).toFixed(2);
      previewInfo.textContent = file.name + ' · ' + sizeMB + ' MB · ' + file.type;
      dropZoneContent.style.display = 'none';
      previewContainer.style.display = 'block';
      submitBtn.disabled = false;
    };
    reader.readAsDataURL(file);
  }

  function resetUpload() {
    fileInput.value = '';
    imagePreview.src = '';
    previewInfo.textContent = '';
    previewContainer.style.display = 'none';
    dropZoneContent.style.display = 'block';
    submitBtn.disabled = true;
    progressContainer.style.display = 'none';
    progressBar.style.width = '0%';
    progressLabel.textContent = 'Uploading... 0%';
  }

  function showError(msg) {
    // Remove any existing error
    const existing = document.querySelector('.client-error');
    if (existing) existing.remove();

    const alert = document.createElement('div');
    alert.className = 'alert alert-error client-error';
    alert.innerHTML = '<span class="alert-icon">&#9888;</span>' + msg;
    document.querySelector('.upload-card').insertAdjacentElement('beforebegin', alert);

    setTimeout(() => alert.remove(), 5000);
  }

  // ── Form submit (standard multipart POST fallback) ──
  // Progress bar wiring will be added in Phase 5 via XHR/fetch
  uploadForm.addEventListener('submit', (e) => {
    if (!fileInput.files.length) {
      e.preventDefault();
      showError('Please select an image to upload.');
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Uploading...';

    // Show progress bar placeholder (Phase 5 will wire actual progress)
    progressContainer.style.display = 'block';
    progressBar.style.width = '30%';
    progressLabel.textContent = 'Uploading...';
  });
})();
</script>
` }) %>