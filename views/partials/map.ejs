<%
const mapLat = parseFloat(lat);
const mapLng = parseFloat(lng);
const isValid = !isNaN(mapLat) && !isNaN(mapLng);
const mapId = 'leaflet-map-' + Math.random().toString(36).substr(2, 9);
%>
<% if (isValid) { %>
<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
  crossorigin=""
/>
<script
  src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
  integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV/XN/WPeE="
  crossorigin=""
></script>

<div
  id="<%= mapId %>"
  class="leaflet-map"
  data-lat="<%= mapLat %>"
  data-lng="<%= mapLng %>"
  role="region"
  aria-label="Map showing photo location"
  style="height: 300px; width: 100%; border-radius: 8px; overflow: hidden;"
></div>

<p class="map-coords">
  <strong>GPS:</strong>
  <%= Math.abs(mapLat).toFixed(6) %>&deg;<%= mapLat >= 0 ? 'N' : 'S' %>,
  <%= Math.abs(mapLng).toFixed(6) %>&deg;<%= mapLng >= 0 ? 'E' : 'W' %>
  &mdash;
  <a
    href="https://www.openstreetmap.org/?mlat=<%= mapLat %>&mlon=<%= mapLng %>&zoom=15"
    target="_blank"
    rel="noopener noreferrer"
    class="map-osm-link"
  >View on OpenStreetMap &nearr;</a>
</p>

<script>
(function() {
  var mapEl = document.getElementById('<%= mapId %>');
  if (!mapEl || typeof L === 'undefined') return;

  var lat = parseFloat(mapEl.getAttribute('data-lat'));
  var lng = parseFloat(mapEl.getAttribute('data-lng'));

  if (isNaN(lat) || isNaN(lng)) return;

  var map = L.map('<%= mapId %>', {
    center: [lat, lng],
    zoom: 13,
    scrollWheelZoom: false,
  });

  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
    maxZoom: 19,
  }).addTo(map);

  var formattedLat = Math.abs(lat).toFixed(6) + '\u00b0' + (lat >= 0 ? 'N' : 'S');
  var formattedLng = Math.abs(lng).toFixed(6) + '\u00b0' + (lng >= 0 ? 'E' : 'W');

  L.marker([lat, lng])
    .addTo(map)
    .bindPopup('<strong>Photo taken here</strong><br>' + formattedLat + ', ' + formattedLng)
    .openPopup();
})();
</script>
<% } %>