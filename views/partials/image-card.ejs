<div class="image-card" data-image-id="<%= image.id %>">
  <a href="/image/<%= image.id %>" class="image-card__link">
    <div class="image-card__thumb-wrapper">
      <img
        src="/uploads/thumbnails/<%= image.filename.replace(/\.[^.]+$/, '') %>_small.jpg"
        alt="<%= image.description || image.originalName || 'Image' %>"
        class="image-card__thumb"
        loading="lazy"
        onerror="this.src='/uploads/<%= image.filename %>'"
        style="<%= image.rotation ? `transform: rotate(${image.rotation}deg);` : '' %>"
      >
    </div>
    <div class="image-card__info">
      <span class="image-card__name"><%= image.originalName || image.filename %></span>
      <% if (image.Tags && image.Tags.length > 0) { %>
        <div class="image-card__tags">
          <% image.Tags.slice(0, 3).forEach(tag => { %>
            <span class="tag-badge tag-badge--sm"><%= tag.name %></span>
          <% }); %>
          <% if (image.Tags.length > 3) { %>
            <span class="tag-badge tag-badge--sm tag-badge--more">+<%= image.Tags.length - 3 %></span>
          <% } %>
        </div>
      <% } %>
    </div>
  </a>
</div>