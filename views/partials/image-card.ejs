<div class="image-card" data-image-id="<%= image.id %>">
  <a href="/images/<%= image.id %>" class="image-card-link">
    <div class="image-card-thumb-wrap">
      <img
        src="/uploads/thumbnails/<%= image.thumbnailFilename || image.filename %>"
        alt="<%= image.description || image.originalName || 'Image' %>"
        class="image-card-thumb"
        loading="lazy"
        style="transform: rotate(<%= image.rotation || 0 %>deg)<%= image.flipH ? ' scaleX(-1)' : '' %>;"
      />
    </div>
  </a>
  <div class="image-card-body">
    <% if (image.description) { %>
      <p class="image-card-desc"><%= image.description.length > 80 ? image.description.slice(0, 80) + '…' : image.description %></p>
    <% } %>
    <div class="card-tags">
      <% if (image.Tags && image.Tags.length > 0) { %>
        <% image.Tags.slice(0, 4).forEach(tag => { %>
          <a href="/gallery?tag=<%= encodeURIComponent(tag.name) %>" class="card-tag" data-tag-name="<%= tag.name %>"><%= tag.name %></a>
        <% }); %>
        <% if (image.Tags.length > 4) { %>
          <span class="card-tag card-tag--more">+<%= image.Tags.length - 4 %></span>
        <% } %>
      <% } %>
    </div>
  </div>
</div>