<div class="image-card card" data-image-id="<%= image.id %>">
  <div class="card-image">
    <a href="/gallery/<%= image.id %>" class="image-card-link">
      <figure class="image is-square">
        <img
          src="/uploads/<%= image.filename %>"
          alt="<%= image.originalName || 'Image' %>"
          loading="lazy"
          style="object-fit: cover; width: 100%; height: 100%;<%= (image.rotation && image.rotation !== 0) ? ` transform: rotate(${image.rotation}deg);` : '' %>"
        />
      </figure>
    </a>
  </div>
  <div class="card-content p-2">
    <% if (image.description) { %>
      <p class="is-size-7 has-text-grey-dark" style="overflow:hidden;white-space:nowrap;text-overflow:ellipsis;">
        <%= image.description %>
      </p>
    <% } %>
    <% if (image.Tags && image.Tags.length > 0) { %>
      <div class="tags mt-1">
        <% image.Tags.slice(0, 3).forEach(tag => { %>
          <a href="/gallery?tag=<%= tag.name %>" class="tag is-info is-small"><%= tag.name %></a>
        <% }) %>
        <% if (image.Tags.length > 3) { %>
          <span class="tag is-light is-small">+<%= image.Tags.length - 3 %></span>
        <% } %>
      </div>
    <% } %>
  </div>
</div>