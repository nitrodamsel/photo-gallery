<div class="image-card" data-image-id="<%= image.id %>">
  <a href="/gallery/<%= image.id %>" class="image-card-link">
    <div class="image-card-thumb">
      <img
        src="/uploads/thumb_medium_<%= image.filename %>"
        alt="<%= image.originalName || image.filename %>"
        loading="lazy"
        onerror="this.src='/uploads/<%= image.filename %>'"
        style="transform: rotate(<%= image.rotation || 0 %>deg);"
      >
    </div>
    <div class="image-card-info">
      <p class="image-card-name"><%= image.originalName || image.filename %></p>
      <% if (image.Tags && image.Tags.length > 0) { %>
      <div class="image-card-tags">
        <% image.Tags.slice(0, 3).forEach(tag => { %>
        <span class="tag-pill tag-pill--small"><%= tag.name %></span>
        <% }) %>
        <% if (image.Tags.length > 3) { %>
        <span class="tag-pill tag-pill--small tag-pill--more">+<%= image.Tags.length - 3 %></span>
        <% } %>
      </div>
      <% } %>
    </div>
  </a>
</div>