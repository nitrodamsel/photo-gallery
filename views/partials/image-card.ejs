<%
const storedFilename = image.stored_filename || '';
const ext = storedFilename.includes('.') ? storedFilename.substring(storedFilename.lastIndexOf('.')) : '.jpg';
const base = storedFilename.replace(ext, '');
const thumbUrl = `/thumbnails/${base}_400${ext}`;

const cameraInfo = [image.camera_make, image.camera_model].filter(Boolean).join(' ');
const altText = [image.original_filename, cameraInfo].filter(Boolean).join(' — ');

const tags = image.tags || [];
const maxVisibleTags = 3;
const visibleTags = tags.slice(0, maxVisibleTags);
const overflowCount = tags.length - maxVisibleTags;

let dateTaken = '';
if (image.date_taken) {
  try {
    dateTaken = new Date(image.date_taken).toLocaleDateString('en-US', {
      year: 'numeric', month: 'short', day: 'numeric'
    });
  } catch(e) { dateTaken = ''; }
} else if (image.created_at) {
  try {
    dateTaken = new Date(image.created_at).toLocaleDateString('en-US', {
      year: 'numeric', month: 'short', day: 'numeric'
    });
  } catch(e) { dateTaken = ''; }
}
%>
<article class="image-card" aria-label="<%= image.original_filename || 'Photo' %>">
  <a href="/gallery/<%= image.id %>" class="card-link" tabindex="0">
    <div class="card-image-wrap">
      <img
        src="<%= thumbUrl %>"
        alt="<%= altText %>"
        class="card-thumbnail"
        loading="lazy"
        onerror="this.onerror=null;this.src='/images/placeholder.jpg'"
      />
      <div class="card-overlay">
        <span class="card-filename"><%= image.original_filename || 'Untitled' %></span>
      </div>
    </div>
  </a>

  <div class="card-body">
    <% if (dateTaken) { %>
    <time class="card-date" datetime="<%= image.date_taken || image.created_at %>">
      <%= dateTaken %>
    </time>
    <% } %>

    <% if (tags.length > 0) { %>
    <div class="card-tags" aria-label="Tags">
      <% visibleTags.forEach(function(tag) { %>
        <a href="/gallery?tag=<%= tag.slug %>" class="tag-badge tag-sm" title="Filter by <%= tag.name %>">
          <%= tag.name %>
        </a>
      <% }); %>
      <% if (overflowCount > 0) { %>
        <span class="tag-badge tag-overflow" title="<%= tags.slice(maxVisibleTags).map(t => t.name).join(', ') %>">
          +<%= overflowCount %> more
        </span>
      <% } %>
    </div>
    <% } %>
  </div>
</article>