<%
  // Determine thumbnail URL — prefer the dedicated thumbnails route for caching
  const thumbUrl = `/thumbnails/medium/${image.id}`;
  const detailUrl = `/gallery/${image.id}`;
  const imageTitle = image.title || image.original_filename || 'Untitled';
  const imageTags = image.tags || [];
%>
<article class="image-card" data-image-id="<%= image.id %>">
  <% if (typeof showCheckbox !== 'undefined' && showCheckbox) { %>
    <input
      type="checkbox"
      class="image-card-checkbox"
      data-image-id="<%= image.id %>"
      aria-label="Select <%= imageTitle %>"
    />
  <% } %>

  <a href="<%= detailUrl %>" class="image-card-link">
    <img
      class="image-card-thumbnail lazy"
      data-src="<%= thumbUrl %>"
      alt="<%= imageTitle %>"
      width="400"
      height="300"
      loading="lazy"
    />
  </a>

  <div class="image-card-body">
    <h3 class="image-card-title">
      <a href="<%= detailUrl %>"><%= imageTitle %></a>
    </h3>

    <% if (image.created_at) { %>
      <p class="image-card-meta">
        <%= new Date(image.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>
        <% if (image.file_size) { %>
          &middot; <%= (image.file_size / 1024 / 1024).toFixed(1) %>MB
        <% } %>
      </p>
    <% } %>

    <% if (imageTags.length > 0) { %>
      <div class="image-card-tags">
        <% imageTags.slice(0, 4).forEach(tag => { %>
          <a href="/gallery?tag=<%= encodeURIComponent(tag.name) %>" class="tag">
            <%= tag.name %>
          </a>
        <% }) %>
        <% if (imageTags.length > 4) { %>
          <span class="tag text-muted">+<%= imageTags.length - 4 %> more</span>
        <% } %>
      </div>
    <% } %>
  </div>
</article>