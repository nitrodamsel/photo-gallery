<%# Image Card Partial %>
<%# Expects: image object %>

<div
  class="image-card"
  data-image-id="<%= image.id %>"
>
  <a href="/images/<%= image.id %>" class="image-card__link">
    <div class="image-card__img-wrapper">
      <img
        src="/uploads/thumbnails/medium/<%= image.filename %>"
        alt="<%= image.originalName || image.filename %>"
        class="image-card__img"
        loading="lazy"
        onerror="this.src='/uploads/<%= image.filename %>'"
      />
    </div>
  </a>

  <div class="image-card__body">
    <% if (image.description) { %>
      <p class="image-card__desc"><%= image.description.length > 80 ? image.description.substring(0, 80) + '...' : image.description %></p>
    <% } %>

    <% if (image.tags && image.tags.length > 0) { %>
      <div class="image-card__tags">
        <% image.tags.slice(0, 3).forEach(tag => { %>
          <a href="/gallery?tag=<%= tag.id %>" class="tag-badge tag-badge--sm"><%= tag.name %></a>
        <% }) %>
        <% if (image.tags.length > 3) { %>
          <span class="tag-badge tag-badge--sm tag-badge--more">+<%= image.tags.length - 3 %></span>
        <% } %>
      </div>
    <% } %>

    <div class="image-card__meta">
      <time datetime="<%= image.createdAt %>">
        <%= new Date(image.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
      </time>
    </div>
  </div>
</div>