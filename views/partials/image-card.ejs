<%
  var ext = image.original_filename ? image.original_filename.split('.').pop() : 'jpg';
  var base = image.stored_filename ? image.stored_filename.replace(/\.[^.]+$/, '') : (image.original_filename ? image.original_filename.replace(/\.[^.]+$/, '') : ('image_' + image.id));
  var thumb400 = '/uploads/thumbnails/' + base + '_400.' + ext;
  var altText = (image.original_filename || 'Image') + (image.camera_make ? ' shot with ' + image.camera_make + (image.camera_model ? ' ' + image.camera_model : '') : '');
  var displayDate = '';
  if (image.date_taken) {
    displayDate = new Date(image.date_taken).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
  } else if (image.created_at) {
    displayDate = new Date(image.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
  }
  var tags = image.tags || [];
  var maxTagsShown = 3;
  var visibleTags = tags.slice(0, maxTagsShown);
  var overflowCount = tags.length - maxTagsShown;
%>
<article class="image-card">
  <a href="/gallery/<%= image.id %>" class="card-link" aria-label="View details for <%= image.original_filename || ('Image #' + image.id) %>">
    <div class="card-image-wrapper">
      <img 
        src="<%= thumb400 %>" 
        alt="<%= altText %>"
        class="card-image"
        loading="lazy"
        onerror="this.src='/uploads/<%= image.stored_filename || image.original_filename %>'"
      />
      <div class="card-overlay" aria-hidden="true">
        <span class="card-filename"><%= image.original_filename || ('Image #' + image.id) %></span>
      </div>
    </div>
  </a>

  <div class="card-body">
    <% if (displayDate) { %>
      <time class="card-date" datetime="<%= image.date_taken || image.created_at %>"><%= displayDate %></time>
    <% } %>

    <% if (tags.length > 0) { %>
      <div class="card-tags" aria-label="Tags">
        <% visibleTags.forEach(function(tag) { %>
          <a 
            href="/gallery?tag=<%= tag.slug %>" 
            class="tag-badge<%= (typeof activeTag !== 'undefined' && activeTag === tag.slug) ? ' tag-active' : '' %>"
            aria-label="Filter by tag <%= tag.name %>"
          ><%= tag.name %></a>
        <% }) %>
        <% if (overflowCount > 0) { %>
          <span class="tag-overflow" aria-label="<%= overflowCount %> more tags">+<%= overflowCount %></span>
        <% } %>
      </div>
    <% } %>
  </div>
</article>