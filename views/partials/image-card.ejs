<article class="image-card">
  <a href="/gallery/<%= image.id %>" class="image-card-link" aria-label="View details for <%= image.original_filename || ('Image #' + image.id) %>">
    <div class="image-card-thumb">
      <img
        src="<%= image.thumbnailUrl || ('/uploads/' + image.filename) %>"
        alt="<%= (image.original_filename || 'Photo') + (image.exif_data && image.exif_data.camera ? ' — taken with ' + image.exif_data.camera : '') %>"
        class="card-img"
        loading="lazy"
        width="400"
      />
      <div class="image-card-overlay">
        <span class="overlay-text"><%= image.original_filename || ('Image #' + image.id) %></span>
      </div>
    </div>
  </a>

  <div class="image-card-body">
    <p class="card-filename" title="<%= image.original_filename %>">
      <%= image.original_filename ? (image.original_filename.length > 30 ? image.original_filename.substring(0, 28) + '…' : image.original_filename) : ('Image #' + image.id) %>
    </p>

    <% 
      var dateTaken = null;
      if (image.exif_data && image.exif_data.dateTaken) {
        dateTaken = new Date(image.exif_data.dateTaken);
      } else if (image.created_at) {
        dateTaken = new Date(image.created_at);
      }
    %>
    <% if (dateTaken && !isNaN(dateTaken)) { %>
      <p class="card-date"><%= dateTaken.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %></p>
    <% } %>

    <% if (image.tags && image.tags.length > 0) { %>
      <div class="card-tags">
        <% var maxTags = 3; %>
        <% image.tags.slice(0, maxTags).forEach(function(tag) { %>
          <a href="/gallery?tag=<%= tag.slug %>" class="tag-badge tag-small" onclick="event.stopPropagation()">
            <%= tag.name %>
          </a>
        <% }); %>
        <% if (image.tags.length > maxTags) { %>
          <span class="tag-overflow">+<%= image.tags.length - maxTags %></span>
        <% } %>
      </div>
    <% } %>
  </div>
</article>