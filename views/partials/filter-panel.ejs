<div class="filter-panel card shadow-sm">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h6 class="mb-0 fw-semibold">
      <i class="bi bi-funnel me-1"></i>Filters
      <% 
        let filterCount = 0;
        if (searchOptions.dateFrom || searchOptions.dateTo) filterCount++;
        if (searchOptions.cameraMake) filterCount++;
        if (searchOptions.hasGps) filterCount++;
        if (searchOptions.tags && searchOptions.tags.length > 0) filterCount++;
      %>
      <% if (filterCount > 0) { %>
        <span class="badge bg-primary rounded-pill ms-1"><%= filterCount %></span>
      <% } %>
    </h6>
    <button
      class="btn btn-sm btn-link text-muted p-0 toggle-filters"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#filterPanelBody"
      aria-expanded="true"
      aria-controls="filterPanelBody"
    >
      <i class="bi bi-chevron-up" id="filterToggleIcon"></i>
    </button>
  </div>

  <div class="collapse show" id="filterPanelBody">
    <div class="card-body p-3">
      <form id="filterForm" action="/search" method="GET">
        <!-- Preserve search query -->
        <% if (searchOptions.q) { %>
          <input type="hidden" name="q" value="<%= searchOptions.q %>">
        <% } %>

        <!-- Date Range -->
        <div class="filter-section mb-4">
          <h6 class="filter-section-title text-muted small text-uppercase fw-semibold mb-2">
            <i class="bi bi-calendar3 me-1"></i>Date Range
          </h6>
          <div class="mb-2">
            <label for="dateFrom" class="form-label form-label-sm text-muted mb-1">From</label>
            <input
              type="date"
              class="form-control form-control-sm"
              id="dateFrom"
              name="dateFrom"
              value="<%= searchOptions.dateFrom || '' %>"
              max="<%= new Date().toISOString().split('T')[0] %>"
            />
          </div>
          <div>
            <label for="dateTo" class="form-label form-label-sm text-muted mb-1">To</label>
            <input
              type="date"
              class="form-control form-control-sm"
              id="dateTo"
              name="dateTo"
              value="<%= searchOptions.dateTo || '' %>"
              max="<%= new Date().toISOString().split('T')[0] %>"
            />
          </div>
        </div>

        <!-- Camera Make -->
        <div class="filter-section mb-4">
          <h6 class="filter-section-title text-muted small text-uppercase fw-semibold mb-2">
            <i class="bi bi-camera me-1"></i>Camera Make
          </h6>
          <select class="form-select form-select-sm" id="cameraMake" name="cameraMake">
            <option value="">Any camera</option>
            <% if (facets && facets.cameraMakes) { %>
              <% facets.cameraMakes.forEach(function(make) { %>
                <option value="<%= make %>" <%= searchOptions.cameraMake === make ? 'selected' : '' %>>
                  <%= make %>
                </option>
              <% }); %>
            <% } %>
          </select>
        </div>

        <!-- GPS Filter -->
        <div class="filter-section mb-4">
          <h6 class="filter-section-title text-muted small text-uppercase fw-semibold mb-2">
            <i class="bi bi-geo-alt me-1"></i>Location
          </h6>
          <div class="form-check">
            <input
              class="form-check-input"
              type="checkbox"
              id="hasGps"
              name="hasGps"
              value="true"
              <%= searchOptions.hasGps ? 'checked' : '' %>
            />
            <label class="form-check-label" for="hasGps">
              Has GPS coordinates
            </label>
          </div>
        </div>

        <!-- Tag Filter -->
        <% if (facets && facets.tags && facets.tags.length > 0) { %>
        <div class="filter-section mb-4">
          <h6 class="filter-section-title text-muted small text-uppercase fw-semibold mb-2">
            <i class="bi bi-tags me-1"></i>Tags
          </h6>
          <div class="tag-filter-list" style="max-height: 250px; overflow-y: auto;">
            <% facets.tags.forEach(function(tag) { %>
              <% const isChecked = searchOptions.tags && searchOptions.tags.includes(tag.id); %>
              <div class="form-check tag-filter-item mb-1">
                <input
                  class="form-check-input"
                  type="checkbox"
                  id="tag-<%= tag.id %>"
                  name="tags"
                  value="<%= tag.id %>"
                  <%= isChecked ? 'checked' : '' %>
                />
                <label class="form-check-label d-flex justify-content-between align-items-center w-100" for="tag-<%= tag.id %>">
                  <span class="d-flex align-items-center gap-1">
                    <span
                      class="tag-dot"
                      style="display:inline-block;width:8px;height:8px;border-radius:50%;background-color:<%= tag.color || '#6c757d' %>;"
                    ></span>
                    <%= tag.name %>
                  </span>
                  <span class="badge bg-secondary-subtle text-secondary-emphasis rounded-pill ms-1">
                    <%= tag.imageCount %>
                  </span>
                </label>
              </div>
            <% }); %>
          </div>
        </div>
        <% } %>

        <!-- Action Buttons -->
        <div class="filter-actions d-grid gap-2">
          <button type="submit" class="btn btn-primary btn-sm">
            <i class="bi bi-funnel-fill me-1"></i>Apply Filters
          </button>
          <a href="/search<%= searchOptions.q ? '?q=' + encodeURIComponent(searchOptions.q) : '' %>" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-counterclockwise me-1"></i>Reset Filters
          </a>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
// Toggle icon direction when filter panel collapses/expands
(function() {
  const filterPanelBody = document.getElementById('filterPanelBody');
  const toggleIcon = document.getElementById('filterToggleIcon');
  if (filterPanelBody && toggleIcon) {
    filterPanelBody.addEventListener('hide.bs.collapse', function() {
      toggleIcon.className = 'bi bi-chevron-down';
    });
    filterPanelBody.addEventListener('show.bs.collapse', function() {
      toggleIcon.className = 'bi bi-chevron-up';
    });
  }

  // Validate date range
  const dateFrom = document.getElementById('dateFrom');
  const dateTo = document.getElementById('dateTo');
  if (dateFrom && dateTo) {
    dateFrom.addEventListener('change', function() {
      if (dateTo.value && this.value > dateTo.value) {
        dateTo.value = this.value;
      }
      dateTo.min = this.value;
    });
    dateTo.addEventListener('change', function() {
      if (dateFrom.value && this.value < dateFrom.value) {
        dateFrom.value = this.value;
      }
      dateFrom.max = this.value;
    });
  }
})();
</script>