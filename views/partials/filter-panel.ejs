<%
/*
 * filter-panel.ejs
 * Expects:
 *   opts        — structured search options object (from queryBuilder)
 *   cameraMakes — string[] of distinct camera make values
 *   allTags     — Tag[] array with {id, name, slug}
 */
%>

<div class="filter-panel card shadow-sm" id="filter-panel">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h6 class="mb-0 fw-semibold">
      <i class="bi bi-funnel me-1"></i>Filters
    </h6>
    <!-- Mobile toggle (controlled by Bootstrap collapse) -->
    <button
      class="btn btn-sm btn-outline-secondary d-lg-none"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#filter-panel-body"
      aria-expanded="false"
      aria-controls="filter-panel-body"
    >
      <i class="bi bi-chevron-down"></i>
    </button>
  </div>

  <!-- On desktop always visible; on mobile collapsible -->
  <div class="collapse d-lg-block" id="filter-panel-body">
    <div class="card-body p-3">

      <form method="GET" action="/search" id="filter-form">

        <!-- ── Text search ── -->
        <div class="mb-3">
          <label for="fp-q" class="form-label small fw-semibold">Keyword</label>
          <div class="input-group input-group-sm">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <input
              type="search"
              id="fp-q"
              name="q"
              class="form-control form-control-sm"
              placeholder="filename, description…"
              value="<%= opts.q || '' %>"
              autocomplete="off"
            >
          </div>
        </div>

        <!-- ── Date range ── -->
        <div class="mb-3">
          <label class="form-label small fw-semibold">Date Range</label>
          <div class="row g-1">
            <div class="col">
              <label for="fp-dateFrom" class="form-label visually-hidden">From</label>
              <input
                type="date"
                id="fp-dateFrom"
                name="dateFrom"
                class="form-control form-control-sm"
                placeholder="From"
                value="<%= opts.dateFrom || '' %>"
                title="Start date"
              >
            </div>
            <div class="col-auto d-flex align-items-center text-muted small">to</div>
            <div class="col">
              <label for="fp-dateTo" class="form-label visually-hidden">To</label>
              <input
                type="date"
                id="fp-dateTo"
                name="dateTo"
                class="form-control form-control-sm"
                placeholder="To"
                value="<%= opts.dateTo || '' %>"
                title="End date"
              >
            </div>
          </div>
        </div>

        <!-- ── Camera make ── -->
        <div class="mb-3">
          <label for="fp-cameraMake" class="form-label small fw-semibold">Camera Make</label>
          <select id="fp-cameraMake" name="cameraMake" class="form-select form-select-sm">
            <option value="">Any</option>
            <% if (cameraMakes && cameraMakes.length > 0) { %>
              <% cameraMakes.forEach(function(make) { %>
                <option value="<%= make %>" <%= (opts.cameraMake === make) ? 'selected' : '' %>>
                  <%= make %>
                </option>
              <% }); %>
            <% } %>
          </select>
        </div>

        <!-- ── Has GPS ── -->
        <div class="mb-3">
          <div class="form-check">
            <input
              class="form-check-input"
              type="checkbox"
              id="fp-hasGps"
              name="hasGps"
              value="1"
              <%= opts.hasGps ? 'checked' : '' %>
            >
            <label class="form-check-label small" for="fp-hasGps">
              <i class="bi bi-geo-alt me-1"></i>Has GPS location
            </label>
          </div>
        </div>

        <!-- ── Tags ── -->
        <% if (allTags && allTags.length > 0) { %>
          <div class="mb-3">
            <label class="form-label small fw-semibold">Tags</label>
            <div class="tag-checkbox-list" style="max-height:220px; overflow-y:auto;">
              <% allTags.forEach(function(tag) { %>
                <%
                  const tagSlug = tag.slug || tag.name;
                  const isChecked = opts.tags && (
                    opts.tags.includes(tagSlug) || opts.tags.includes(tag.name)
                  );
                %>
                <div class="form-check">
                  <input
                    class="form-check-input"
                    type="checkbox"
                    id="fp-tag-<%= tag.id %>"
                    name="tags"
                    value="<%= tagSlug %>"
                    <%= isChecked ? 'checked' : '' %>
                  >
                  <label class="form-check-label small" for="fp-tag-<%= tag.id %>">
                    <%= tag.name %>
                  </label>
                </div>
              <% }); %>
            </div>
          </div>
        <% } %>

        <!-- ── Actions ── -->
        <div class="d-grid gap-2">
          <button type="submit" class="btn btn-primary btn-sm">
            <i class="bi bi-search me-1"></i>Apply Filters
          </button>
          <a href="/search" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-x-circle me-1"></i>Reset
          </a>
        </div>

      </form><!-- /filter-form -->

    </div><!-- /card-body -->
  </div><!-- /collapse -->
</div><!-- /filter-panel -->