<div class="filter-panel card shadow-sm" id="filterPanel">
  <div class="card-header d-flex justify-content-between align-items-center py-2">
    <h5 class="mb-0 fs-6 fw-semibold">
      <i class="bi bi-funnel me-2"></i>Filters
    </h5>
    <button
      class="btn btn-sm btn-link p-0 text-muted d-lg-none"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#filterPanelBody"
      aria-expanded="false"
      aria-controls="filterPanelBody"
    >
      <i class="bi bi-chevron-down"></i>
    </button>
  </div>

  <div class="collapse show" id="filterPanelBody">
    <form action="/search" method="GET" id="filterForm">
      <!-- Preserve the text search query -->
      <% if (query && query.q) { %>
        <input type="hidden" name="q" value="<%= query.q %>">
      <% } %>

      <div class="card-body p-3">

        <!-- Date Range -->
        <div class="filter-section mb-3">
          <label class="filter-label fw-semibold text-uppercase small text-muted mb-2 d-block">
            <i class="bi bi-calendar3 me-1"></i>Date Range
          </label>
          <div class="mb-2">
            <label for="dateFrom" class="form-label small mb-1">From</label>
            <input
              type="date"
              class="form-control form-control-sm"
              id="dateFrom"
              name="dateFrom"
              value="<%= (query && query.dateFrom) ? query.dateFrom : '' %>"
              max="<%= new Date().toISOString().slice(0, 10) %>"
            >
          </div>
          <div>
            <label for="dateTo" class="form-label small mb-1">To</label>
            <input
              type="date"
              class="form-control form-control-sm"
              id="dateTo"
              name="dateTo"
              value="<%= (query && query.dateTo) ? query.dateTo : '' %>"
              max="<%= new Date().toISOString().slice(0, 10) %>"
            >
          </div>
        </div>

        <hr class="my-2">

        <!-- Camera Make -->
        <% if (facets && facets.cameraMakes && facets.cameraMakes.length > 0) { %>
          <div class="filter-section mb-3">
            <label for="cameraMake" class="filter-label fw-semibold text-uppercase small text-muted mb-2 d-block">
              <i class="bi bi-camera me-1"></i>Camera Make
            </label>
            <select
              class="form-select form-select-sm"
              id="cameraMake"
              name="cameraMake"
            >
              <option value="">Any Camera</option>
              <% facets.cameraMakes.forEach(function(make) { %>
                <option
                  value="<%= make %>"
                  <%= (query && query.cameraMake === make) ? 'selected' : '' %>
                ><%= make %></option>
              <% }); %>
            </select>
          </div>
          <hr class="my-2">
        <% } %>

        <!-- Has GPS Toggle -->
        <div class="filter-section mb-3">
          <label class="filter-label fw-semibold text-uppercase small text-muted mb-2 d-block">
            <i class="bi bi-geo-alt me-1"></i>Location
          </label>
          <div class="form-check">
            <input
              class="form-check-input"
              type="checkbox"
              id="hasGps"
              name="hasGps"
              value="true"
              <%= (query && (query.hasGps === 'true' || query.hasGps === '1')) ? 'checked' : '' %>
            >
            <label class="form-check-label small" for="hasGps">
              Has GPS coordinates
            </label>
          </div>
        </div>

        <hr class="my-2">

        <!-- Tags -->
        <% if (facets && facets.tags && facets.tags.length > 0) { %>
          <div class="filter-section mb-3">
            <label class="filter-label fw-semibold text-uppercase small text-muted mb-2 d-block">
              <i class="bi bi-tags me-1"></i>Tags
            </label>
            <div class="tag-filter-list" style="max-height: 200px; overflow-y: auto;">
              <% const activeTags = query && query.tags
                ? (Array.isArray(query.tags) ? query.tags : [query.tags])
                : []; %>
              <% facets.tags.forEach(function(tag) { %>
                <div class="form-check">
                  <input
                    class="form-check-input"
                    type="checkbox"
                    name="tags"
                    value="<%= tag.name %>"
                    id="tag_<%= tag.id %>"
                    <%= activeTags.includes(tag.name) ? 'checked' : '' %>
                  >
                  <label class="form-check-label small d-flex justify-content-between" for="tag_<%= tag.id %>">
                    <span><%= tag.name %></span>
                    <span class="badge bg-secondary-subtle text-secondary-emphasis ms-1"><%= tag.count %></span>
                  </label>
                </div>
              <% }); %>
            </div>
          </div>
        <% } else if (!facets || !facets.tags || facets.tags.length === 0) { %>
          <div class="filter-section mb-3">
            <label class="filter-label fw-semibold text-uppercase small text-muted mb-2 d-block">
              <i class="bi bi-tags me-1"></i>Tags
            </label>
            <p class="text-muted small mb-0">No tags available</p>
          </div>
        <% } %>

      </div>

      <div class="card-footer bg-transparent p-3">
        <div class="d-grid gap-2">
          <button type="submit" class="btn btn-primary btn-sm">
            <i class="bi bi-funnel-fill me-1"></i>Apply Filters
          </button>
          <a href="/search<%= query && query.q ? '?q=' + encodeURIComponent(query.q) : '' %>" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-x-circle me-1"></i>Reset Filters
          </a>
        </div>
      </div>
    </form>
  </div>
</div>