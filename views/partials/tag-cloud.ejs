<% if (typeof tags !== 'undefined' && tags && tags.length > 0) { %>
<div class="tag-cloud">
  <%
    const counts = tags.map(t => t.imageCount || 0);
    const maxCount = Math.max(...counts, 1);
    const minCount = Math.min(...counts, 0);
    const minSize = 0.8;
    const maxSize = 2.0;

    function getTagSize(count) {
      if (maxCount === minCount) return (minSize + maxSize) / 2;
      // Logarithmic scaling
      const logMin = Math.log(minCount + 1);
      const logMax = Math.log(maxCount + 1);
      const logCount = Math.log(count + 1);
      if (logMax === logMin) return (minSize + maxSize) / 2;
      const ratio = (logCount - logMin) / (logMax - logMin);
      return minSize + ratio * (maxSize - minSize);
    }
  %>
  <% tags.forEach(function(tag) { %>
    <%
      const fontSize = getTagSize(tag.imageCount || 0).toFixed(2);
      const color = tag.color || '#6c757d';
    %>
    <a href="/gallery?tag=<%= tag.slug %>"
       class="tag-cloud-item text-decoration-none"
       style="font-size: <%= fontSize %>rem; color: <%= color %>;"
       title="<%= tag.name %> (<%= tag.imageCount || 0 %> image<%= (tag.imageCount || 0) !== 1 ? 's' : '' %>)">
      <%= tag.name %>
    </a>
  <% }) %>
</div>
<% } else { %>
<p class="text-muted small"><em>No tags yet.</em></p>
<% } %>