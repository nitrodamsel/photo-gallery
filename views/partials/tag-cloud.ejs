<% if (typeof tags !== 'undefined' && tags && tags.length > 0) { %>
  <%
    const counts = tags.map(function(t) { return t.imageCount || 0; });
    const minCount = Math.min.apply(null, counts);
    const maxCount = Math.max.apply(null, counts);
    const minSize = 0.8;
    const maxSize = 2.0;

    function getTagSize(count) {
      if (maxCount === minCount) return (minSize + maxSize) / 2;
      var logMin = Math.log(minCount + 1);
      var logMax = Math.log(maxCount + 1);
      var logCount = Math.log(count + 1);
      if (logMax === logMin) return (minSize + maxSize) / 2;
      return minSize + (logCount - logMin) / (logMax - logMin) * (maxSize - minSize);
    }
  %>
  <div class="tag-cloud d-flex flex-wrap gap-1 align-items-center">
    <% tags.forEach(function(tag) { %>
      <%
        var size = getTagSize(tag.imageCount || 0);
        var sizeRem = size.toFixed(2);
        var bgColor = tag.color || '#6c757d';
      %>
      <a href="/gallery?tag=<%= tag.slug %>" 
         class="tag-cloud-item text-decoration-none"
         style="font-size: <%= sizeRem %>rem; line-height: 1.2;"
         title="<%= tag.name %> (<%= tag.imageCount || 0 %> image<%= (tag.imageCount || 0) !== 1 ? 's' : '' %>)">
        <span class="badge" style="background-color: <%= bgColor %>; font-size: inherit;">
          <%= tag.name %>
          <small class="opacity-75">(<%= tag.imageCount || 0 %>)</small>
        </span>
      </a>
    <% }); %>
  </div>
<% } else { %>
  <p class="text-muted small mb-0">No tags yet. <a href="/tags">Create some tags</a> to get started!</p>
<% } %>