<% if (tags && tags.length > 0) { %>
  <%
    var counts = tags.map(function(t) {
      return parseInt((t.dataValues && t.dataValues.imageCount) || 0);
    });
    var minCount = Math.max(1, Math.min.apply(null, counts.length ? counts : [1]));
    var maxCount = Math.max(1, Math.max.apply(null, counts.length ? counts : [1]));

    function getTagFontSize(count) {
      var c = Math.max(1, parseInt(count) || 1);
      if (maxCount === minCount) return 1.2;
      var logMin = Math.log(minCount);
      var logMax = Math.log(maxCount);
      var logC = Math.log(c);
      if (logMax === logMin) return 1.2;
      var scale = (logC - logMin) / (logMax - logMin);
      return 0.8 + scale * (2.0 - 0.8);
    }
  %>
  <div class="tag-cloud">
    <% tags.forEach(function(tag) { %>
      <%
        var count = parseInt((tag.dataValues && tag.dataValues.imageCount) || 0);
        var fontSize = getTagFontSize(count).toFixed(2);
        var tagColor = tag.color || '#6c757d';
      %>
      <a href="/gallery?tag=<%= encodeURIComponent(tag.slug) %>"
         class="tag-cloud-item"
         style="font-size: <%= fontSize %>rem; color: <%= tagColor %>;"
         title="<%= tag.name %> (<%= count %> image<%= count !== 1 ? 's' : '' %>)">
        <%= tag.name %>
      </a>
    <% }); %>
  </div>
<% } else { %>
  <p class="text-muted small mb-0">No tags yet. <a href="/tags">Create one!</a></p>
<% } %>