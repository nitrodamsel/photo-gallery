<%
/**
 * Tag Cloud Partial
 * Usage: <%- include('partials/tag-cloud', { tags: [...], title: 'Browse by Tag' }) %>
 *
 * Each tag should have: id, name, slug, color, imageCount (or dataValue imageCount)
 */
const cloudTitle = typeof title !== 'undefined' ? title : 'Browse by Tag';
const cloudTags = typeof tags !== 'undefined' ? tags : [];

// Compute min/max counts for logarithmic scaling
const counts = cloudTags.map(t => {
  const c = t.getDataValue ? (t.getDataValue('imageCount') || 0) : (t.imageCount || 0);
  return parseInt(c, 10) || 0;
});
const minCount = counts.length > 0 ? Math.min(...counts) : 0;
const maxCount = counts.length > 0 ? Math.max(...counts) : 1;

const minFont = 0.8;  // rem
const maxFont = 2.0;  // rem

function getTagFontSize(count) {
  if (maxCount === minCount) return ((minFont + maxFont) / 2).toFixed(2) + 'rem';
  // Logarithmic scale
  const logMin = Math.log(minCount + 1);
  const logMax = Math.log(maxCount + 1);
  const logCount = Math.log(count + 1);
  const scale = logMax > logMin ? (logCount - logMin) / (logMax - logMin) : 0.5;
  const size = minFont + scale * (maxFont - minFont);
  return size.toFixed(2) + 'rem';
}
%>

<% if (cloudTags && cloudTags.length > 0) { %>
<div class="tag-cloud-widget">
  <% if (cloudTitle) { %>
  <h6 class="tag-cloud-title fw-semibold text-uppercase text-muted mb-3">
    <i class="bi bi-tags me-1"></i><%= cloudTitle %>
  </h6>
  <% } %>
  <div class="tag-cloud d-flex flex-wrap gap-1 align-items-center">
    <% cloudTags.forEach(function(tag) { %>
      <%
        const count = tag.getDataValue
          ? (parseInt(tag.getDataValue('imageCount'), 10) || 0)
          : (parseInt(tag.imageCount, 10) || 0);
        const fontSize = getTagFontSize(count);
        const bgColor = tag.color || '#6c757d';
      %>
      <a
        href="/gallery?tag=<%= encodeURIComponent(tag.name) %>"
        class="tag-cloud-item text-decoration-none"
        style="font-size: <%= fontSize %>; color: <%= bgColor %>;"
        title="<%= tag.name %> (<%= count %> image<%= count !== 1 ? 's' : '' %>)"
      >
        <%= tag.name %>
        <sup class="tag-count" style="font-size:0.6rem;opacity:0.7;"><%= count %></sup>
      </a>
    <% }); %>
  </div>
</div>
<% } else { %>
<div class="tag-cloud-widget text-muted fst-italic small">
  <i class="bi bi-tags me-1"></i>No tags yet.
</div>
<% } %>