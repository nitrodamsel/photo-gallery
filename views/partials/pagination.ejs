<%
  var currentPage = pagination.page;
  var totalPages = pagination.totalPages;
  var limit = pagination.limit;

  // Build query string preserving existing params except 'page'
  function buildHref(pageNum) {
    var params = Object.assign({}, query || {});
    params.page = pageNum;
    var parts = [];
    Object.keys(params).forEach(function(k) {
      if (params[k] !== undefined && params[k] !== null && params[k] !== '') {
        parts.push(encodeURIComponent(k) + '=' + encodeURIComponent(params[k]));
      }
    });
    return '/gallery?' + parts.join('&');
  }

  // Determine page range to display (max 5 pages shown)
  var windowSize = 5;
  var startPage = Math.max(1, currentPage - Math.floor(windowSize / 2));
  var endPage = Math.min(totalPages, startPage + windowSize - 1);
  if (endPage - startPage + 1 < windowSize) {
    startPage = Math.max(1, endPage - windowSize + 1);
  }
%>

<% if (totalPages > 1) { %>
<nav class="pagination" aria-label="Gallery pagination">
  <ul class="pagination-list">

    <!-- Previous -->
    <li class="pagination-item">
      <% if (currentPage > 1) { %>
        <a href="<%= buildHref(currentPage - 1) %>" class="pagination-btn pagination-prev" rel="prev" aria-label="Go to previous page">
          &#8592; Prev
        </a>
      <% } else { %>
        <span class="pagination-btn pagination-prev disabled" aria-disabled="true">&#8592; Prev</span>
      <% } %>
    </li>

    <!-- First page + ellipsis -->
    <% if (startPage > 1) { %>
      <li class="pagination-item">
        <a href="<%= buildHref(1) %>" class="pagination-btn" aria-label="Go to page 1">1</a>
      </li>
      <% if (startPage > 2) { %>
        <li class="pagination-item pagination-ellipsis" aria-hidden="true"><span>…</span></li>
      <% } %>
    <% } %>

    <!-- Page numbers -->
    <% for (var p = startPage; p <= endPage; p++) { %>
      <li class="pagination-item">
        <% if (p === currentPage) { %>
          <span class="pagination-btn pagination-current" aria-current="page" aria-label="Page <%= p %>, current">
            <%= p %>
          </span>
        <% } else { %>
          <a href="<%= buildHref(p) %>" class="pagination-btn" aria-label="Go to page <%= p %>">
            <%= p %>
          </a>
        <% } %>
      </li>
    <% } %>

    <!-- Ellipsis + Last page -->
    <% if (endPage < totalPages) { %>
      <% if (endPage < totalPages - 1) { %>
        <li class="pagination-item pagination-ellipsis" aria-hidden="true"><span>…</span></li>
      <% } %>
      <li class="pagination-item">
        <a href="<%= buildHref(totalPages) %>" class="pagination-btn" aria-label="Go to page <%= totalPages %>">
          <%= totalPages %>
        </a>
      </li>
    <% } %>

    <!-- Next -->
    <li class="pagination-item">
      <% if (currentPage < totalPages) { %>
        <a href="<%= buildHref(currentPage + 1) %>" class="pagination-btn pagination-next" rel="next" aria-label="Go to next page">
          Next &#8594;
        </a>
      <% } else { %>
        <span class="pagination-btn pagination-next disabled" aria-disabled="true">Next &#8594;</span>
      <% } %>
    </li>

  </ul>

  <p class="pagination-info" aria-live="polite">
    Page <%= currentPage %> of <%= totalPages %>
    (<%= pagination.total %> image<%= pagination.total !== 1 ? 's' : '' %> total)
  </p>
</nav>
<% } %>