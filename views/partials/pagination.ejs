<%
// Build query string preserving existing params except 'page'
function buildQuery(params, newPage) {
  const q = Object.assign({}, params, { page: newPage });
  // Remove undefined/null values
  Object.keys(q).forEach(k => { if (!q[k] || q[k] === '1' && k === 'page') {} });
  const parts = [];
  Object.keys(q).forEach(function(k) {
    if (q[k] != null && q[k] !== '') {
      parts.push(encodeURIComponent(k) + '=' + encodeURIComponent(q[k]));
    }
  });
  return parts.length ? '?' + parts.join('&') : '';
}

const basePath = basePath || '/gallery';
const currentPage = page || 1;
const tp = totalPages || 1;

// Calculate page window
const delta = 2;
const rangeStart = Math.max(1, currentPage - delta);
const rangeEnd = Math.min(tp, currentPage + delta);
const pages = [];
for (let i = rangeStart; i <= rangeEnd; i++) {
  pages.push(i);
}
%>
<% if (tp > 1) { %>
<nav class="pagination" aria-label="Gallery pagination">
  <ul class="pagination-list">

    <!-- Previous -->
    <li class="pagination-item">
      <% if (currentPage > 1) { %>
        <a
          href="<%= basePath %><%= buildQuery(query, currentPage - 1) %>"
          class="pagination-btn"
          aria-label="Previous page"
        >&larr; Prev</a>
      <% } else { %>
        <span class="pagination-btn disabled" aria-disabled="true">&larr; Prev</span>
      <% } %>
    </li>

    <!-- First page + ellipsis -->
    <% if (rangeStart > 1) { %>
      <li class="pagination-item">
        <a href="<%= basePath %><%= buildQuery(query, 1) %>" class="pagination-btn">1</a>
      </li>
      <% if (rangeStart > 2) { %>
        <li class="pagination-item pagination-ellipsis" aria-hidden="true">…</li>
      <% } %>
    <% } %>

    <!-- Page numbers -->
    <% pages.forEach(function(p) { %>
      <li class="pagination-item">
        <% if (p === currentPage) { %>
          <span class="pagination-btn active" aria-current="page"><%= p %></span>
        <% } else { %>
          <a href="<%= basePath %><%= buildQuery(query, p) %>" class="pagination-btn"><%= p %></a>
        <% } %>
      </li>
    <% }); %>

    <!-- Last page + ellipsis -->
    <% if (rangeEnd < tp) { %>
      <% if (rangeEnd < tp - 1) { %>
        <li class="pagination-item pagination-ellipsis" aria-hidden="true">…</li>
      <% } %>
      <li class="pagination-item">
        <a href="<%= basePath %><%= buildQuery(query, tp) %>" class="pagination-btn"><%= tp %></a>
      </li>
    <% } %>

    <!-- Next -->
    <li class="pagination-item">
      <% if (currentPage < tp) { %>
        <a
          href="<%= basePath %><%= buildQuery(query, currentPage + 1) %>"
          class="pagination-btn"
          aria-label="Next page"
        >Next &rarr;</a>
      <% } else { %>
        <span class="pagination-btn disabled" aria-disabled="true">Next &rarr;</span>
      <% } %>
    </li>

  </ul>

  <p class="pagination-info">
    Page <%= currentPage %> of <%= tp %>
  </p>
</nav>
<% } %>