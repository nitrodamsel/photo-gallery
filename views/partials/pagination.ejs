<% if (pagination.totalPages > 1) { %>
<nav class="pagination" aria-label="Gallery pagination">
  <%
    // Build base query string preserving existing params except page
    var baseParams = Object.assign({}, query);
    delete baseParams.page;
    var baseQs = Object.keys(baseParams).length > 0
      ? '&' + Object.keys(baseParams).map(function(k) { return encodeURIComponent(k) + '=' + encodeURIComponent(baseParams[k]); }).join('&')
      : '';
  %>

  <!-- Previous -->
  <% if (pagination.page > 1) { %>
    <a href="?page=<%= pagination.page - 1 %><%= baseQs %>" class="pagination-btn" aria-label="Previous page">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
      Prev
    </a>
  <% } else { %>
    <span class="pagination-btn disabled" aria-disabled="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
      Prev
    </span>
  <% } %>

  <!-- Page Numbers -->
  <div class="pagination-pages">
    <%
      var startPage = Math.max(1, pagination.page - 2);
      var endPage = Math.min(pagination.totalPages, pagination.page + 2);
    %>

    <% if (startPage > 1) { %>
      <a href="?page=1<%= baseQs %>" class="pagination-page">1</a>
      <% if (startPage > 2) { %>
        <span class="pagination-ellipsis">…</span>
      <% } %>
    <% } %>

    <% for (var p = startPage; p <= endPage; p++) { %>
      <% if (p === pagination.page) { %>
        <span class="pagination-page active" aria-current="page"><%= p %></span>
      <% } else { %>
        <a href="?page=<%= p %><%= baseQs %>" class="pagination-page"><%= p %></a>
      <% } %>
    <% } %>

    <% if (endPage < pagination.totalPages) { %>
      <% if (endPage < pagination.totalPages - 1) { %>
        <span class="pagination-ellipsis">…</span>
      <% } %>
      <a href="?page=<%= pagination.totalPages %><%= baseQs %>" class="pagination-page"><%= pagination.totalPages %></a>
    <% } %>
  </div>

  <!-- Next -->
  <% if (pagination.page < pagination.totalPages) { %>
    <a href="?page=<%= pagination.page + 1 %><%= baseQs %>" class="pagination-btn" aria-label="Next page">
      Next
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
    </a>
  <% } else { %>
    <span class="pagination-btn disabled" aria-disabled="true">
      Next
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
    </span>
  <% } %>
</nav>
<% } %>