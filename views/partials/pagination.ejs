<% if (totalPages > 1) { %>
  <nav class="mt-4" aria-label="Gallery pagination">
    <ul class="pagination justify-content-center">
      <li class="page-item <%= page <= 1 ? 'disabled' : '' %>">
        <a class="page-link" href="?page=<%= page - 1 %><%= search ? '&search=' + encodeURIComponent(search) : '' %><%= currentTag ? '&tag=' + encodeURIComponent(currentTag.slug) : '' %>">
          <i class="bi bi-chevron-left"></i> Prev
        </a>
      </li>
      <% for (var i = Math.max(1, page - 2); i <= Math.min(totalPages, page + 2); i++) { %>
        <li class="page-item <%= i === page ? 'active' : '' %>">
          <a class="page-link" href="?page=<%= i %><%= search ? '&search=' + encodeURIComponent(search) : '' %><%= currentTag ? '&tag=' + encodeURIComponent(currentTag.slug) : '' %>">
            <%= i %>
          </a>
        </li>
      <% } %>
      <li class="page-item <%= page >= totalPages ? 'disabled' : '' %>">
        <a class="page-link" href="?page=<%= page + 1 %><%= search ? '&search=' + encodeURIComponent(search) : '' %><%= currentTag ? '&tag=' + encodeURIComponent(currentTag.slug) : '' %>">
          Next <i class="bi bi-chevron-right"></i>
        </a>
      </li>
    </ul>
    <p class="text-center text-muted small">Page <%= page %> of <%= totalPages %></p>
  </nav>
<% } %>