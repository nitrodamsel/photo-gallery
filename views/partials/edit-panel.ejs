<!-- Edit Panel - Slide-in panel for image detail page -->
<div id="edit-panel" class="edit-panel">
  <div class="edit-panel-inner">
    <div class="edit-panel-header">
      <h3 class="title is-5 mb-0">
        <span class="icon"><i class="fas fa-edit"></i></span>
        Edit Image
      </h3>
      <button id="edit-cancel-btn" class="delete is-medium" aria-label="Close editor"></button>
    </div>

    <div class="edit-panel-body">
      <form id="edit-form" autocomplete="off">

        <!-- Hidden inputs -->
        <input type="hidden" id="rotation-input" value="<%= image.rotation || 0 %>">
        <input type="hidden" id="current-rotation" value="<%= image.rotation || 0 %>">

        <!-- Description -->
        <div class="field">
          <label class="label" for="edit-description">Description</label>
          <div class="control">
            <textarea
              id="edit-description"
              class="textarea"
              rows="3"
              placeholder="Add a description..."
            ><%= image.description || '' %></textarea>
          </div>
        </div>

        <!-- Rotation Controls -->
        <div class="field">
          <label class="label">Rotation / Flip</label>
          <div class="control">
            <p id="rotation-label" class="help mb-2">
              Current: <%= (image.rotation === -1) ? 'Flip H' : (image.rotation === -2) ? 'Flip V' : (image.rotation || 0) + '°' %>
            </p>
            <div class="buttons are-small">
              <button type="button" class="button is-info is-light" data-rotation-action="ccw90" title="Rotate 90° counter-clockwise">
                <span class="icon"><i class="fas fa-undo"></i></span>
                <span>90° CCW</span>
              </button>
              <button type="button" class="button is-info is-light" data-rotation-action="cw90" title="Rotate 90° clockwise">
                <span class="icon"><i class="fas fa-redo"></i></span>
                <span>90° CW</span>
              </button>
              <button type="button" class="button is-info is-light" data-rotation-action="flipH" title="Flip horizontally">
                <span class="icon">↔</span>
                <span>Flip H</span>
              </button>
              <button type="button" class="button is-light" data-rotation-action="0" title="Reset rotation">
                <span class="icon"><i class="fas fa-sync-alt"></i></span>
                <span>Reset</span>
              </button>
            </div>
            <p class="help has-text-grey-light">
              Preview updates live. Click Save to apply permanently.
            </p>
          </div>
        </div>

        <hr class="edit-divider">

        <!-- Manual EXIF Overrides -->
        <p class="label mb-2">Manual EXIF Overrides</p>
        <p class="help mb-3 has-text-grey">These fields override or supplement the auto-detected EXIF data.</p>

        <div class="field">
          <label class="label is-small" for="edit-caption">Caption</label>
          <div class="control">
            <input
              id="edit-caption"
              class="input is-small"
              type="text"
              placeholder="Image caption"
              value="<%= (image.manualExif && image.manualExif.caption) ? image.manualExif.caption : '' %>"
            >
          </div>
        </div>

        <div class="field">
          <label class="label is-small" for="edit-location">Location Name</label>
          <div class="control">
            <input
              id="edit-location"
              class="input is-small"
              type="text"
              placeholder="e.g. Paris, France"
              value="<%= (image.manualExif && image.manualExif.location) ? image.manualExif.location : '' %>"
            >
          </div>
        </div>

        <div class="field">
          <label class="label is-small" for="edit-date-taken">Date Taken</label>
          <div class="control">
            <input
              id="edit-date-taken"
              class="input is-small"
              type="datetime-local"
              value="<%= (image.manualExif && image.manualExif.dateTaken) ? image.manualExif.dateTaken.replace(' ', 'T').substring(0, 16) : '' %>"
            >
          </div>
        </div>

        <div class="field">
          <label class="label is-small" for="edit-camera">Camera / Device</label>
          <div class="control">
            <input
              id="edit-camera"
              class="input is-small"
              type="text"
              placeholder="e.g. Canon EOS 5D Mark IV"
              value="<%= (image.manualExif && image.manualExif.camera) ? image.manualExif.camera : '' %>"
            >
          </div>
        </div>

        <div class="field">
          <label class="label is-small" for="edit-lens">Lens</label>
          <div class="control">
            <input
              id="edit-lens"
              class="input is-small"
              type="text"
              placeholder="e.g. 50mm f/1.4"
              value="<%= (image.manualExif && image.manualExif.lens) ? image.manualExif.lens : '' %>"
            >
          </div>
        </div>

        <hr class="edit-divider">

        <!-- Save / Cancel -->
        <div class="field is-grouped">
          <div class="control">
            <button type="button" id="edit-save-btn" class="button is-primary">
              <span class="icon"><i class="fas fa-save"></i></span>
              <span>Save Changes</span>
            </button>
          </div>
          <div class="control">
            <button type="button" id="edit-cancel-btn-footer" class="button is-light" onclick="document.getElementById('edit-cancel-btn').click()">
              Cancel
            </button>
          </div>
        </div>

      </form>

      <hr class="edit-divider">

      <!-- Admin Actions -->
      <div class="edit-admin-section">
        <p class="label is-small mb-2">Admin Actions</p>
        <div class="buttons are-small">
          <button type="button" id="regenerate-thumbnails-btn" class="button is-warning is-light">
            <span class="icon"><i class="fas fa-images"></i></span>
            <span>Regenerate Thumbnails</span>
          </button>
          <button type="button" id="delete-image-btn" class="button is-danger is-light">
            <span class="icon"><i class="fas fa-trash"></i></span>
            <span>Delete Image</span>
          </button>
        </div>
      </div>

    </div><!-- /.edit-panel-body -->
  </div><!-- /.edit-panel-inner -->
</div><!-- /#edit-panel -->