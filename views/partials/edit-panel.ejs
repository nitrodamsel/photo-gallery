<%# Edit Panel - Slide-in panel for image editing on the detail page %>
<div
  id="editPanel"
  class="edit-panel"
  data-image-id="<%= image.id %>"
  data-rotation="<%= image.rotation || 0 %>"
>
  <div class="edit-panel__header">
    <h3 class="edit-panel__title">✏️ Edit Image</h3>
    <span class="edit-panel__subtitle">Changes are saved without modifying the original file</span>
  </div>

  <form id="editForm" class="edit-panel__form">

    <%# Description %>
    <div class="edit-panel__section">
      <label class="edit-panel__label" for="editDescription">Description</label>
      <textarea
        id="editDescription"
        class="edit-panel__textarea"
        name="description"
        rows="4"
        placeholder="Enter a description for this image..."
      ><%= image.description || '' %></textarea>
    </div>

    <%# Manual EXIF Overrides %>
    <div class="edit-panel__section">
      <h4 class="edit-panel__section-title">Manual EXIF Overrides</h4>
      <p class="edit-panel__hint">These fields override or supplement the auto-detected EXIF data.</p>

      <div class="edit-panel__field">
        <label class="edit-panel__label" for="editCaption">Caption / Title</label>
        <input
          type="text"
          id="editCaption"
          class="edit-panel__input"
          name="caption"
          placeholder="Caption or title for the image"
          value="<%= (image.manualExif && image.manualExif.caption) ? image.manualExif.caption : '' %>"
        >
      </div>

      <div class="edit-panel__field">
        <label class="edit-panel__label" for="editLocation">Location Name</label>
        <input
          type="text"
          id="editLocation"
          class="edit-panel__input"
          name="location"
          placeholder="e.g. Paris, France"
          value="<%= (image.manualExif && image.manualExif.locationName) ? image.manualExif.locationName : '' %>"
        >
      </div>

      <div class="edit-panel__field">
        <label class="edit-panel__label" for="editDateTaken">Date Taken</label>
        <input
          type="text"
          id="editDateTaken"
          class="edit-panel__input"
          name="dateTaken"
          placeholder="e.g. 2024-06-15 or June 15, 2024"
          value="<%= (image.manualExif && image.manualExif.dateTaken) ? image.manualExif.dateTaken : '' %>"
        >
      </div>
    </div>

    <%# Rotation Controls %>
    <div class="edit-panel__section" id="rotationSection">
      <h4 class="edit-panel__section-title">Rotation & Orientation</h4>
      <p class="edit-panel__hint">Non-destructive — the original file is never modified.</p>

      <div class="rotation-controls">
        <div class="rotation-current">
          Current: <strong id="currentRotationDisplay"><%= image.rotation || 0 %>°</strong>
        </div>
        <div class="rotation-buttons">
          <button type="button" id="rotateCCWBtn" class="btn btn--secondary rotation-btn" title="Rotate 90° Counter-Clockwise">
            ↺ 90° CCW
          </button>
          <button type="button" id="rotateCWBtn" class="btn btn--secondary rotation-btn" title="Rotate 90° Clockwise">
            ↻ 90° CW
          </button>
          <button type="button" id="flipHBtn" class="btn btn--secondary rotation-btn" title="Flip Horizontal (180°)">
            ↔ Flip
          </button>
        </div>
      </div>
    </div>

    <%# Status Message %>
    <div id="editStatus" class="edit-status" role="status" aria-live="polite"></div>

    <%# Action Buttons %>
    <div class="edit-panel__actions">
      <button type="submit" id="saveEditBtn" class="btn btn--primary">
        💾 Save Changes
      </button>
      <button type="button" id="cancelEditBtn" class="btn btn--secondary">
        Cancel
      </button>
    </div>

  </form>

  <%# Admin / Danger Zone %>
  <div class="edit-panel__section edit-panel__danger-zone">
    <h4 class="edit-panel__section-title edit-panel__danger-title">Admin Actions</h4>

    <div class="edit-panel__admin-actions">
      <button type="button" id="regenerateThumbsBtn" class="btn btn--secondary">
        🔄 Regenerate Thumbnails
      </button>

      <button type="button" id="deleteImageBtn" class="btn btn--danger">
        🗑️ Delete Image
      </button>
    </div>

    <p class="edit-panel__danger-hint">Deleting an image is permanent and cannot be undone.</p>
  </div>
</div>