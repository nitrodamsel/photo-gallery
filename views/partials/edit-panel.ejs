<div id="edit-panel" class="edit-panel" aria-hidden="true" role="dialog" aria-label="Edit Image">
  <div class="edit-panel-inner">
    <div class="edit-panel-header">
      <h2 class="edit-panel-title">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        Edit Image
      </h2>
      <button id="edit-panel-close" class="edit-panel-close" aria-label="Close edit panel">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <form id="edit-form" class="edit-form" novalidate>
      <!-- Description -->
      <div class="edit-field-group">
        <label class="edit-label" for="edit-description">Description</label>
        <textarea
          id="edit-description"
          name="description"
          class="edit-textarea"
          rows="4"
          placeholder="Add a description for this image..."
        ><%= image.description || '' %></textarea>
      </div>

      <!-- Rotation Controls -->
      <div class="edit-field-group">
        <label class="edit-label">Rotation</label>
        <p class="edit-help-text">Changes are applied non-destructively. Original file is never modified.</p>
        <div class="rotation-controls">
          <button type="button" class="rotation-btn" data-action="ccw" title="Rotate 90° Counter-Clockwise">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.5"/></svg>
            <span>90° CCW</span>
          </button>
          <button type="button" class="rotation-btn" data-action="cw" title="Rotate 90° Clockwise">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-.49-4.5"/></svg>
            <span>90° CW</span>
          </button>
          <button type="button" class="rotation-btn" data-action="flip" title="Flip Horizontal">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
            <span>Flip H</span>
          </button>
          <div class="rotation-display">
            <span class="rotation-label">Current:</span>
            <span id="rotation-value-display"><%= image.rotation || 0 %>°</span>
          </div>
        </div>
        <input type="hidden" id="edit-rotation" name="rotation" value="<%= image.rotation || 0 %>">
      </div>

      <!-- Manual EXIF Overrides -->
      <div class="edit-field-group">
        <label class="edit-label">Manual EXIF Overrides</label>
        <p class="edit-help-text">These values override the auto-detected EXIF data.</p>

        <div class="edit-sub-field">
          <label class="edit-sub-label" for="edit-caption">Caption</label>
          <input
            type="text"
            id="edit-caption"
            name="caption"
            class="edit-input"
            placeholder="Image caption..."
            value="<%= (image.manualExif && JSON.parse(image.manualExif || '{}').caption) ? JSON.parse(image.manualExif).caption : '' %>"
          >
        </div>

        <div class="edit-sub-field">
          <label class="edit-sub-label" for="edit-location">Location Name</label>
          <input
            type="text"
            id="edit-location"
            name="locationName"
            class="edit-input"
            placeholder="e.g. Paris, France"
            value="<%= (image.manualExif && JSON.parse(image.manualExif || '{}').locationName) ? JSON.parse(image.manualExif).locationName : '' %>"
          >
        </div>

        <div class="edit-sub-field">
          <label class="edit-sub-label" for="edit-date-taken">Date Taken</label>
          <input
            type="datetime-local"
            id="edit-date-taken"
            name="dateTaken"
            class="edit-input"
            value="<%= (() => { try { const m = JSON.parse(image.manualExif || '{}'); return m.dateTaken ? new Date(m.dateTaken).toISOString().slice(0,16) : ''; } catch(e) { return ''; } })() %>"
          >
        </div>

        <div class="edit-sub-field">
          <label class="edit-sub-label" for="edit-camera">Camera/Device</label>
          <input
            type="text"
            id="edit-camera"
            name="camera"
            class="edit-input"
            placeholder="e.g. Canon EOS R5"
            value="<%= (image.manualExif && JSON.parse(image.manualExif || '{}').camera) ? JSON.parse(image.manualExif).camera : '' %>"
          >
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="edit-actions">
        <button type="submit" id="edit-save-btn" class="btn btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
          Save Changes
        </button>
        <button type="button" id="edit-cancel-btn" class="btn btn-secondary">
          Cancel
        </button>
        <button type="button" id="edit-delete-btn" class="btn btn-danger">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
          Delete Image
        </button>
      </div>

      <!-- Status Message -->
      <div id="edit-status" class="edit-status" aria-live="polite"></div>
    </form>

    <!-- Regenerate Thumbnails Section -->
    <div class="edit-admin-section">
      <h3 class="edit-admin-title">Admin Actions</h3>
      <button type="button" id="regenerate-thumbnails-btn" class="btn btn-outline">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
        Regenerate Thumbnails
      </button>
      <p class="edit-help-text">Use this after moving the server or if thumbnails appear broken.</p>
    </div>
  </div>
</div>

<!-- Edit Panel Overlay -->
<div id="edit-panel-overlay" class="edit-panel-overlay"></div>