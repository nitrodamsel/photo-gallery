<%
  const currentRotation = image.rotation || 0;
  const manualExif = image.manualExif || {};
  const description = image.description || '';
%>

<!-- Edit Panel Slide-in -->
<div
  id="edit-panel"
  class="edit-panel panel-closed box"
  data-current-rotation="<%= currentRotation %>"
  data-original-description="<%= description.replace(/"/g, '&quot;') %>"
  aria-label="Image edit panel"
>
  <h3 class="title is-5">
    <span class="icon"><i class="fas fa-edit"></i></span>
    Edit Image
  </h3>

  <!-- Description -->
  <div class="field">
    <label class="label" for="edit-description">Description</label>
    <div class="control">
      <textarea
        id="edit-description"
        class="textarea"
        rows="3"
        placeholder="Enter image description..."
      ><%= description %></textarea>
    </div>
  </div>

  <!-- Manual EXIF Overrides -->
  <h4 class="title is-6 mt-4">Manual EXIF Overrides</h4>

  <div class="field">
    <label class="label" for="edit-caption">Caption</label>
    <div class="control">
      <input
        id="edit-caption"
        class="input"
        type="text"
        placeholder="Photo caption..."
        value="<%= manualExif.caption || '' %>"
      />
    </div>
  </div>

  <div class="field">
    <label class="label" for="edit-location-name">Location Name</label>
    <div class="control">
      <input
        id="edit-location-name"
        class="input"
        type="text"
        placeholder="e.g. Paris, France"
        value="<%= manualExif.locationName || '' %>"
      />
    </div>
  </div>

  <div class="field">
    <label class="label" for="edit-date-taken">Date Taken</label>
    <div class="control">
      <input
        id="edit-date-taken"
        class="input"
        type="date"
        value="<%= manualExif.dateTaken || '' %>"
      />
    </div>
    <p class="help">Override the EXIF date with a manual entry</p>
  </div>

  <!-- Rotation Controls -->
  <h4 class="title is-6 mt-4">Rotation</h4>

  <div class="field">
    <p class="help mb-2">
      Current rotation:
      <strong>
        <span id="current-rotation-display"><%= currentRotation %>°</span>
      </strong>
    </p>
    <input type="hidden" id="rotation-input" value="<%= currentRotation %>" />
  </div>

  <div class="buttons">
    <button
      id="rotate-ccw-btn"
      class="button is-light"
      type="button"
      title="Rotate 90° Counter-Clockwise"
      aria-label="Rotate 90 degrees counter-clockwise"
    >
      <span class="icon"><i class="fas fa-undo"></i></span>
      <span>90° CCW</span>
    </button>

    <button
      id="rotate-cw-btn"
      class="button is-light"
      type="button"
      title="Rotate 90° Clockwise"
      aria-label="Rotate 90 degrees clockwise"
    >
      <span class="icon"><i class="fas fa-redo"></i></span>
      <span>90° CW</span>
    </button>

    <button
      id="flip-h-btn"
      class="button is-light"
      type="button"
      title="Flip Horizontal (preview only)"
      aria-label="Flip horizontal"
    >
      <span class="icon"><i class="fas fa-arrows-alt-h"></i></span>
      <span>Flip H</span>
    </button>
  </div>

  <p
    id="editor-inline-note"
    class="help is-info is-hidden"
  ></p>

  <!-- Save / Cancel -->
  <div class="buttons mt-4">
    <button
      id="edit-save-btn"
      class="button is-primary"
      type="button"
    >
      <span class="icon"><i class="fas fa-save"></i></span>
      <span>Save Changes</span>
    </button>

    <button
      id="edit-cancel-btn"
      class="button is-light"
      type="button"
    >
      <span class="icon"><i class="fas fa-times"></i></span>
      <span>Cancel</span>
    </button>
  </div>

  <!-- Danger Zone -->
  <hr />
  <h4 class="title is-6 has-text-danger">Admin Actions</h4>

  <div class="buttons">
    <button
      id="regenerate-thumbnails-btn"
      class="button is-warning is-small"
      type="button"
      title="Regenerate all thumbnails for this image"
    >
      <span class="icon"><i class="fas fa-sync-alt"></i></span>
      <span>Regenerate Thumbnails</span>
    </button>

    <button
      id="delete-image-btn"
      class="button is-danger is-small"
      type="button"
      title="Permanently delete this image"
    >
      <span class="icon"><i class="fas fa-trash-alt"></i></span>
      <span>Delete Image</span>
    </button>
  </div>
</div>