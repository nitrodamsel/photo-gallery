<!-- Edit Panel - slides in from right on image detail page -->
<div id="edit-panel" class="edit-panel" aria-hidden="true" role="dialog" aria-label="Edit Image">
  <div class="edit-panel-header">
    <h3 class="edit-panel-title">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px;vertical-align:middle;">
        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
      </svg>
      Edit Image
    </h3>
    <button id="edit-panel-close" class="edit-panel-close" aria-label="Close edit panel">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>

  <div class="edit-panel-body">
    <form id="edit-form" novalidate>
      <!-- Description -->
      <div class="edit-field-group">
        <label class="edit-label" for="edit-description">Description</label>
        <textarea
          id="edit-description"
          name="description"
          class="edit-textarea"
          rows="3"
          placeholder="Add a description..."
        ><%= image.description || '' %></textarea>
      </div>

      <!-- Manual EXIF Overrides -->
      <div class="edit-section-title">EXIF Overrides</div>

      <div class="edit-field-group">
        <label class="edit-label" for="edit-caption">Caption</label>
        <input
          type="text"
          id="edit-caption"
          name="manualExif[caption]"
          class="edit-input"
          placeholder="Caption or title"
          value="<%= (image.manualExif && (typeof image.manualExif === 'string' ? JSON.parse(image.manualExif) : image.manualExif).caption) || '' %>"
        />
      </div>

      <div class="edit-field-group">
        <label class="edit-label" for="edit-location">Location Name</label>
        <input
          type="text"
          id="edit-location"
          name="manualExif[locationName]"
          class="edit-input"
          placeholder="City, Country"
          value="<%= (image.manualExif && (typeof image.manualExif === 'string' ? JSON.parse(image.manualExif) : image.manualExif).locationName) || '' %>"
        />
      </div>

      <div class="edit-field-group">
        <label class="edit-label" for="edit-date-taken">Date Taken</label>
        <input
          type="datetime-local"
          id="edit-date-taken"
          name="manualExif[dateTaken]"
          class="edit-input"
          value="<%= (image.manualExif && (typeof image.manualExif === 'string' ? JSON.parse(image.manualExif) : image.manualExif).dateTaken) ? new Date((typeof image.manualExif === 'string' ? JSON.parse(image.manualExif) : image.manualExif).dateTaken).toISOString().slice(0, 16) : '' %>"
        />
      </div>

      <div class="edit-field-group">
        <label class="edit-label" for="edit-camera">Camera / Device</label>
        <input
          type="text"
          id="edit-camera"
          name="manualExif[camera]"
          class="edit-input"
          placeholder="e.g. Canon EOS R5"
          value="<%= (image.manualExif && (typeof image.manualExif === 'string' ? JSON.parse(image.manualExif) : image.manualExif).camera) || '' %>"
        />
      </div>

      <!-- Rotation Controls -->
      <div class="edit-section-title">Orientation</div>

      <div class="edit-rotation-preview-wrap">
        <div class="edit-rotation-preview" id="rotation-preview">
          <img
            src="/uploads/thumbnails/<%= image.thumbnailFilename || image.filename %>"
            alt="Preview"
            id="rotation-preview-img"
            style="max-width:100%;max-height:120px;object-fit:contain;"
          />
        </div>
        <p class="edit-rotation-hint">Preview (CSS transform only — actual rotation saved on server)</p>
      </div>

      <input type="hidden" id="edit-rotation" name="rotation" value="<%= image.rotation || 0 %>" />
      <input type="hidden" id="edit-flip-h" name="flipH" value="<%= image.flipH ? 'true' : 'false' %>" />

      <div class="edit-rotation-buttons">
        <button type="button" class="edit-btn-rotation" id="btn-rotate-ccw" title="Rotate 90° Counter-Clockwise">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="1 4 1 10 7 10"></polyline>
            <path d="M3.51 15a9 9 0 1 0 .49-4.5"></path>
          </svg>
          90° CCW
        </button>
        <button type="button" class="edit-btn-rotation" id="btn-rotate-cw" title="Rotate 90° Clockwise">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="23 4 23 10 17 10"></polyline>
            <path d="M20.49 15a9 9 0 1 1-.49-4.5"></path>
          </svg>
          90° CW
        </button>
        <button type="button" class="edit-btn-rotation" id="btn-flip-h" title="Flip Horizontal">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="17 1 21 5 17 9"></polyline>
            <path d="M3 11V9a4 4 0 0 1 4-4h14"></path>
            <polyline points="7 23 3 19 7 15"></polyline>
            <path d="M21 13v2a4 4 0 0 1-4 4H3"></path>
          </svg>
          Flip H
        </button>
        <button type="button" class="edit-btn-rotation edit-btn-reset" id="btn-reset-rotation" title="Reset orientation">
          Reset
        </button>
      </div>

      <!-- Status message -->
      <div id="edit-status" class="edit-status" role="alert" aria-live="polite"></div>

      <!-- Actions -->
      <div class="edit-panel-actions">
        <button type="submit" class="btn btn-primary" id="edit-save-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px;vertical-align:middle;">
            <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
            <polyline points="17 21 17 13 7 13 7 21"></polyline>
            <polyline points="7 3 7 8 15 8"></polyline>
          </svg>
          Save Changes
        </button>
        <button type="button" class="btn btn-secondary" id="edit-cancel-btn">Cancel</button>
      </div>

      <!-- Danger Zone -->
      <div class="edit-danger-zone">
        <div class="edit-section-title edit-section-title--danger">Danger Zone</div>
        <button type="button" class="btn btn-danger" id="btn-delete-image">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px;vertical-align:middle;">
            <polyline points="3 6 5 6 21 6"></polyline>
            <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path>
            <path d="M10 11v6"></path>
            <path d="M14 11v6"></path>
            <path d="M9 6V4h6v2"></path>
          </svg>
          Delete Image
        </button>
        <button type="button" class="btn btn-secondary btn-sm" id="btn-regen-thumbnails" style="margin-top:8px;">
          Regenerate Thumbnails
        </button>
      </div>
    </form>
  </div>
</div>

<!-- Edit Panel Overlay -->
<div id="edit-panel-overlay" class="edit-panel-overlay"></div>