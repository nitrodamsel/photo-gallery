<%
  // Parse manualExif safely
  let manualExifData = {};
  try {
    if (image.manualExif) {
      manualExifData = typeof image.manualExif === 'string'
        ? JSON.parse(image.manualExif)
        : image.manualExif;
    }
  } catch(e) {}
  
  const currentRotation = image.rotation || 0;
%>

<div id="edit-panel" class="edit-panel" data-image-id="<%= image.id %>">
  <div class="edit-panel-inner">
    <div class="edit-panel-header">
      <h3 class="title is-5">
        <span class="icon"><i class="fas fa-edit"></i></span>
        Edit Image
      </h3>
      <button id="edit-cancel-btn" class="delete is-medium" aria-label="Close editor"></button>
    </div>

    <div class="edit-panel-body">

      <!-- Description -->
      <div class="field">
        <label class="label" for="edit-description">
          <span class="icon is-small"><i class="fas fa-align-left"></i></span>
          Description
        </label>
        <div class="control">
          <textarea
            id="edit-description"
            class="textarea"
            rows="3"
            placeholder="Enter a description for this image..."
          ><%= image.description || '' %></textarea>
        </div>
      </div>

      <!-- Manual EXIF Overrides -->
      <div class="field">
        <label class="label">
          <span class="icon is-small"><i class="fas fa-info-circle"></i></span>
          Manual EXIF Overrides
        </label>
        <p class="help mb-2">These fields override or supplement the automatic EXIF data extracted from the image.</p>

        <div class="field">
          <label class="label is-small" for="edit-caption">Caption</label>
          <div class="control">
            <input
              id="edit-caption"
              class="input is-small"
              type="text"
              placeholder="Image caption..."
              value="<%= manualExifData.caption || '' %>"
            />
          </div>
        </div>

        <div class="field">
          <label class="label is-small" for="edit-location">Location Name</label>
          <div class="control">
            <input
              id="edit-location"
              class="input is-small"
              type="text"
              placeholder="e.g. Paris, France"
              value="<%= manualExifData.locationName || '' %>"
            />
          </div>
        </div>

        <div class="field">
          <label class="label is-small" for="edit-date-taken">Date Taken</label>
          <div class="control">
            <input
              id="edit-date-taken"
              class="input is-small"
              type="text"
              placeholder="e.g. 2024-06-15 or June 15, 2024"
              value="<%= manualExifData.dateTaken || '' %>"
            />
          </div>
        </div>
      </div>

      <!-- Rotation Controls -->
      <div class="field">
        <label class="label">
          <span class="icon is-small"><i class="fas fa-sync-alt"></i></span>
          Rotation &amp; Flip
        </label>
        <p class="help mb-2">
          Non-destructive — the original file is never modified. Thumbnails are regenerated after saving.
        </p>

        <input type="hidden" id="edit-rotation" value="<%= currentRotation %>" data-saved-value="<%= currentRotation %>">

        <div class="rotation-controls">
          <div class="rotation-display-badge" id="rotation-display" title="Current rotation">
            <%= currentRotation %>°
          </div>

          <div class="buttons are-small">
            <button id="rotate-ccw-btn" class="button is-light" type="button" title="Rotate 90° Counter-Clockwise">
              <span class="icon"><i class="fas fa-undo"></i></span>
              <span>90° CCW</span>
            </button>
            <button id="rotate-cw-btn" class="button is-light" type="button" title="Rotate 90° Clockwise">
              <span class="icon"><i class="fas fa-redo"></i></span>
              <span>90° CW</span>
            </button>
            <button id="flip-h-btn" class="button is-light" type="button" title="Flip Horizontal">
              <span class="icon"><i class="fas fa-arrows-alt-h"></i></span>
              <span>Flip H</span>
            </button>
          </div>
        </div>
      </div>

      <!-- Admin Actions -->
      <div class="field mt-4">
        <label class="label">
          <span class="icon is-small"><i class="fas fa-tools"></i></span>
          Admin Actions
        </label>
        <div class="buttons are-small">
          <button id="regenerate-thumbnails-btn" class="button is-light is-warning" type="button" title="Regenerate all thumbnails for this image">
            <span class="icon"><i class="fas fa-images"></i></span>
            <span>Regenerate Thumbnails</span>
          </button>
        </div>
      </div>

    </div><!-- /.edit-panel-body -->

    <div class="edit-panel-footer">
      <div class="buttons">
        <button id="edit-save-btn" class="button is-primary" type="button">
          <span class="icon"><i class="fas fa-save"></i></span>
          <span>Save Changes</span>
        </button>
        <button id="edit-cancel-btn-footer" class="button is-light" type="button" onclick="document.getElementById('edit-cancel-btn').click()">
          <span>Cancel</span>
        </button>
      </div>

      <div class="has-text-right mt-3">
        <button id="image-delete-btn" class="button is-danger is-outlined is-small" type="button">
          <span class="icon"><i class="fas fa-trash"></i></span>
          <span>Delete Image</span>
        </button>
      </div>
    </div><!-- /.edit-panel-footer -->

  </div><!-- /.edit-panel-inner -->
</div><!-- /#edit-panel -->