<%# Edit Panel Partial - included on image-detail.ejs %>
<%# Expects: image object with id, description, rotation, manualExif %>

<%
  let manualExif = {};
  try {
    if (image.manualExif) {
      manualExif = typeof image.manualExif === 'string'
        ? JSON.parse(image.manualExif)
        : image.manualExif;
    }
  } catch(e) {}
  const imageRotation = image.rotation || 0;
%>

<div
  id="edit-panel"
  class="edit-panel"
  data-image-id="<%= image.id %>"
  data-rotation="<%= imageRotation %>"
  role="complementary"
  aria-label="Image Editor"
>
  <div class="edit-panel__header">
    <h3 class="edit-panel__title">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
      </svg>
      Edit Image
    </h3>
    <button
      id="edit-panel-close"
      class="edit-panel__close"
      aria-label="Close editor"
      type="button"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>

  <div class="edit-panel__body">

    <!-- Status message -->
    <div id="edit-status" class="edit-status" style="display:none;" role="status" aria-live="polite"></div>

    <!-- Description -->
    <div class="edit-panel__section">
      <label for="edit-description" class="edit-panel__label">Description</label>
      <textarea
        id="edit-description"
        class="edit-panel__textarea"
        rows="3"
        placeholder="Add a description..."
      ><%= image.description || '' %></textarea>
    </div>

    <!-- Manual EXIF Overrides -->
    <div class="edit-panel__section">
      <h4 class="edit-panel__section-title">EXIF Overrides</h4>
      <p class="edit-panel__section-hint">These values override or supplement the auto-detected EXIF data.</p>

      <div class="edit-panel__field">
        <label for="edit-caption" class="edit-panel__label">Caption</label>
        <input
          type="text"
          id="edit-caption"
          class="edit-panel__input"
          value="<%= manualExif.caption || '' %>"
          placeholder="Image caption"
        />
      </div>

      <div class="edit-panel__field">
        <label for="edit-location" class="edit-panel__label">Location Name</label>
        <input
          type="text"
          id="edit-location"
          class="edit-panel__input"
          value="<%= manualExif.locationName || '' %>"
          placeholder="e.g. Paris, France"
        />
      </div>

      <div class="edit-panel__field">
        <label for="edit-date-taken" class="edit-panel__label">Date Taken</label>
        <input
          type="date"
          id="edit-date-taken"
          class="edit-panel__input"
          value="<%= manualExif.dateTaken ? manualExif.dateTaken.substring(0, 10) : '' %>"
        />
      </div>
    </div>

    <!-- Rotation Controls -->
    <div class="edit-panel__section">
      <h4 class="edit-panel__section-title">Rotation &amp; Orientation</h4>
      <p class="edit-panel__section-hint">
        Non-destructive — the original file is preserved.
        Current: <strong id="rotation-display"><%= imageRotation %>°</strong>
      </p>

      <input type="hidden" id="rotation-input" value="<%= imageRotation %>" />

      <div class="edit-panel__rotation-btns">
        <button
          id="rotate-ccw-btn"
          type="button"
          class="edit-panel__btn edit-panel__btn--secondary"
          title="Rotate 90° counter-clockwise"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="1 4 1 10 7 10"></polyline>
            <path d="M3.51 15a9 9 0 1 0 .49-3.5"></path>
          </svg>
          90° CCW
        </button>

        <button
          id="rotate-cw-btn"
          type="button"
          class="edit-panel__btn edit-panel__btn--secondary"
          title="Rotate 90° clockwise"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="23 4 23 10 17 10"></polyline>
            <path d="M20.49 15a9 9 0 1 1-.49-3.5"></path>
          </svg>
          90° CW
        </button>

        <button
          id="flip-h-btn"
          type="button"
          class="edit-panel__btn edit-panel__btn--secondary"
          title="Flip horizontal (preview only)"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="17 1 21 5 17 9"></polyline>
            <path d="M3 11V9a4 4 0 0 1 4-4h14"></path>
            <polyline points="7 23 3 19 7 15"></polyline>
            <path d="M21 13v2a4 4 0 0 1-4 4H3"></path>
          </svg>
          Flip H
        </button>
      </div>
    </div>

    <!-- Admin Actions -->
    <div class="edit-panel__section edit-panel__section--admin">
      <h4 class="edit-panel__section-title">Admin Actions</h4>

      <button
        id="regen-thumbnails-btn"
        type="button"
        class="edit-panel__btn edit-panel__btn--outline"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="23 4 23 10 17 10"></polyline>
          <polyline points="1 20 1 14 7 14"></polyline>
          <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
        </svg>
        Regenerate Thumbnails
      </button>

      <button
        id="delete-image-btn"
        type="button"
        class="edit-panel__btn edit-panel__btn--danger"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="3 6 5 6 21 6"></polyline>
          <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path>
          <path d="M10 11v6"></path>
          <path d="M14 11v6"></path>
          <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"></path>
        </svg>
        Delete Image
      </button>
    </div>
  </div>

  <!-- Footer Actions -->
  <div class="edit-panel__footer">
    <button
      id="edit-cancel-btn"
      type="button"
      class="edit-panel__btn edit-panel__btn--secondary"
    >
      Cancel
    </button>
    <button
      id="edit-save-btn"
      type="button"
      class="edit-panel__btn edit-panel__btn--primary"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
        <polyline points="17 21 17 13 7 13 7 21"></polyline>
        <polyline points="7 3 7 8 15 8"></polyline>
      </svg>
      Save Changes
    </button>
  </div>
</div>