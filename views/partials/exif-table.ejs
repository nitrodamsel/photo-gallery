<%
// Helper to check if a value is worth displaying
function hasValue(v) {
  return v !== null && v !== undefined && v !== '' && v !== 'Unknown';
}

// Group definitions
var groups = [
  {
    label: 'Camera',
    fields: [
      { key: 'camera', label: 'Camera' },
      { key: 'make', label: 'Make' },
      { key: 'model', label: 'Model' },
      { key: 'lens', label: 'Lens' },
      { key: 'lensModel', label: 'Lens Model' },
      { key: 'software', label: 'Software' },
    ]
  },
  {
    label: 'Exposure',
    fields: [
      { key: 'exposureTime', label: 'Shutter Speed' },
      { key: 'fNumber', label: 'Aperture' },
      { key: 'iso', label: 'ISO' },
      { key: 'focalLength', label: 'Focal Length' },
      { key: 'focalLength35mm', label: 'Focal Length (35mm)' },
      { key: 'exposureMode', label: 'Exposure Mode' },
      { key: 'exposureProgram', label: 'Exposure Program' },
      { key: 'meteringMode', label: 'Metering Mode' },
      { key: 'flash', label: 'Flash' },
      { key: 'whiteBalance', label: 'White Balance' },
      { key: 'dateTaken', label: 'Date Taken' },
    ]
  },
  {
    label: 'Location',
    fields: [
      { key: 'latitude', label: 'Latitude' },
      { key: 'longitude', label: 'Longitude' },
      { key: 'altitude', label: 'Altitude' },
    ]
  }
];
%>

<div class="exif-table">
  <% groups.forEach(function(group) { %>
    <%
      var groupFields = group.fields.filter(function(f) {
        return hasValue(exif[f.key]);
      });
    %>
    <% if (groupFields.length > 0) { %>
      <div class="exif-group">
        <h3 class="exif-group-label"><%= group.label %></h3>
        <dl class="exif-dl">
          <% groupFields.forEach(function(field) { %>
            <div class="exif-row">
              <dt class="exif-key"><%= field.label %></dt>
              <dd class="exif-val">
                <%
                  var val = exif[field.key];
                  var displayVal = val;

                  if (field.key === 'fNumber' && typeof val === 'number') {
                    displayVal = 'f/' + val;
                  } else if (field.key === 'exposureTime' && typeof val === 'number') {
                    if (val < 1) {
                      var denom = Math.round(1 / val);
                      displayVal = '1/' + denom + 's';
                    } else {
                      displayVal = val + 's';
                    }
                  } else if (field.key === 'focalLength' && typeof val === 'number') {
                    displayVal = val + 'mm';
                  } else if (field.key === 'focalLength35mm' && typeof val === 'number') {
                    displayVal = val + 'mm';
                  } else if (field.key === 'iso') {
                    displayVal = 'ISO ' + val;
                  } else if (field.key === 'altitude' && typeof val === 'number') {
                    displayVal = val.toFixed(1) + 'm';
                  } else if ((field.key === 'latitude' || field.key === 'longitude') && typeof val === 'number') {
                    displayVal = val.toFixed(6) + '°';
                  } else if (field.key === 'dateTaken') {
                    try {
                      displayVal = new Date(val).toLocaleString();
                    } catch(e) {
                      displayVal = val;
                    }
                  }
                %>
                <%= displayVal %>
              </dd>
            </div>
          <% }); %>
        </dl>
      </div>
    <% } %>
  <% }); %>
</div>