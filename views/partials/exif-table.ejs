<%
const { formatAperture, formatShutterSpeed, formatFocalLength, formatGps } = require('../../utils/exifFormatter');

// Helper to safely get a value
function val(v) { return (v !== null && v !== undefined && v !== '') ? v : null; }

// Camera section
const cameraMake = val(image.camera_make);
const cameraModel = val(image.camera_model);
const lensModel = val(image.lens_model);
const cameraSerial = val(exifData.SerialNumber || exifData.CameraSerialNumber);
const software = val(exifData.Software);

// Exposure section
const iso = val(image.iso || exifData.ISO || exifData.ISOSpeedRatings);
const apertureRaw = val(image.aperture || exifData.FNumber || exifData.ApertureValue);
const shutterRaw = val(image.shutter_speed || exifData.ExposureTime || exifData.ShutterSpeedValue);
const focalLengthRaw = val(image.focal_length || exifData.FocalLength);
const focalLength35 = val(exifData.FocalLengthIn35mmFormat || exifData.FocalLengthIn35mmFilm);
const exposureMode = val(exifData.ExposureMode);
const exposureProgram = val(exifData.ExposureProgram);
const meteringMode = val(exifData.MeteringMode);
const flash = val(exifData.Flash);
const whiteBalance = val(exifData.WhiteBalance);

// Location section
const lat = val(image.gps_latitude);
const lng = val(image.gps_longitude);
const altitude = val(exifData.GPSAltitude);

const hasCamera = cameraMake || cameraModel || lensModel || cameraSerial || software;
const hasExposure = iso || apertureRaw || shutterRaw || focalLengthRaw || exposureMode || meteringMode || flash || whiteBalance;
const hasLocation = lat || lng || altitude;
%>

<% if (!hasCamera && !hasExposure && !hasLocation) { %>
  <p class="exif-empty">No EXIF data available for this image.</p>
<% } else { %>

<div class="exif-table">

  <% if (hasCamera) { %>
  <div class="exif-group">
    <h3 class="exif-group-title">Camera</h3>
    <dl class="exif-dl">
      <% if (cameraMake) { %>
      <div class="exif-row">
        <dt class="exif-label">Make</dt>
        <dd class="exif-value"><%= cameraMake %></dd>
      </div>
      <% } %>
      <% if (cameraModel) { %>
      <div class="exif-row">
        <dt class="exif-label">Model</dt>
        <dd class="exif-value"><%= cameraModel %></dd>
      </div>
      <% } %>
      <% if (lensModel) { %>
      <div class="exif-row">
        <dt class="exif-label">Lens</dt>
        <dd class="exif-value"><%= lensModel %></dd>
      </div>
      <% } %>
      <% if (cameraSerial) { %>
      <div class="exif-row">
        <dt class="exif-label">Serial No.</dt>
        <dd class="exif-value"><%= cameraSerial %></dd>
      </div>
      <% } %>
      <% if (software) { %>
      <div class="exif-row">
        <dt class="exif-label">Software</dt>
        <dd class="exif-value"><%= software %></dd>
      </div>
      <% } %>
    </dl>
  </div>
  <% } %>

  <% if (hasExposure) { %>
  <div class="exif-group">
    <h3 class="exif-group-title">Exposure</h3>
    <dl class="exif-dl">
      <% if (apertureRaw) { %>
      <div class="exif-row">
        <dt class="exif-label">Aperture</dt>
        <dd class="exif-value"><%= formatAperture(apertureRaw) %></dd>
      </div>
      <% } %>
      <% if (shutterRaw) { %>
      <div class="exif-row">
        <dt class="exif-label">Shutter Speed</dt>
        <dd class="exif-value"><%= formatShutterSpeed(shutterRaw) %></dd>
      </div>
      <% } %>
      <% if (iso) { %>
      <div class="exif-row">
        <dt class="exif-label">ISO</dt>
        <dd class="exif-value">ISO <%= iso %></dd>
      </div>
      <% } %>
      <% if (focalLengthRaw) { %>
      <div class="exif-row">
        <dt class="exif-label">Focal Length</dt>
        <dd class="exif-value"><%= formatFocalLength(focalLengthRaw) %><% if (focalLength35) { %> (<%= focalLength35 %>mm equiv.)<% } %></dd>
      </div>
      <% } %>
      <% if (exposureMode !== null) { %>
      <div class="exif-row">
        <dt class="exif-label">Exposure Mode</dt>
        <dd class="exif-value"><%= exposureMode %></dd>
      </div>
      <% } %>
      <% if (meteringMode) { %>
      <div class="exif-row">
        <dt class="exif-label">Metering</dt>
        <dd class="exif-value"><%= meteringMode %></dd>
      </div>
      <% } %>
      <% if (flash !== null) { %>
      <div class="exif-row">
        <dt class="exif-label">Flash</dt>
        <dd class="exif-value"><%= flash %></dd>
      </div>
      <% } %>
      <% if (whiteBalance !== null) { %>
      <div class="exif-row">
        <dt class="exif-label">White Balance</dt>
        <dd class="exif-value"><%= whiteBalance %></dd>
      </div>
      <% } %>
    </dl>
  </div>
  <% } %>

  <% if (hasLocation) { %>
  <div class="exif-group">
    <h3 class="exif-group-title">Location</h3>
    <dl class="exif-dl">
      <% if (lat && lng) { %>
      <div class="exif-row">
        <dt class="exif-label">Coordinates</dt>
        <dd class="exif-value"><%= formatGps(lat, lng) %></dd>
      </div>
      <div class="exif-row">
        <dt class="exif-label">Latitude</dt>
        <dd class="exif-value"><%= parseFloat(lat).toFixed(6) %>&deg;</dd>
      </div>
      <div class="exif-row">
        <dt class="exif-label">Longitude</dt>
        <dd class="exif-value"><%= parseFloat(lng).toFixed(6) %>&deg;</dd>
      </div>
      <% } %>
      <% if (altitude) { %>
      <div class="exif-row">
        <dt class="exif-label">Altitude</dt>
        <dd class="exif-value"><%= parseFloat(altitude).toFixed(1) %> m</dd>
      </div>
      <% } %>
    </dl>
  </div>
  <% } %>

</div>
<% } %>