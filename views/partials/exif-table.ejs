<%
  // Helper: only render if value is non-null/undefined/empty
  function hasVal(v) {
    return v !== null && v !== undefined && v !== '';
  }
%>
<div class="exif-table">

  <!-- Camera section -->
  <% if (hasVal(image.camera_make) || hasVal(image.camera_model) || hasVal(image.lens_model) || hasVal(image.software)) { %>
  <section class="exif-group" aria-labelledby="exif-camera">
    <h3 id="exif-camera" class="exif-group-title">Camera</h3>
    <dl class="exif-list">
      <% if (hasVal(image.camera_make)) { %>
        <dt>Make</dt>
        <dd><%= image.camera_make %></dd>
      <% } %>
      <% if (hasVal(image.camera_model)) { %>
        <dt>Model</dt>
        <dd><%= image.camera_model %></dd>
      <% } %>
      <% if (hasVal(image.lens_model)) { %>
        <dt>Lens</dt>
        <dd><%= image.lens_model %></dd>
      <% } %>
      <% if (hasVal(image.software)) { %>
        <dt>Software</dt>
        <dd><%= image.software %></dd>
      <% } %>
    </dl>
  </section>
  <% } %>

  <!-- Exposure section -->
  <% if (hasVal(image.exposure_time) || hasVal(image.f_number) || hasVal(image.iso_speed) || hasVal(image.focal_length) || hasVal(image.exposure_mode) || hasVal(image.white_balance) || hasVal(image.flash)) { %>
  <section class="exif-group" aria-labelledby="exif-exposure">
    <h3 id="exif-exposure" class="exif-group-title">Exposure</h3>
    <dl class="exif-list">
      <% if (hasVal(image.exposure_time)) { %>
        <dt>Shutter Speed</dt>
        <dd>
          <% 
            var et = parseFloat(image.exposure_time);
            if (et < 1) {
              var denom = Math.round(1 / et);
              %><%= '1/' + denom + 's' %><%
            } else {
              %><%= et + 's' %><%
            }
          %>
        </dd>
      <% } %>
      <% if (hasVal(image.f_number)) { %>
        <dt>Aperture</dt>
        <dd>f/<%= parseFloat(image.f_number).toFixed(1) %></dd>
      <% } %>
      <% if (hasVal(image.iso_speed)) { %>
        <dt>ISO</dt>
        <dd><%= image.iso_speed %></dd>
      <% } %>
      <% if (hasVal(image.focal_length)) { %>
        <dt>Focal Length</dt>
        <dd><%= parseFloat(image.focal_length).toFixed(0) %>mm</dd>
      <% } %>
      <% if (hasVal(image.exposure_mode)) { %>
        <dt>Exposure Mode</dt>
        <dd><%= image.exposure_mode %></dd>
      <% } %>
      <% if (hasVal(image.white_balance)) { %>
        <dt>White Balance</dt>
        <dd><%= image.white_balance %></dd>
      <% } %>
      <% if (hasVal(image.flash)) { %>
        <dt>Flash</dt>
        <dd><%= image.flash %></dd>
      <% } %>
    </dl>
  </section>
  <% } %>

  <!-- Location section -->
  <% if (hasVal(image.gps_latitude) || hasVal(image.gps_longitude) || hasVal(image.gps_altitude)) { %>
  <section class="exif-group" aria-labelledby="exif-location">
    <h3 id="exif-location" class="exif-group-title">Location</h3>
    <dl class="exif-list">
      <% if (hasVal(image.gps_latitude) && hasVal(image.gps_longitude)) { %>
        <dt>Coordinates</dt>
        <dd>
          <%= parseFloat(image.gps_latitude).toFixed(6) %>&deg;, 
          <%= parseFloat(image.gps_longitude).toFixed(6) %>&deg;
        </dd>
      <% } %>
      <% if (hasVal(image.gps_altitude)) { %>
        <dt>Altitude</dt>
        <dd><%= parseFloat(image.gps_altitude).toFixed(1) %>m</dd>
      <% } %>
    </dl>
  </section>
  <% } %>

  <!-- Dimensions section -->
  <% if (hasVal(image.image_width) || hasVal(image.image_height) || hasVal(image.color_space)) { %>
  <section class="exif-group" aria-labelledby="exif-dims">
    <h3 id="exif-dims" class="exif-group-title">Image</h3>
    <dl class="exif-list">
      <% if (hasVal(image.image_width) && hasVal(image.image_height)) { %>
        <dt>Dimensions</dt>
        <dd><%= image.image_width %> &times; <%= image.image_height %> px</dd>
      <% } %>
      <% if (hasVal(image.color_space)) { %>
        <dt>Color Space</dt>
        <dd><%= image.color_space %></dd>
      <% } %>
      <% if (hasVal(image.file_size)) { %>
        <dt>File Size</dt>
        <dd>
          <%
            var bytes = parseInt(image.file_size);
            var sizeStr;
            if (bytes >= 1024 * 1024) {
              sizeStr = (bytes / (1024 * 1024)).toFixed(2) + ' MB';
            } else if (bytes >= 1024) {
              sizeStr = (bytes / 1024).toFixed(1) + ' KB';
            } else {
              sizeStr = bytes + ' B';
            }
          %><%= sizeStr %>
        </dd>
      <% } %>
    </dl>
  </section>
  <% } %>

  <% 
    var hasAny = hasVal(image.camera_make) || hasVal(image.camera_model) || hasVal(image.lens_model) ||
      hasVal(image.exposure_time) || hasVal(image.f_number) || hasVal(image.iso_speed) || hasVal(image.focal_length) ||
      hasVal(image.gps_latitude) || hasVal(image.gps_longitude) || hasVal(image.image_width);
  %>
  <% if (!hasAny) { %>
    <p class="no-exif">No EXIF data available for this image.</p>
  <% } %>

</div>