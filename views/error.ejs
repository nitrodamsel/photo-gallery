<%- include('layouts/base', { body: `

  <section class="py-5">
    <div class="container text-center">
      <div class="row justify-content-center">
        <div class="col-md-6">
          <div class="display-1 fw-bold text-muted mb-3">${status}</div>
          <h2 class="fw-bold mb-3">
            ${status === 404 ? 'Page Not Found' : 'Something Went Wrong'}
          </h2>
          <p class="text-muted mb-4">${message}</p>

          ${stack ? \`
            <details class="text-start mb-4">
              <summary class="text-muted small mb-2">Stack Trace</summary>
              <pre class="bg-dark text-light p-3 rounded small overflow-auto">${stack}</pre>
            </details>
          \` : ''}

          <a href="/" class="btn btn-primary">
            <i class="bi bi-house me-2"></i>Back to Home
          </a>
        </div>
      </div>
    </div>
  </section>

` }) %>