<%- include('layouts/base', { title: (typeof status !== 'undefined' ? status + ' — ' : '') + 'Error', body: `

<div class="error-page error-page--generic">
  <div class="error-page__inner">
    <div class="error-page__icon" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
    </div>
    <% if (typeof status !== 'undefined') { %>
      <h1 class="error-page__code"><%= status %></h1>
    <% } %>
    <h2 class="error-page__title">Something went wrong</h2>
    <p class="error-page__message">
      <%= typeof message !== 'undefined' ? message : 'An unexpected error occurred.' %>
    </p>
    <% if (typeof stack !== 'undefined' && stack) { %>
      <details class="error-page__stack">
        <summary>Stack trace</summary>
        <pre><%= stack %></pre>
      </details>
    <% } %>
    <div class="error-page__actions">
      <a href="/gallery" class="btn btn--primary">Browse Gallery</a>
      <a href="/" class="btn btn--secondary">Go Home</a>
    </div>
  </div>
</div>

` }) %>