<%- include('layouts/base', { body: `
  <section class="error-section py-5">
    <div class="container">
      <div class="row justify-content-center text-center">
        <div class="col-lg-6">
          <div class="error-icon mb-4">${status === 404 ? '🔍' : '⚠️'}</div>
          <h1 class="display-1 fw-bold text-primary">${status}</h1>
          <h2 class="fw-semibold mb-3">${status === 404 ? 'Page Not Found' : 'Something Went Wrong'}</h2>
          <p class="text-muted lead mb-4">${message}</p>
          <div class="d-flex flex-wrap justify-content-center gap-3">
            <a href="/" class="btn btn-primary px-4">
              <i class="bi bi-house-fill me-2"></i>Go Home
            </a>
            <button onclick="history.back()" class="btn btn-outline-secondary px-4">
              <i class="bi bi-arrow-left me-2"></i>Go Back
            </button>
          </div>
          ${stack ? `
            <div class="mt-5 text-start">
              <details class="text-muted">
                <summary class="btn btn-sm btn-outline-danger mb-2">Stack Trace</summary>
                <pre class="bg-dark text-light p-3 rounded small overflow-auto">${stack}</pre>
              </details>
            </div>
          ` : ''}
        </div>
      </div>
    </div>
  </section>
`) %>