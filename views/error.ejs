<%- include('layouts/base', { title: title || 'Error', body: `
<div class="error-page">
  <div class="error-content">
    <div class="error-code"><%= status || 500 %></div>
    <h1 class="error-title"><%= status === 404 ? 'Not Found' : 'Server Error' %></h1>
    <p class="error-message"><%= message || 'Something went wrong.' %></p>

    <% if (typeof stack !== 'undefined' && stack) { %>
    <details class="error-stack">
      <summary>Stack Trace (development only)</summary>
      <pre><%= stack %></pre>
    </details>
    <% } %>

    <div class="error-actions">
      <a href="/gallery" class="btn btn-primary">&larr; Back to Gallery</a>
      <a href="/" class="btn btn-outline">Home</a>
    </div>
  </div>
</div>
` }) %>