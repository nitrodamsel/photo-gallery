<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title : 'Error' %></title>
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
    crossorigin="anonymous"
  />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <link rel="stylesheet" href="/css/main.css" />
</head>
<body class="d-flex flex-column min-vh-100">
  <%- include('partials/navbar') %>

  <main class="flex-grow-1 d-flex align-items-center justify-content-center py-5">
    <div class="container text-center">
      <div class="row justify-content-center">
        <div class="col-md-6">
          <div class="mb-4">
            <% if (status === 404) { %>
              <i class="bi bi-search display-1 text-muted"></i>
            <% } else { %>
              <i class="bi bi-exclamation-triangle display-1 text-danger"></i>
            <% } %>
          </div>
          <h1 class="display-4 fw-bold text-muted"><%= status %></h1>
          <p class="lead mb-4"><%= message %></p>
          <a href="/" class="btn btn-primary">
            <i class="bi bi-house me-2"></i>Go Home
          </a>
        </div>
      </div>
    </div>
  </main>

  <footer class="footer py-3 bg-dark text-white">
    <div class="container text-center">
      <span class="text-muted small">
        &copy; <%= new Date().getFullYear() %> Photo Gallery
      </span>
    </div>
  </footer>

  <script
    src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
    integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmW1XcME7fFeFZBe9APe1CJjMGGe"
    crossorigin="anonymous"
  ></script>
</body>
</html>