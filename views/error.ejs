<%- include('layouts/base', { title: 'Error — ' + (locals.status || 500), body: `
<div class="error-page">
  <div class="container">
    <div class="error-content">
      <div class="error-illustration">
        <svg xmlns="http://www.w3.org/2000/svg" width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="8" x2="12" y2="12"></line>
          <line x1="12" y1="16" x2="12.01" y2="16"></line>
        </svg>
      </div>
      <h1 class="error-code"><%= locals.status || 500 %></h1>
      <h2 class="error-title"><%= locals.status === 404 ? 'Not Found' : 'Internal Server Error' %></h2>
      <p class="error-message">
        <%= locals.message || 'Something went wrong. Please try again later.' %>
      </p>
      <% if (locals.stack && process.env.NODE_ENV !== 'production') { %>
        <details class="error-stack">
          <summary>Stack Trace (dev only)</summary>
          <pre><%= locals.stack %></pre>
        </details>
      <% } %>
      <div class="error-actions">
        <a href="/gallery" class="btn btn-primary">Back to Gallery</a>
        <a href="/" class="btn btn-secondary">Go Home</a>
      </div>
    </div>
  </div>
</div>
` }) %>