<%- include('layouts/base', { title: 'Error ' + status, body: `
<div style="
  min-height: calc(100vh - 64px);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rem;
">
  <div style="text-align: center; max-width: 480px;">
    <div style="font-size: 5rem; font-weight: 800; color: #e2e8f0; line-height: 1;">${status || 500}</div>
    <h1 style="font-size: 1.5rem; color: #1e293b; margin: 0.5rem 0;">${message || 'Something went wrong'}</h1>
    <p style="color: #64748b;">
      ${status === 404
        ? "The page you're looking for doesn't exist."
        : 'An unexpected error occurred. Please try again.'}
    </p>
    <a href="/" style="
      display: inline-block;
      margin-top: 1.5rem;
      background: #6366f1;
      color: #fff;
      padding: 0.625rem 1.5rem;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 600;
    ">Go Home</a>
    ${stack ? '<pre style="text-align:left;background:#f1f5f9;padding:1rem;border-radius:8px;font-size:0.75rem;overflow:auto;margin-top:2rem;">' + stack + '</pre>' : ''}
  </div>
</div>
` }) %>