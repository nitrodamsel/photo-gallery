<%- include('layouts/base', { body: `

<section class="error-section py-5 text-center">
  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-md-6">
        <div class="error-code display-1 fw-bold text-primary mb-2">
          <%= statusCode || 500 %>
        </div>
        <h1 class="h3 fw-bold mb-3"><%= title || 'Something Went Wrong' %></h1>
        <p class="text-muted mb-4"><%= message || 'An unexpected error occurred.' %></p>
        <div class="d-flex gap-3 justify-content-center">
          <a href="/" class="btn btn-primary px-4">
            <i class="bi bi-house me-2"></i>Go Home
          </a>
          <button onclick="history.back()" class="btn btn-outline-secondary px-4">
            <i class="bi bi-arrow-left me-2"></i>Go Back
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

` }) %>