<div class="error-page server-error-page">
  <div class="error-content">
    <div class="error-code" aria-hidden="true"><%= typeof status !== 'undefined' ? status : 500 %></div>
    <h1 class="error-title">
      <% if (typeof status !== 'undefined' && status === 404) { %>
        Page Not Found
      <% } else { %>
        Something Went Wrong
      <% } %>
    </h1>
    <p class="error-message">
      <% if (typeof message !== 'undefined' && message) { %>
        <%= message %>
      <% } else { %>
        An unexpected error occurred. Please try again later.
      <% } %>
    </p>
    <% if (typeof error !== 'undefined' && error && process.env.NODE_ENV !== 'production') { %>
      <details class="error-details">
        <summary>Technical Details</summary>
        <pre class="error-stack"><%= error.stack || error.message || error %></pre>
      </details>
    <% } %>
    <div class="error-actions">
      <a href="/gallery" class="btn btn-primary">&#8592; Back to Gallery</a>
      <a href="/" class="btn btn-secondary">Go Home</a>
    </div>
  </div>
</div>