<%- include('../layouts/base', { title: title, body: `
<div class="admin-dashboard">
  <div class="hero is-dark is-small mb-5">
    <div class="hero-body">
      <div class="container">
        <h1 class="title">
          <span class="icon mr-2"><i class="fas fa-tachometer-alt"></i></span>
          Admin Dashboard
        </h1>
        <p class="subtitle">System overview and management</p>
      </div>
    </div>
  </div>

  <section class="section pt-0">
    <div class="container is-fluid">

      <!-- Stat Cards -->
      <div class="columns is-multiline mb-5">
        <div class="column is-3">
          <div class="box has-text-centered stat-card">
            <p class="heading">Total Images</p>
            <p class="title is-2 has-text-primary">${stats.totalImages.toLocaleString()}</p>
            <span class="icon is-large has-text-primary">
              <i class="fas fa-images fa-2x"></i>
            </span>
          </div>
        </div>
        <div class="column is-3">
          <div class="box has-text-centered stat-card">
            <p class="heading">Storage Used</p>
            <p class="title is-2 has-text-info">${stats.totalStorageMB} MB</p>
            <span class="icon is-large has-text-info">
              <i class="fas fa-hdd fa-2x"></i>
            </span>
          </div>
        </div>
        <div class="column is-3">
          <div class="box has-text-centered stat-card">
            <p class="heading">Total Tags</p>
            <p class="title is-2 has-text-success">${stats.totalTags.toLocaleString()}</p>
            <span class="icon is-large has-text-success">
              <i class="fas fa-tags fa-2x"></i>
            </span>
          </div>
        </div>
        <div class="column is-3">
          <div class="box has-text-centered stat-card">
            <p class="heading">API Keys</p>
            <p class="title is-2 has-text-warning">${stats.totalApiKeys}</p>
            <span class="icon is-large has-text-warning">
              <i class="fas fa-key fa-2x"></i>
            </span>
          </div>
        </div>
      </div>

      <!-- Charts Row -->
      <div class="columns mb-5">
        <div class="column is-8">
          <div class="box">
            <h2 class="title is-5 mb-4">
              <span class="icon mr-1"><i class="fas fa-chart-bar"></i></span>
              Uploads Per Month
            </h2>
            <div style="position: relative; height: 280px;">
              <canvas id="uploadsChart"></canvas>
            </div>
          </div>
        </div>
        <div class="column is-4">
          <div class="box">
            <h2 class="title is-5 mb-4">
              <span class="icon mr-1"><i class="fas fa-camera"></i></span>
              Camera Makes
            </h2>
            <div style="position: relative; height: 280px;">
              <canvas id="cameraChart"></canvas>
            </div>
          </div>
        </div>
      </div>

      <!-- Tables Row -->
      <div class="columns mb-5">
        <div class="column is-6">
          <div class="box">
            <h2 class="title is-5 mb-4">
              <span class="icon mr-1"><i class="fas fa-fire"></i></span>
              Top 10 Tags
            </h2>
            <% if (stats.topTags && stats.topTags.length > 0) { %>
            <table class="table is-fullwidth is-striped is-hoverable is-size-7">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Tag</th>
                  <th class="has-text-right">Images</th>
                </tr>
              </thead>
              <tbody>
                <% stats.topTags.forEach((tag, i) => { %>
                <tr>
                  <td><span class="tag is-light">${i + 1}</span></td>
                  <td>
                    <a href="/tags/${tag.name}" class="has-text-primary">
                      <span class="tag is-info is-light">${tag.name}</span>
                    </a>
                  </td>
                  <td class="has-text-right">
                    <strong>${tag.imageCount.toLocaleString()}</strong>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
            <% } else { %>
            <p class="has-text-grey has-text-centered py-4">No tags yet</p>
            <% } %>
          </div>
        </div>

        <div class="column is-6">
          <div class="box">
            <h2 class="title is-5 mb-4">
              <span class="icon mr-1"><i class="fas fa-clock"></i></span>
              Recent Uploads
            </h2>
            <% if (recentImages && recentImages.length > 0) { %>
            <div class="recent-uploads-list">
              <% recentImages.forEach(image => { %>
              <div class="media mb-3">
                <figure class="media-left">
                  <p class="image is-48x48">
                    <img src="/thumbnails/${image.filename}?size=64" 
                         alt="${image.originalName || image.filename}"
                         style="object-fit: cover; width: 48px; height: 48px; border-radius: 4px;"
                         onerror="this.src='/images/placeholder.png'">
                  </p>
                </figure>
                <div class="media-content">
                  <p class="is-size-7">
                    <a href="/gallery/${image.id}" class="has-text-weight-semibold">
                      ${image.title || image.originalName || image.filename}
                    </a>
                  </p>
                  <p class="is-size-7 has-text-grey">
                    ${new Date(image.createdAt).toLocaleDateString()} · 
                    ${image.fileSize ? (image.fileSize / 1024).toFixed(1) + ' KB' : 'N/A'}
                  </p>
                </div>
              </div>
              <% }) %>
            </div>
            <% } else { %>
            <p class="has-text-grey has-text-centered py-4">No images uploaded yet</p>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Admin Actions -->
      <div class="box mb-5">
        <h2 class="title is-5 mb-4">
          <span class="icon mr-1"><i class="fas fa-tools"></i></span>
          Admin Actions
        </h2>
        <div class="buttons">
          <button class="button is-warning" id="flushCacheBtn">
            <span class="icon"><i class="fas fa-broom"></i></span>
            <span>Flush Cache</span>
          </button>
          <a href="/api/docs/ui" target="_blank" class="button is-info is-light">
            <span class="icon"><i class="fas fa-book"></i></span>
            <span>API Documentation</span>
          </a>
          <a href="/upload" class="button is-primary is-light">
            <span class="icon"><i class="fas fa-upload"></i></span>
            <span>Upload Images</span>
          </a>
        </div>
        <div id="cacheMessage" class="mt-3" style="display:none;"></div>
      </div>

    </div>
  </section>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
(function() {
  // Uploads Per Month Chart
  const monthlyLabels = <%- JSON.stringify(stats.uploadsPerMonth.map(d => d.month)) %>;
  const monthlyCounts = <%- JSON.stringify(stats.uploadsPerMonth.map(d => parseInt(d.count))) %>;

  if (document.getElementById('uploadsChart')) {
    new Chart(document.getElementById('uploadsChart'), {
      type: 'bar',
      data: {
        labels: monthlyLabels.length ? monthlyLabels : ['No data'],
        datasets: [{
          label: 'Uploads',
          data: monthlyCounts.length ? monthlyCounts : [0],
          backgroundColor: 'rgba(72, 199, 142, 0.7)',
          borderColor: 'rgba(72, 199, 142, 1)',
          borderWidth: 1,
          borderRadius: 4,
        }],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: ctx => ` ${ctx.raw} image${ctx.raw !== 1 ? 's' : ''}`,
            },
          },
        },
        scales: {
          y: {
            beginAtZero: true,
            ticks: { stepSize: 1 },
          },
        },
      },
    });
  }

  // Camera Makes Chart
  const cameraLabels = <%- JSON.stringify(stats.cameraMakes.map(c => c.cameraMake || 'Unknown')) %>;
  const cameraCounts = <%- JSON.stringify(stats.cameraMakes.map(c => parseInt(c.count))) %>;

  if (document.getElementById('cameraChart')) {
    const colors = [
      '#48c78e','#3e8ed0','#f14668','#ffe08a','#b86bff',
      '#ff6e40','#00d1b2','#f38020','#485fc7','#7a7a7a',
    ];
    new Chart(document.getElementById('cameraChart'), {
      type: 'doughnut',
      data: {
        labels: cameraLabels.length ? cameraLabels : ['No data'],
        datasets: [{
          data: cameraCounts.length ? cameraCounts : [1],
          backgroundColor: colors,
          hoverOffset: 8,
        }],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            position: 'bottom',
            labels: { font: { size: 11 }, padding: 8 },
          },
        },
      },
    });
  }

  // Flush Cache Button
  const flushBtn = document.getElementById('flushCacheBtn');
  const cacheMsg = document.getElementById('cacheMessage');
  if (flushBtn) {
    flushBtn.addEventListener('click', async () => {
      flushBtn.classList.add('is-loading');
      try {
        const res = await fetch('/admin/cache/flush', { method: 'POST' });
        const data = await res.json();
        cacheMsg.style.display = 'block';
        if (data.success) {
          cacheMsg.innerHTML = '<div class="notification is-success is-light py-2 px-3"><i class="fas fa-check mr-2"></i>' + data.message + '</div>';
        } else {
          cacheMsg.innerHTML = '<div class="notification is-danger is-light py-2 px-3">Failed to flush cache</div>';
        }
      } catch (e) {
        cacheMsg.style.display = 'block';
        cacheMsg.innerHTML = '<div class="notification is-danger is-light py-2 px-3">Error: ' + e.message + '</div>';
      } finally {
        flushBtn.classList.remove('is-loading');
      }
    });
  }
})();
</script>

<style>
.stat-card {
  transition: transform 0.2s, box-shadow 0.2s;
}
.stat-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(0,0,0,0.12);
}
.recent-uploads-list {
  max-height: 360px;
  overflow-y: auto;
}
</style>
` }) %>