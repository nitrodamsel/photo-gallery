<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> — Image Gallery</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@0.9.4/css/bulma.min.css" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
    body { background: #f5f5f5; }
    .stat-card { background: #fff; border-radius: 8px; padding: 1.5rem; box-shadow: 0 2px 8px rgba(0,0,0,.08); }
    .stat-value { font-size: 2.5rem; font-weight: 700; color: #3273dc; }
    .stat-label { font-size: 0.9rem; color: #666; text-transform: uppercase; letter-spacing: 0.05em; }
    .section-title { font-size: 1.2rem; font-weight: 600; margin-bottom: 1rem; color: #363636; border-bottom: 2px solid #3273dc; padding-bottom: 0.5rem; }
    .chart-container { position: relative; height: 300px; }
    .tag-freq-table td, .tag-freq-table th { padding: 0.5rem 0.75rem; }
    .badge { display: inline-block; padding: 0.2em 0.6em; border-radius: 999px; font-size: 0.8rem; font-weight: 600; }
    .badge-blue { background: #ebf0ff; color: #3273dc; }
    .recent-list .recent-item { display: flex; align-items: center; gap: 1rem; padding: 0.5rem 0; border-bottom: 1px solid #eee; }
    .recent-list .recent-item:last-child { border-bottom: none; }
    .file-size { color: #888; font-size: 0.85rem; }
    .navbar-custom { background: #2c3e50; }
    .navbar-custom .navbar-brand .navbar-item { color: #fff; font-weight: 700; font-size: 1.1rem; }
    .navbar-custom .navbar-item { color: #ecf0f1; }
    .navbar-custom .navbar-item:hover { color: #fff; background: rgba(255,255,255,.1); }
    .flash-button { cursor: pointer; }
    .camera-bar { height: 20px; background: #3273dc; border-radius: 3px; min-width: 4px; transition: width 0.3s; }
  </style>
</head>
<body>
  <nav class="navbar navbar-custom" role="navigation" aria-label="main navigation">
    <div class="navbar-brand">
      <a class="navbar-item" href="/">📷 Image Gallery</a>
    </div>
    <div class="navbar-menu">
      <div class="navbar-start">
        <a class="navbar-item" href="/">Gallery</a>
        <a class="navbar-item" href="/admin">Dashboard</a>
        <a class="navbar-item" href="/api/docs/ui" target="_blank">API Docs</a>
      </div>
    </div>
  </nav>

  <section class="section">
    <div class="container is-fluid">
      <h1 class="title">Admin Dashboard</h1>
      <p class="subtitle">System overview and usage statistics</p>

      <!-- Stat Cards -->
      <div class="columns is-multiline mb-5">
        <div class="column is-3">
          <div class="stat-card">
            <div class="stat-value"><%= stats.totalImages.toLocaleString() %></div>
            <div class="stat-label">Total Images</div>
          </div>
        </div>
        <div class="column is-3">
          <div class="stat-card">
            <div class="stat-value"><%= stats.totalStorageMB %> MB</div>
            <div class="stat-label">Storage Used</div>
          </div>
        </div>
        <div class="column is-3">
          <div class="stat-card">
            <div class="stat-value"><%= stats.tagCount.toLocaleString() %></div>
            <div class="stat-label">Total Tags</div>
          </div>
        </div>
        <div class="column is-3">
          <div class="stat-card">
            <div class="stat-value"><%= stats.apiKeyCount.toLocaleString() %></div>
            <div class="stat-label">API Keys</div>
          </div>
        </div>
      </div>

      <!-- Charts Row -->
      <div class="columns mb-5">
        <!-- Uploads Per Month Chart -->
        <div class="column is-8">
          <div class="stat-card">
            <div class="section-title">Uploads Per Month</div>
            <div class="chart-container">
              <canvas id="uploadsChart"></canvas>
            </div>
          </div>
        </div>

        <!-- Camera Make Distribution -->
        <div class="column is-4">
          <div class="stat-card" style="height: 100%">
            <div class="section-title">Camera Makes</div>
            <% if (stats.cameraMakes && stats.cameraMakes.length > 0) { %>
              <% const maxCount = Math.max(...stats.cameraMakes.map(c => parseInt(c.count) || 0)); %>
              <% stats.cameraMakes.forEach(cam => { %>
                <div style="margin-bottom: 0.75rem">
                  <div style="display: flex; justify-content: space-between; margin-bottom: 4px">
                    <span style="font-size:0.9rem"><%= cam.make || 'Unknown' %></span>
                    <span class="badge badge-blue"><%= cam.count %></span>
                  </div>
                  <div style="background:#eee; border-radius:3px; overflow:hidden">
                    <div class="camera-bar" style="width: <%= maxCount > 0 ? Math.round((parseInt(cam.count)/maxCount)*100) : 0 %>%"></div>
                  </div>
                </div>
              <% }) %>
            <% } else { %>
              <p class="has-text-grey">No EXIF camera data available.</p>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Tags & Recent Uploads Row -->
      <div class="columns">
        <!-- Top Tags Table -->
        <div class="column is-6">
          <div class="stat-card">
            <div class="section-title">Top 10 Tags</div>
            <% if (stats.topTags && stats.topTags.length > 0) { %>
              <table class="table is-fullwidth is-striped is-hoverable tag-freq-table">
                <thead>
                  <tr>
                    <th>#</th>
                    <th>Tag</th>
                    <th>Images</th>
                  </tr>
                </thead>
                <tbody>
                  <% stats.topTags.forEach((tag, i) => { %>
                    <tr>
                      <td><%= i + 1 %></td>
                      <td>
                        <a href="/tags/<%= tag.id || tag.name %>">
                          <span class="badge badge-blue"><%= tag.name %></span>
                        </a>
                      </td>
                      <td><%= tag.imageCount || tag['images.count'] || 0 %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            <% } else { %>
              <p class="has-text-grey">No tags found.</p>
            <% } %>
          </div>
        </div>

        <!-- Recent Uploads -->
        <div class="column is-6">
          <div class="stat-card">
            <div class="section-title">Recent Uploads</div>
            <% if (stats.recentUploads && stats.recentUploads.length > 0) { %>
              <div class="recent-list">
                <% stats.recentUploads.forEach(img => { %>
                  <div class="recent-item">
                    <div style="flex: 1; min-width: 0">
                      <div style="font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis">
                        <a href="/images/<%= img.id %>"><%= img.title || img.originalName || img.filename %></a>
                      </div>
                      <div class="file-size">
                        <%= img.mimeType %> &bull;
                        <%= img.fileSize ? (img.fileSize / 1024).toFixed(1) + ' KB' : 'N/A' %> &bull;
                        <%= new Date(img.createdAt).toLocaleDateString() %>
                      </div>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } else { %>
              <p class="has-text-grey">No images uploaded yet.</p>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Admin Actions -->
      <div class="columns mt-4">
        <div class="column">
          <div class="stat-card">
            <div class="section-title">Admin Actions</div>
            <div class="buttons">
              <button class="button is-warning flash-button" id="flushCacheBtn">
                🗑️ Flush Cache
              </button>
              <a class="button is-info" href="/api/docs/ui" target="_blank">
                📖 API Documentation
              </a>
              <a class="button is-link" href="/api/docs" target="_blank">
                📄 OpenAPI Spec (JSON)
              </a>
            </div>
            <div id="flushResult" style="margin-top: 0.5rem"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    // Uploads per month chart
    const uploadsData = <%- JSON.stringify(stats.uploadsPerMonth || []) %>;

    const labels = uploadsData.map(d => {
      const monthStr = d.month || '';
      try {
        const date = new Date(monthStr);
        return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
      } catch (e) {
        return monthStr;
      }
    });
    const counts = uploadsData.map(d => parseInt(d.count) || 0);

    const ctx = document.getElementById('uploadsChart').getContext('2d');
    new Chart(ctx, {
      type: 'bar',
      data: {
        labels,
        datasets: [{
          label: 'Uploads',
          data: counts,
          backgroundColor: 'rgba(50, 115, 220, 0.7)',
          borderColor: 'rgba(50, 115, 220, 1)',
          borderWidth: 1,
          borderRadius: 4,
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: (ctx) => `${ctx.raw} uploads`
            }
          }
        },
        scales: {
          y: {
            beginAtZero: true,
            ticks: { precision: 0 }
          }
        }
      }
    });

    // Flush cache button
    document.getElementById('flushCacheBtn').addEventListener('click', async () => {
      const btn = document.getElementById('flushCacheBtn');
      const result = document.getElementById('flushResult');
      btn.classList.add('is-loading');
      btn.disabled = true;
      try {
        const resp = await fetch('/admin/cache/flush', { method: 'POST' });
        const data = await resp.json();
        result.innerHTML = '<span class="tag is-success">✅ ' + (data.message || 'Cache flushed!') + '</span>';
      } catch (e) {
        result.innerHTML = '<span class="tag is-danger">❌ Failed to flush cache</span>';
      } finally {
        btn.classList.remove('is-loading');
        btn.disabled = false;
      }
    });
  </script>
</body>
</html>