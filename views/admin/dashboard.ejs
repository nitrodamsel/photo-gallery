<%- include('../layouts/base', { title: title, body: `

<div class="container-fluid py-4">
  <!-- Header -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h3 mb-0">
        <i class="bi bi-speedometer2 me-2 text-primary"></i>Admin Dashboard
      </h1>
      <p class="text-muted mb-0 mt-1">System overview and statistics</p>
    </div>
    <div class="d-flex gap-2">
      <button class="btn btn-outline-warning" onclick="flushCache()">
        <i class="bi bi-arrow-clockwise me-1"></i>Flush Cache
      </button>
      <a href="/api/docs/ui" target="_blank" class="btn btn-outline-info">
        <i class="bi bi-book me-1"></i>API Docs
      </a>
    </div>
  </div>

  <!-- Stat Cards -->
  <div class="row g-4 mb-4">
    <div class="col-sm-6 col-xl-3">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="d-flex align-items-center">
            <div class="flex-shrink-0 me-3">
              <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                <i class="bi bi-images fs-4 text-primary"></i>
              </div>
            </div>
            <div>
              <div class="h4 mb-0 fw-bold">${stats.totalImages.toLocaleString()}</div>
              <div class="text-muted small">Total Images</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-sm-6 col-xl-3">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="d-flex align-items-center">
            <div class="flex-shrink-0 me-3">
              <div class="bg-success bg-opacity-10 rounded-3 p-3">
                <i class="bi bi-hdd fs-4 text-success"></i>
              </div>
            </div>
            <div>
              <div class="h4 mb-0 fw-bold">${formatBytes(stats.totalStorage)}</div>
              <div class="text-muted small">Storage Used</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-sm-6 col-xl-3">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="d-flex align-items-center">
            <div class="flex-shrink-0 me-3">
              <div class="bg-info bg-opacity-10 rounded-3 p-3">
                <i class="bi bi-tags fs-4 text-info"></i>
              </div>
            </div>
            <div>
              <div class="h4 mb-0 fw-bold">${stats.totalTags.toLocaleString()}</div>
              <div class="text-muted small">Total Tags</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-sm-6 col-xl-3">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="d-flex align-items-center">
            <div class="flex-shrink-0 me-3">
              <div class="bg-warning bg-opacity-10 rounded-3 p-3">
                <i class="bi bi-key fs-4 text-warning"></i>
              </div>
            </div>
            <div>
              <div class="h4 mb-0 fw-bold">${stats.totalApiKeys.toLocaleString()}</div>
              <div class="text-muted small">API Keys</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Charts Row -->
  <div class="row g-4 mb-4">
    <!-- Uploads Per Month Chart -->
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h5 class="card-title mb-0">
            <i class="bi bi-bar-chart me-2 text-primary"></i>Uploads Per Month
          </h5>
          <p class="text-muted small mb-0">Last 12 months</p>
        </div>
        <div class="card-body px-4 pb-4">
          <canvas id="uploadsChart" height="250"></canvas>
        </div>
      </div>
    </div>

    <!-- Camera Makes -->
    <div class="col-lg-4">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h5 class="card-title mb-0">
            <i class="bi bi-camera me-2 text-success"></i>Camera Makes
          </h5>
        </div>
        <div class="card-body px-4 pb-4">
          ${cameraMakeStats.length > 0 ? `
          <canvas id="cameraMakeChart" height="220"></canvas>
          ` : `
          <div class="text-center text-muted py-5">
            <i class="bi bi-camera fs-1 opacity-25 d-block mb-2"></i>
            <small>No camera EXIF data available</small>
          </div>
          `}
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Row -->
  <div class="row g-4">
    <!-- Top Tags -->
    <div class="col-lg-6">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h5 class="card-title mb-0">
            <i class="bi bi-tags me-2 text-info"></i>Top Tags
          </h5>
        </div>
        <div class="card-body p-0">
          ${topTags.length > 0 ? `
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead>
                <tr>
                  <th class="px-4 border-0 text-muted small fw-semibold">#</th>
                  <th class="border-0 text-muted small fw-semibold">Tag</th>
                  <th class="border-0 text-muted small fw-semibold text-end pe-4">Images</th>
                </tr>
              </thead>
              <tbody>
                ${topTags.map((tag, idx) => `
                <tr>
                  <td class="px-4 text-muted">${idx + 1}</td>
                  <td>
                    <a href="/tags/${tag.id}" class="text-decoration-none">
                      <span class="badge bg-secondary-subtle text-secondary rounded-pill px-3 py-1">${tag.name}</span>
                    </a>
                  </td>
                  <td class="text-end pe-4">
                    <span class="fw-semibold">${parseInt(tag.imageCount).toLocaleString()}</span>
                  </td>
                </tr>
                `).join('')}
              </tbody>
            </table>
          </div>
          ` : `
          <div class="text-center text-muted py-5">
            <i class="bi bi-tags fs-1 opacity-25 d-block mb-2"></i>
            <small>No tags yet</small>
          </div>
          `}
        </div>
      </div>
    </div>

    <!-- Recent Uploads -->
    <div class="col-lg-6">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h5 class="card-title mb-0">
            <i class="bi bi-clock-history me-2 text-warning"></i>Recent Uploads
          </h5>
        </div>
        <div class="card-body p-0">
          ${recentImages.length > 0 ? `
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead>
                <tr>
                  <th class="px-4 border-0 text-muted small fw-semibold">File</th>
                  <th class="border-0 text-muted small fw-semibold">Size</th>
                  <th class="border-0 text-muted small fw-semibold text-end pe-4">Date</th>
                </tr>
              </thead>
              <tbody>
                ${recentImages.map((img) => `
                <tr>
                  <td class="px-4">
                    <a href="/images/${img.id}" class="text-decoration-none text-truncate d-inline-block" style="max-width: 200px;">
                      <i class="bi bi-image me-1 text-muted"></i>${img.originalName || 'Untitled'}
                    </a>
                  </td>
                  <td class="text-muted small">${formatBytesSmall(img.fileSize)}</td>
                  <td class="text-end pe-4 text-muted small">${new Date(img.createdAt).toLocaleDateString()}</td>
                </tr>
                `).join('')}
              </tbody>
            </table>
          </div>
          ` : `
          <div class="text-center text-muted py-5">
            <i class="bi bi-images fs-1 opacity-25 d-block mb-2"></i>
            <small>No images uploaded yet</small>
          </div>
          `}
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Alert toast -->
<div class="toast-container position-fixed bottom-0 end-0 p-3" id="toastContainer"></div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
  // Helper: format bytes
  function formatBytes(bytes) {
    if (!bytes) return '0 B';
    const units = ['B', 'KB', 'MB', 'GB', 'TB'];
    const i = Math.floor(Math.log(bytes) / Math.log(1024));
    return (bytes / Math.pow(1024, i)).toFixed(2) + ' ' + units[i];
  }

  function formatBytesSmall(bytes) {
    if (!bytes) return '—';
    const units = ['B', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(1024));
    return (bytes / Math.pow(1024, i)).toFixed(1) + ' ' + units[i];
  }

  // Show toast notification
  function showToast(message, type = 'success') {
    const id = 'toast-' + Date.now();
    const toast = document.createElement('div');
    toast.className = 'toast align-items-center text-bg-' + type + ' border-0 show';
    toast.id = id;
    toast.setAttribute('role', 'alert');
    toast.innerHTML = '<div class="d-flex"><div class="toast-body">' + message + '</div><button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div>';
    document.getElementById('toastContainer').appendChild(toast);
    setTimeout(() => toast.remove(), 4000);
  }

  // Flush cache
  async function flushCache() {
    try {
      const resp = await fetch('/admin/cache/flush', { method: 'POST' });
      const data = await resp.json();
      if (resp.ok) {
        showToast(data.message || 'Cache flushed!', 'success');
      } else {
        showToast('Failed to flush cache', 'danger');
      }
    } catch (e) {
      showToast('Error: ' + e.message, 'danger');
    }
  }

  // Uploads per month chart
  const uploadsData = <%- JSON.stringify(uploadsPerMonth) %>;

  if (uploadsData.length > 0) {
    const ctx = document.getElementById('uploadsChart').getContext('2d');
    new Chart(ctx, {
      type: 'bar',
      data: {
        labels: uploadsData.map(d => d.month),
        datasets: [{
          label: 'Uploads',
          data: uploadsData.map(d => d.count),
          backgroundColor: 'rgba(13, 110, 253, 0.7)',
          borderColor: 'rgba(13, 110, 253, 1)',
          borderWidth: 1,
          borderRadius: 4,
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: ctx => ctx.parsed.y + ' image' + (ctx.parsed.y !== 1 ? 's' : '')
            }
          }
        },
        scales: {
          y: {
            beginAtZero: true,
            ticks: { precision: 0 },
            grid: { color: 'rgba(0,0,0,0.05)' }
          },
          x: {
            grid: { display: false }
          }
        }
      }
    });
  } else {
    document.getElementById('uploadsChart').parentElement.innerHTML = '<div class="text-center text-muted py-5"><i class="bi bi-bar-chart fs-1 opacity-25 d-block mb-2"></i><small>No upload data available</small></div>';
  }

  // Camera make chart
  const cameraMakes = <%- JSON.stringify(cameraMakeStats) %>;
  if (cameraMakes.length > 0 && document.getElementById('cameraMakeChart')) {
    const ctx2 = document.getElementById('cameraMakeChart').getContext('2d');
    const colors = ['#0d6efd','#198754','#0dcaf0','#ffc107','#dc3545','#6f42c1','#fd7e14','#20c997','#6c757d','#d63384'];
    new Chart(ctx2, {
      type: 'doughnut',
      data: {
        labels: cameraMakes.map(c => c.cameraMake || 'Unknown'),
        datasets: [{
          data: cameraMakes.map(c => parseInt(c.count)),
          backgroundColor: colors.slice(0, cameraMakes.length),
          borderWidth: 2,
          borderColor: '#fff'
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            position: 'bottom',
            labels: { font: { size: 11 }, boxWidth: 12 }
          }
        }
      }
    });
  }
</script>
` }) %>