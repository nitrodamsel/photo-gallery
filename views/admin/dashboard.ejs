<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> — Gallery</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@0.9.4/css/bulma.min.css" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
    .stat-card {
      text-align: center;
      padding: 1.5rem;
    }
    .stat-number {
      font-size: 2.5rem;
      font-weight: bold;
      color: #3273dc;
    }
    .stat-label {
      font-size: 0.9rem;
      color: #7a7a7a;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .section-title {
      font-size: 1.2rem;
      font-weight: 600;
      margin-bottom: 1rem;
      padding-bottom: 0.5rem;
      border-bottom: 2px solid #ededed;
    }
    .tag-bar {
      background: #3273dc;
      height: 12px;
      border-radius: 6px;
      display: inline-block;
      min-width: 4px;
    }
    .admin-nav {
      background: #363636;
      padding: 0.75rem 1.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .admin-nav .brand {
      color: white;
      font-weight: bold;
      font-size: 1.1rem;
    }
    .admin-nav a {
      color: #ccc;
      margin-left: 1rem;
      text-decoration: none;
    }
    .admin-nav a:hover { color: white; }
    .file-size-cell { white-space: nowrap; }
  </style>
</head>
<body>
  <div class="admin-nav">
    <span class="brand">🖼 Gallery Admin</span>
    <div>
      <a href="/">← Back to Gallery</a>
      <a href="/api/docs/ui" target="_blank">API Docs</a>
    </div>
  </div>

  <section class="section">
    <div class="container is-fluid">
      <h1 class="title">Dashboard</h1>
      <p class="subtitle">System overview and usage statistics</p>

      <!-- Stat Cards -->
      <div class="columns is-multiline">
        <div class="column is-3">
          <div class="box stat-card">
            <div class="stat-number"><%= stats.totalImages.toLocaleString() %></div>
            <div class="stat-label">Total Images</div>
          </div>
        </div>
        <div class="column is-3">
          <div class="box stat-card">
            <div class="stat-number"><%= formatBytes(stats.totalStorageBytes) %></div>
            <div class="stat-label">Storage Used</div>
          </div>
        </div>
        <div class="column is-3">
          <div class="box stat-card">
            <div class="stat-number"><%= stats.totalTags.toLocaleString() %></div>
            <div class="stat-label">Total Tags</div>
          </div>
        </div>
        <div class="column is-3">
          <div class="box stat-card">
            <div class="stat-number"><%= stats.totalApiKeys.toLocaleString() %></div>
            <div class="stat-label">API Keys</div>
          </div>
        </div>
      </div>

      <!-- Charts Row -->
      <div class="columns">
        <!-- Uploads per Month Chart -->
        <div class="column is-8">
          <div class="box">
            <p class="section-title">Uploads per Month</p>
            <canvas id="uploadsChart" height="120"></canvas>
          </div>
        </div>

        <!-- Camera Makes -->
        <div class="column is-4">
          <div class="box">
            <p class="section-title">Camera Makes</p>
            <% if (stats.cameraMakes.length === 0) { %>
              <p class="has-text-grey">No EXIF camera data available.</p>
            <% } else { %>
              <% stats.cameraMakes.forEach(function(cm) { %>
                <div class="mb-2">
                  <div style="display:flex;justify-content:space-between;margin-bottom:2px;">
                    <span class="is-size-7"><%= cm.cameraMake || 'Unknown' %></span>
                    <span class="is-size-7 has-text-grey"><%= cm.count %></span>
                  </div>
                  <div style="background:#ededed;border-radius:6px;overflow:hidden;">
                    <div class="tag-bar" style="width:<%= Math.round((cm.count / stats.totalImages) * 100) %>%;"></div>
                  </div>
                </div>
              <% }); %>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Bottom Row -->
      <div class="columns">
        <!-- Top Tags -->
        <div class="column is-6">
          <div class="box">
            <p class="section-title">Top 10 Tags</p>
            <% if (stats.topTags.length === 0) { %>
              <p class="has-text-grey">No tags yet.</p>
            <% } else { %>
              <table class="table is-fullwidth is-striped is-hoverable is-size-7">
                <thead>
                  <tr>
                    <th>#</th>
                    <th>Tag</th>
                    <th>Images</th>
                  </tr>
                </thead>
                <tbody>
                  <% stats.topTags.forEach(function(tag, i) { %>
                    <tr>
                      <td><%= i + 1 %></td>
                      <td>
                        <a href="/tags/<%= tag.slug %>">
                          <span class="tag is-info is-light"><%= tag.name %></span>
                        </a>
                      </td>
                      <td><%= tag.get ? tag.get('imageCount') : tag.imageCount %></td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            <% } %>
          </div>
        </div>

        <!-- Recent Uploads -->
        <div class="column is-6">
          <div class="box">
            <p class="section-title">Recent Uploads</p>
            <% if (stats.recentUploads.length === 0) { %>
              <p class="has-text-grey">No uploads yet.</p>
            <% } else { %>
              <table class="table is-fullwidth is-striped is-hoverable is-size-7">
                <thead>
                  <tr>
                    <th>File</th>
                    <th>Size</th>
                    <th>Date</th>
                  </tr>
                </thead>
                <tbody>
                  <% stats.recentUploads.forEach(function(img) { %>
                    <tr>
                      <td>
                        <a href="/images/<%= img.id %>">
                          <%= img.originalName ? img.originalName.substring(0, 30) : img.id %>
                        </a>
                      </td>
                      <td class="file-size-cell"><%= formatBytes(img.fileSize || 0) %></td>
                      <td><%= new Date(img.createdAt).toLocaleDateString() %></td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Admin Actions -->
      <div class="box">
        <p class="section-title">Admin Actions</p>
        <div class="buttons">
          <button class="button is-warning" id="flushCacheBtn">
            🗑 Flush Cache
          </button>
          <a href="/api/docs/ui" target="_blank" class="button is-info is-light">
            📖 API Documentation
          </a>
          <a href="/api/docs" target="_blank" class="button is-light">
            📄 OpenAPI Spec (YAML)
          </a>
        </div>
        <div id="actionMessage"></div>
      </div>

    </div>
  </section>

  <script>
    // Uploads per Month Chart
    const uploadsData = <%- JSON.stringify(stats.uploadsPerMonth) %>;

    const labels = uploadsData.map(d => d.month);
    const counts = uploadsData.map(d => parseInt(d.count));

    const ctx = document.getElementById('uploadsChart').getContext('2d');
    new Chart(ctx, {
      type: 'bar',
      data: {
        labels: labels.length > 0 ? labels : ['No data'],
        datasets: [{
          label: 'Uploads',
          data: counts.length > 0 ? counts : [0],
          backgroundColor: 'rgba(50, 115, 220, 0.7)',
          borderColor: 'rgba(50, 115, 220, 1)',
          borderWidth: 1,
          borderRadius: 4,
        }]
      },
      options: {
        responsive: true,
        plugins: {
          legend: { display: false },
        },
        scales: {
          y: {
            beginAtZero: true,
            ticks: { stepSize: 1, precision: 0 }
          }
        }
      }
    });

    // Flush cache action
    document.getElementById('flushCacheBtn').addEventListener('click', async () => {
      const btn = document.getElementById('flushCacheBtn');
      const msg = document.getElementById('actionMessage');
      btn.classList.add('is-loading');
      try {
        const res = await fetch('/admin/cache/flush', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
        });
        const data = await res.json();
        msg.innerHTML = '<p class="has-text-success mt-2">✓ ' + (data.message || 'Cache flushed') + '</p>';
      } catch (e) {
        msg.innerHTML = '<p class="has-text-danger mt-2">✗ Failed to flush cache</p>';
      } finally {
        btn.classList.remove('is-loading');
        setTimeout(() => { msg.innerHTML = ''; }, 4000);
      }
    });
  </script>
</body>
</html>