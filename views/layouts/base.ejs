<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Image Gallery - Browse, search, and manage your photos">
  <title><%= typeof title !== 'undefined' ? title + ' | Image Gallery' : 'Image Gallery' %></title>

  <!-- Bootstrap 5 -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>

  <!-- Navbar -->
  <%- include('../partials/navbar', { activePage: typeof activePage !== 'undefined' ? activePage : '' }) %>

  <!-- Main Content -->
  <main class="container-xl py-4">
    <%- body %>
  </main>

  <!-- Footer -->
  <footer class="bg-white border-top mt-5 py-4">
    <div class="container-xl">
      <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
        <div class="text-muted small">
          <i class="bi bi-images me-1"></i>
          Image Gallery &mdash; Built with Node.js &amp; Express
        </div>
        <div class="d-flex gap-3">
          <a href="/gallery" class="text-muted small text-decoration-none">Gallery</a>
          <a href="/search" class="text-muted small text-decoration-none">Search</a>
          <a href="/upload" class="text-muted small text-decoration-none">Upload</a>
          <a href="/tags" class="text-muted small text-decoration-none">Tags</a>
        </div>
      </div>
    </div>
  </footer>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

  <!-- Main JS -->
  <script src="/js/main.js"></script>
</body>
</html>