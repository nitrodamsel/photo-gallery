<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' | Photo Gallery' : 'Photo Gallery' %></title>
  
  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <!-- Custom CSS -->
  <link href="/css/main.css" rel="stylesheet">
  
  <%- typeof styles !== 'undefined' ? styles : '' %>
</head>
<body>
  <!-- Navigation -->
  <%- include('../partials/navbar') %>

  <!-- Main Content -->
  <main class="pb-5">
    <%- body %>
  </main>

  <!-- Footer -->
  <footer class="bg-light border-top py-3 mt-auto">
    <div class="container text-center text-muted small">
      <p class="mb-0">&copy; <%= new Date().getFullYear() %> Photo Gallery. Built with Node.js & Express.</p>
    </div>
  </footer>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  
  <%- typeof scripts !== 'undefined' ? scripts : '' %>
</body>
</html>