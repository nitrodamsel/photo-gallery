<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Photo Gallery — Browse and manage your images" />
  <title><%= title ? title + ' | PhotoGallery' : 'PhotoGallery' %></title>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap"
    rel="stylesheet"
  />

  <!-- App CSS -->
  <link rel="stylesheet" href="/css/main.css" />
</head>
<body>

  <%- include('../partials/navbar') %>

  <main>
    <%- body %>
  </main>

  <footer style="padding: 2rem 1.5rem; text-align: center; color: var(--color-text-muted); font-size: 0.8rem; border-top: 1px solid var(--color-border); margin-top: 3rem;">
    &copy; <%= new Date().getFullYear() %> PhotoGallery
  </footer>

  <!-- App JS -->
  <script src="/js/main.js"></script>
</body>
</html>