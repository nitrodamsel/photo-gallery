<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title + ' — Photo Gallery' : 'Photo Gallery' %></title>
  <meta name="description" content="<%= typeof description !== 'undefined' ? description : 'A beautiful photo gallery application' %>" />

  <!-- Styles -->
  <link rel="stylesheet" href="/css/main.css" />

  <!-- Preload critical resources -->
  <link rel="preconnect" href="/" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Ctext y='24' font-size='24'%3E🖼%3C/text%3E%3C/svg%3E" />

  <%- typeof head !== 'undefined' ? head : '' %>
</head>
<body>
  <%- include('../partials/navbar') %>

  <main class="main-container">
    <%- body %>
  </main>

  <!-- Lazy loading script (loaded early so it's ready for images) -->
  <script src="/js/lazyLoad.js"></script>

  <!-- Main JS -->
  <script src="/js/main.js"></script>

  <%- typeof scripts !== 'undefined' ? scripts : '' %>
</body>
</html>