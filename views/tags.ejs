<%- include('layouts/base', { title: title, body: `
<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-tags-fill me-2"></i>Tag Management</h1>
    <a href="/gallery" class="btn btn-outline-secondary">
      <i class="bi bi-arrow-left me-1"></i>Back to Gallery
    </a>
  </div>

  <!-- Create New Tag -->
  <div class="card mb-4 shadow-sm">
    <div class="card-header bg-primary text-white">
      <h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Create New Tag</h5>
    </div>
    <div class="card-body">
      <form id="createTagForm" class="row g-3">
        <div class="col-md-5">
          <label for="newTagName" class="form-label">Tag Name <span class="text-danger">*</span></label>
          <input type="text" class="form-control" id="newTagName" name="name"
            placeholder="e.g. landscape, black-and-white" minlength="2" maxlength="30" required>
          <div class="form-text">2–30 characters, letters, numbers, spaces, and hyphens.</div>
        </div>
        <div class="col-md-3">
          <label for="newTagColor" class="form-label">Color</label>
          <input type="color" class="form-control form-control-color" id="newTagColor" name="color" value="#6c757d">
        </div>
        <div class="col-md-4 d-flex align-items-end">
          <button type="submit" class="btn btn-primary w-100">
            <i class="bi bi-plus-lg me-1"></i>Create Tag
          </button>
        </div>
        <div class="col-12" id="createTagMessage" style="display:none;"></div>
      </form>
    </div>
  </div>

  <!-- Tags Table -->
  <div class="card shadow-sm">
    <div class="card-header">
      <h5 class="mb-0"><i class="bi bi-table me-2"></i>All Tags (<span id="tagCount">${tags.length}</span>)</h5>
    </div>
    <div class="card-body p-0">
      ${tags.length === 0 ? `
        <div class="text-center text-muted py-5">
          <i class="bi bi-tags fs-1"></i>
          <p class="mt-3">No tags yet. Create your first tag above!</p>
        </div>
      ` : `
        <div class="table-responsive">
          <table class="table table-hover mb-0" id="tagsTable">
            <thead class="table-light">
              <tr>
                <th>Color</th>
                <th>Name</th>
                <th>Slug</th>
                <th class="text-center">Images</th>
                <th>Created</th>
                <th class="text-center">Actions</th>
              </tr>
            </thead>
            <tbody id="tagsTableBody">
              ${tags.map(tag => `
                <tr id="tag-row-${tag.id}" data-tag-id="${tag.id}">
                  <td>
                    <span class="d-inline-block rounded" style="width:24px;height:24px;background:${tag.color || '#6c757d'};border:1px solid #dee2e6;"></span>
                  </td>
                  <td>
                    <span class="tag-name-display" id="tag-name-${tag.id}">${tag.name}</span>
                    <input type="text" class="form-control form-control-sm tag-name-input d-none"
                      id="tag-input-${tag.id}" value="${tag.name}" minlength="2" maxlength="30"
                      style="display:none!important;">
                  </td>
                  <td>
                    <code class="tag-slug-display" id="tag-slug-${tag.id}">${tag.slug}</code>
                  </td>
                  <td class="text-center">
                    <a href="/gallery?tag=${encodeURIComponent(tag.slug)}" class="badge bg-secondary text-decoration-none">
                      ${tag.get ? tag.get('imageCount') || 0 : (tag.dataValues ? tag.dataValues.imageCount || 0 : 0)}
                    </a>
                  </td>
                  <td>
                    <small class="text-muted">${new Date(tag.createdAt).toLocaleDateString()}</small>
                  </td>
                  <td class="text-center">
                    <div class="btn-group btn-group-sm" id="tag-actions-${tag.id}">
                      <button class="btn btn-outline-primary btn-rename" data-tag-id="${tag.id}" title="Rename">
                        <i class="bi bi-pencil"></i>
                      </button>
                      <button class="btn btn-outline-danger btn-delete" data-tag-id="${tag.id}" data-tag-name="${tag.name}" title="Delete">
                        <i class="bi bi-trash"></i>
                      </button>
                    </div>
                    <div class="btn-group btn-group-sm d-none" id="tag-edit-actions-${tag.id}">
                      <button class="btn btn-success btn-save" data-tag-id="${tag.id}" title="Save">
                        <i class="bi bi-check-lg"></i> Save
                      </button>
                      <button class="btn btn-secondary btn-cancel" data-tag-id="${tag.id}" title="Cancel">
                        <i class="bi bi-x-lg"></i>
                      </button>
                    </div>
                  </td>
                </tr>
              `).join('')}
            </tbody>
          </table>
        </div>
      `}
    </div>
  </div>
</div>
` }) %>