<%- include('layouts/base', { title: title, body: `
<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-tags-fill me-2"></i>Tag Management</h1>
    <span class="badge bg-secondary fs-6">${tags.length} tags</span>
  </div>

  <!-- Create New Tag -->
  <div class="card mb-4 shadow-sm">
    <div class="card-header bg-primary text-white">
      <h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Create New Tag</h5>
    </div>
    <div class="card-body">
      <form id="createTagForm" class="row g-3 align-items-end">
        <div class="col-md-5">
          <label for="newTagName" class="form-label fw-semibold">Tag Name</label>
          <input
            type="text"
            class="form-control"
            id="newTagName"
            placeholder="e.g. landscape, street-photography"
            minlength="2"
            maxlength="30"
            pattern="[a-zA-Z0-9\\- ]+"
            required
          />
          <div class="form-text">2–30 chars, letters, numbers, hyphens, spaces.</div>
        </div>
        <div class="col-md-3">
          <label for="newTagColor" class="form-label fw-semibold">Color</label>
          <input type="color" class="form-control form-control-color w-100" id="newTagColor" value="#6c757d" />
        </div>
        <div class="col-md-4">
          <button type="submit" class="btn btn-primary w-100">
            <i class="bi bi-plus-lg me-1"></i>Create Tag
          </button>
        </div>
        <div id="createTagError" class="col-12 text-danger d-none"></div>
        <div id="createTagSuccess" class="col-12 text-success d-none"></div>
      </form>
    </div>
  </div>

  <!-- Tags Table -->
  <div class="card shadow-sm">
    <div class="card-header">
      <div class="d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-list-ul me-2"></i>All Tags</h5>
        <input type="text" class="form-control w-auto" id="tagSearch" placeholder="Search tags...">
      </div>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0" id="tagsTable">
          <thead class="table-light">
            <tr>
              <th>Color</th>
              <th>Name</th>
              <th>Slug</th>
              <th class="text-center">Images</th>
              <th>Created</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody id="tagsTableBody">
            ${tags.map(tag => {
              const count = tag.getDataValue ? tag.getDataValue('imageCount') : (tag.imageCount || 0);
              const createdDate = tag.createdAt ? new Date(tag.createdAt).toLocaleDateString() : 'N/A';
              return \`
              <tr id="tag-row-\${tag.id}" data-tag-id="\${tag.id}">
                <td>
                  <span class="tag-color-swatch" style="display:inline-block;width:24px;height:24px;border-radius:4px;background:\${tag.color || '#6c757d'};border:1px solid #ccc;"></span>
                </td>
                <td>
                  <span class="tag-name-display fw-semibold">\${tag.name}</span>
                  <input
                    type="text"
                    class="tag-name-edit form-control form-control-sm d-none"
                    value="\${tag.name}"
                    maxlength="30"
                    minlength="2"
                  />
                </td>
                <td><code class="tag-slug-display">\${tag.slug || ''}</code></td>
                <td class="text-center">
                  <a href="/gallery?tag=\${encodeURIComponent(tag.name)}" class="badge bg-info text-dark text-decoration-none">
                    \${count}
                  </a>
                </td>
                <td class="text-muted small">\${createdDate}</td>
                <td class="text-end">
                  <div class="btn-group btn-group-sm">
                    <button class="btn btn-outline-secondary rename-btn" data-id="\${tag.id}" title="Rename">
                      <i class="bi bi-pencil"></i> Rename
                    </button>
                    <button class="btn btn-outline-success save-btn d-none" data-id="\${tag.id}" title="Save">
                      <i class="bi bi-check-lg"></i> Save
                    </button>
                    <button class="btn btn-outline-danger cancel-btn d-none" data-id="\${tag.id}" title="Cancel">
                      <i class="bi bi-x-lg"></i>
                    </button>
                    <button class="btn btn-outline-danger delete-btn" data-id="\${tag.id}" data-name="\${tag.name}" title="Delete">
                      <i class="bi bi-trash"></i> Delete
                    </button>
                  </div>
                  <div class="tag-error text-danger small mt-1"></div>
                </td>
              </tr>\`;
            }).join('')}
          </tbody>
        </table>
        ${tags.length === 0 ? '<div class="p-4 text-center text-muted">No tags yet. Create one above!</div>' : ''}
      </div>
    </div>
  </div>
</div>

<script src="/js/tagging.js"></script>
<script>
  // Initialize tag management page
  document.addEventListener('DOMContentLoaded', function() {
    initTagManagement();
  });
</script>
` }) %>