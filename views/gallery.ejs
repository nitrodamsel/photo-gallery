<div class="container-fluid mt-4">
  <div class="row">
    <!-- Sidebar -->
    <div class="col-lg-2 col-md-3 mb-3">
      <!-- Tag Cloud -->
      <div class="card mb-3">
        <div class="card-header py-2">
          <h6 class="mb-0"><i class="bi bi-tags me-1"></i>Browse by Tag</h6>
        </div>
        <div class="card-body py-2">
          <%- include('partials/tag-cloud', { tags: typeof allTags !== 'undefined' ? allTags : [] }) %>
          <% if (typeof currentTag !== 'undefined' && currentTag) { %>
            <div class="mt-2">
              <a href="/gallery" class="btn btn-sm btn-outline-secondary w-100">
                <i class="bi bi-x-circle me-1"></i>Clear Filter
              </a>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Manage Tags Link -->
      <div class="d-grid">
        <a href="/tags" class="btn btn-sm btn-outline-primary">
          <i class="bi bi-gear me-1"></i>Manage Tags
        </a>
      </div>
    </div>

    <!-- Main Content -->
    <div class="col-lg-10 col-md-9">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
          <h1 class="h3 mb-0">
            <% if (typeof currentTag !== 'undefined' && currentTag) { %>
              <i class="bi bi-tag-fill me-2"></i>Tag: 
              <span class="badge" style="background-color: <%= currentTag.color || '#6c757d' %>;">
                <%= currentTag.name %>
              </span>
            <% } else { %>
              <i class="bi bi-images me-2"></i>Gallery
            <% } %>
          </h1>
          <% if (typeof totalImages !== 'undefined') { %>
            <small class="text-muted"><%= totalImages %> image<%= totalImages !== 1 ? 's' : '' %></small>
          <% } %>
        </div>
        <div class="d-flex gap-2">
          <a href="/upload" class="btn btn-sm btn-success">
            <i class="bi bi-plus-lg me-1"></i>Upload
          </a>
        </div>
      </div>

      <% if (typeof images !== 'undefined' && images && images.length > 0) { %>
        <div class="row g-3">
          <% images.forEach(function(image) { %>
            <div class="col-6 col-sm-4 col-md-3 col-xl-2">
              <%- include('partials/image-card', { image: image }) %>
            </div>
          <% }); %>
        </div>

        <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
          <div class="mt-4">
            <%- include('partials/pagination', {
              currentPage: currentPage || 1,
              totalPages: totalPages,
              baseUrl: (typeof currentTag !== 'undefined' && currentTag) ? '/gallery?tag=' + currentTag.slug : '/gallery'
            }) %>
          </div>
        <% } %>
      <% } else { %>
        <div class="text-center py-5">
          <i class="bi bi-images display-1 text-muted"></i>
          <h3 class="mt-3 text-muted">No images found</h3>
          <% if (typeof currentTag !== 'undefined' && currentTag) { %>
            <p class="text-muted">No images are tagged with "<%= currentTag.name %>".</p>
            <a href="/gallery" class="btn btn-outline-secondary me-2">View All Images</a>
          <% } else { %>
            <p class="text-muted">Start by uploading your first image!</p>
          <% } %>
          <a href="/upload" class="btn btn-primary">
            <i class="bi bi-cloud-upload me-1"></i>Upload Image
          </a>
        </div>
      <% } %>
    </div>
  </div>
</div>