<%- include('layouts/base', { title: title, activePage: 'gallery', body: `
<div class="container-fluid py-4">
  <div class="row g-4">

    <!-- Sidebar -->
    <div class="col-lg-3 col-xl-2">
      <div class="sticky-top" style="top: 80px;">

        <!-- Search -->
        <div class="card shadow-sm mb-3">
          <div class="card-header bg-primary text-white py-2">
            <h6 class="mb-0"><i class="bi bi-search me-2"></i>Search</h6>
          </div>
          <div class="card-body p-2">
            <form action="/gallery" method="GET">
              ${typeof currentTag !== 'undefined' && currentTag
                ? `<input type="hidden" name="tag" value="${escapeHtml(currentTag)}" />`
                : ''
              }
              <div class="input-group input-group-sm">
                <input
                  type="text"
                  name="q"
                  class="form-control"
                  placeholder="Search images..."
                  value="${typeof searchQuery !== 'undefined' ? escapeHtml(searchQuery) : ''}"
                />
                <button class="btn btn-primary" type="submit">
                  <i class="bi bi-search"></i>
                </button>
              </div>
            </form>
          </div>
        </div>

        <!-- Tag Cloud -->
        <div class="card shadow-sm mb-3">
          <div class="card-header bg-secondary text-white py-2">
            <h6 class="mb-0"><i class="bi bi-tags me-2"></i>Browse by Tag</h6>
          </div>
          <div class="card-body">
            ${typeof currentTag !== 'undefined' && currentTag
              ? `<div class="mb-2">
                   <a href="/gallery" class="btn btn-sm btn-outline-secondary w-100">
                     <i class="bi bi-x-circle me-1"></i>Clear filter
                   </a>
                 </div>`
              : ''
            }
            <%- include('partials/tag-cloud', { tags: typeof tagCloud !== 'undefined' ? tagCloud : [] }) %>
          </div>
        </div>

        <!-- Stats -->
        ${typeof totalImages !== 'undefined'
          ? `<div class="card shadow-sm">
               <div class="card-body p-3 text-center">
                 <div class="text-muted small">Showing</div>
                 <div class="fs-4 fw-bold text-primary">${totalImages}</div>
                 <div class="text-muted small">image${totalImages !== 1 ? 's' : ''}</div>
                 ${typeof currentTag !== 'undefined' && currentTag
                   ? `<div class="badge bg-secondary mt-1">#${escapeHtml(currentTag)}</div>`
                   : ''
                 }
               </div>
             </div>`
          : ''
        }

      </div>
    </div>

    <!-- Main Gallery -->
    <div class="col-lg-9 col-xl-10">

      <!-- Header -->
      <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <h1 class="h3 mb-0">
          ${typeof currentTag !== 'undefined' && currentTag
            ? `<i class="bi bi-tag-fill text-primary me-2"></i>Tag: <em>${escapeHtml(currentTag)}</em>`
            : (typeof searchQuery !== 'undefined' && searchQuery
                ? `<i class="bi bi-search text-primary me-2"></i>Results for: <em>${escapeHtml(searchQuery)}</em>`
                : '<i class="bi bi-images text-primary me-2"></i>Gallery'
              )
          }
        </h1>
        <div class="d-flex gap-2 align-items-center">
          <!-- Sort -->
          <form action="/gallery" method="GET" class="d-flex gap-1">
            ${typeof searchQuery !== 'undefined' && searchQuery
              ? `<input type="hidden" name="q" value="${escapeHtml(searchQuery)}" />`
              : ''
            }
            ${typeof currentTag !== 'undefined' && currentTag
              ? `<input type="hidden" name="tag" value="${escapeHtml(currentTag)}" />`
              : ''
            }
            <select name="sort" class="form-select form-select-sm" onchange="this.form.submit()" aria-label="Sort images">
              <option value="newest" ${typeof currentSort !== 'undefined' && currentSort === 'newest' ? 'selected' : ''}>Newest</option>
              <option value="oldest" ${typeof currentSort !== 'undefined' && currentSort === 'oldest' ? 'selected' : ''}>Oldest</option>
              <option value="name" ${typeof currentSort !== 'undefined' && currentSort === 'name' ? 'selected' : ''}>Name</option>
            </select>
          </form>
          <a href="/upload" class="btn btn-sm btn-primary">
            <i class="bi bi-upload me-1"></i>Upload
          </a>
        </div>
      </div>

      <!-- Image Grid -->
      ${typeof images !== 'undefined' && images && images.length > 0
        ? `<div class="row g-3 image-grid">
             ${images.map(image => `
               <div class="col-6 col-md-4 col-xl-3">
                 <%- include('partials/image-card', { image: ${JSON.stringify(image)} }) %>
               </div>
             `).join('')}
           </div>`
        : `<div class="text-center py-5">
             <i class="bi bi-images fs-1 text-muted d-block mb-3"></i>
             <h4 class="text-muted">No images found</h4>
             ${typeof currentTag !== 'undefined' && currentTag
               ? `<p class="text-muted">No images tagged with "<strong>${escapeHtml(currentTag)}</strong>".</p>
                  <a href="/gallery" class="btn btn-outline-secondary me-2">Clear Filter</a>`
               : `<p class="text-muted">Upload some images to get started.</p>`
             }
             <a href="/upload" class="btn btn-primary">
               <i class="bi bi-upload me-1"></i>Upload Images
             </a>
           </div>`
      }

      <!-- Pagination -->
      ${typeof pagination !== 'undefined' && pagination
        ? `<%- include('partials/pagination', { pagination, query: typeof searchQuery !== 'undefined' ? searchQuery : '', tag: typeof currentTag !== 'undefined' ? currentTag : '', sort: typeof currentSort !== 'undefined' ? currentSort : 'newest' }) %>`
        : ''
      }

    </div>
  </div>
</div>

<style>
  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    line-height: 1.6;
  }
  .tag-cloud-item {
    display: inline-block;
    padding: 0.1rem 0.3rem;
    border-radius: 3px;
    transition: opacity 0.2s;
  }
  .tag-cloud-item:hover {
    opacity: 0.75;
    text-decoration: underline !important;
  }
  .tag-cloud-item.active {
    font-weight: bold;
    text-decoration: underline !important;
  }
</style>

<script>
  // Highlight active tag in cloud
  const currentTag = '${typeof currentTag !== 'undefined' ? escapeHtml(currentTag) : ''}';
  if (currentTag) {
    document.querySelectorAll('.tag-cloud-item').forEach(link => {
      const href = link.getAttribute('href') || '';
      if (href.includes('tag=' + currentTag)) {
        link.classList.add('active');
      }
    });
  }

  function escapeHtml(str) {
    if (!str) return '';
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
</script>
`) %>

<%
function escapeHtml(str) {
  if (!str) return '';
  return String(str)
    .replace(/&/g,'&amp;')
    .replace(/</g,'&lt;')
    .replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;')
    .replace(/`/g,'&#96;')
    .replace(/\$/g,'&#36;');
}
%>