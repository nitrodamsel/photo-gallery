<%- include('layouts/base', { title: title || 'Gallery', activePage: 'gallery', body: `
<div class="container-fluid py-4">
  <div class="row g-4">
    <!-- Sidebar -->
    <div class="col-lg-2 gallery-sidebar">
      <!-- Tag Cloud -->
      <div class="card shadow-sm mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h6 class="mb-0"><i class="bi bi-tags me-1"></i>Tags</h6>
          <a href="/tags" class="btn btn-outline-secondary btn-sm">Manage</a>
        </div>
        <div class="card-body">
          <%- include('partials/tag-cloud', { tags: typeof allTags !== 'undefined' ? allTags : [] }) %>
          ${typeof activeTag !== 'undefined' && activeTag ? `
          <div class="mt-2 pt-2 border-top">
            <a href="/gallery" class="btn btn-sm btn-outline-secondary w-100">
              <i class="bi bi-x me-1"></i>Clear filter
            </a>
          </div>` : ''}
        </div>
      </div>

      <!-- Stats -->
      ${typeof totalImages !== 'undefined' ? `
      <div class="card shadow-sm">
        <div class="card-body text-center py-2">
          <div class="fs-4 fw-bold text-primary">${totalImages}</div>
          <div class="small text-muted">Total Images</div>
        </div>
      </div>` : ''}
    </div>

    <!-- Main Content -->
    <div class="col-lg-10">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0">
          ${typeof activeTag !== 'undefined' && activeTag
            ? `<i class="bi bi-tag me-2"></i>Tagged: ${activeTag}`
            : '<i class="bi bi-images me-2"></i>Gallery'}
        </h1>
        <div class="d-flex gap-2">
          <a href="/upload" class="btn btn-primary btn-sm">
            <i class="bi bi-cloud-upload me-1"></i>Upload
          </a>
        </div>
      </div>

      ${typeof images !== 'undefined' && images && images.length > 0 ? `
      <div class="row g-3">
        ${images.map(image => `
        <div class="col-6 col-md-4 col-xl-3">
          <%- include('partials/image-card', { image }) %>
        </div>
        `).join('')}
      </div>

      <!-- Pagination -->
      ${typeof pagination !== 'undefined' && pagination && pagination.totalPages > 1
        ? `<%- include('partials/pagination', { pagination }) %>`
        : ''}
      ` : `
      <div class="text-center py-5 text-muted">
        <i class="bi bi-images display-4 d-block mb-3"></i>
        <h4>No images yet</h4>
        <p>Upload your first image to get started.</p>
        <a href="/upload" class="btn btn-primary">
          <i class="bi bi-cloud-upload me-2"></i>Upload Images
        </a>
      </div>
      `}
    </div>
  </div>
</div>
` }) %>