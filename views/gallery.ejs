<%- include('layouts/base', { title: title, body: `
<div class="container-fluid mt-4">
  <div class="row">
    <!-- Sidebar -->
    <div class="col-lg-3 col-xl-2 mb-4">
      <!-- Search -->
      <div class="card shadow-sm mb-3">
        <div class="card-header">
          <h6 class="mb-0"><i class="bi bi-search me-2"></i>Search</h6>
        </div>
        <div class="card-body">
          <form action="/gallery" method="get">
            <div class="input-group input-group-sm">
              <input type="text" class="form-control" name="search"
                value="${search || ''}" placeholder="Search images...">
              <button class="btn btn-outline-primary" type="submit">
                <i class="bi bi-search"></i>
              </button>
            </div>
          </form>
        </div>
      </div>

      <!-- Tag Cloud -->
      <div class="card shadow-sm mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h6 class="mb-0"><i class="bi bi-tags me-2"></i>Tags</h6>
          <a href="/tags" class="btn btn-outline-secondary btn-sm" title="Manage Tags">
            <i class="bi bi-gear"></i>
          </a>
        </div>
        <div class="card-body">
          ${currentTag ? `
            <div class="mb-2">
              <a href="/gallery" class="btn btn-sm btn-outline-secondary w-100">
                <i class="bi bi-x me-1"></i>Clear filter: #${currentTag.name}
              </a>
            </div>
          ` : ''}
          <%- include('partials/tag-cloud', { tags: tags }) %>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="col-lg-9 col-xl-10">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">
          ${currentTag ? `<span class="badge me-2" style="background:${currentTag.color || '#6c757d'}">#${currentTag.name}</span>` : ''}
          ${count} image${count !== 1 ? 's' : ''}
          ${search ? ` matching "<strong>${search}</strong>"` : ''}
        </h4>
        <a href="/upload" class="btn btn-primary">
          <i class="bi bi-cloud-upload me-1"></i>Upload
        </a>
      </div>

      ${images.length === 0 ? `
        <div class="text-center py-5 text-muted">
          <i class="bi bi-images fs-1 d-block mb-3"></i>
          <p class="fs-5">No images found.</p>
          ${!currentTag && !search ? `<a href="/upload" class="btn btn-primary">Upload your first image</a>` : ''}
        </div>
      ` : `
        <div class="row row-cols-2 row-cols-md-3 row-cols-xl-4 g-3">
          ${images.map(image => `
            <%- include('partials/image-card', { image: image }) %>
          `).join('')}
        </div>
      `}

      <!-- Pagination -->
      ${totalPages > 1 ? `<%- include('partials/pagination', { page: page, totalPages: totalPages, search: search, currentTag: currentTag }) %>` : ''}
    </div>
  </div>
</div>
` }) %>