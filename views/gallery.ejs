<%- include('layouts/base', { title: 'Gallery', body: `

<div class="gallery-page">

  <div class="gallery-header">
    <h1 class="gallery-title">Photo Gallery</h1>
    <div class="gallery-header__actions">
      <a href="/upload" class="btn btn--primary">+ Upload</a>
      <button id="bulkSelectToggle" class="btn btn--secondary">☑ Select</button>
    </div>
  </div>

  <!-- Filter Panel -->
  <%- include('partials/filter-panel') %>

  <!-- Tag Cloud -->
  <% if (locals.tags && tags.length > 0) { %>
    <%- include('partials/tag-cloud', { tags }) %>
  <% } %>

  <!-- Results Info -->
  <% if (locals.images) { %>
    <div class="gallery-meta">
      <span class="gallery-count">
        <% if (locals.pagination) { %>
          Showing <%= images.length %> of <%= pagination.total %> images
        <% } else { %>
          <%= images.length %> image<%= images.length !== 1 ? 's' : '' %>
        <% } %>
      </span>
    </div>
  <% } %>

  <!-- Image Grid -->
  <% if (locals.images && images.length > 0) { %>
    <div class="gallery-grid">
      <% images.forEach(image => { %>
        <%- include('partials/image-card', { image }) %>
      <% }); %>
    </div>
  <% } else { %>
    <div class="gallery-empty">
      <div class="gallery-empty__icon">📷</div>
      <h2 class="gallery-empty__title">No images yet</h2>
      <p class="gallery-empty__text">Upload some photos to get started!</p>
      <a href="/upload" class="btn btn--primary">Upload Images</a>
    </div>
  <% } %>

  <!-- Pagination -->
  <% if (locals.pagination && pagination.totalPages > 1) { %>
    <%- include('partials/pagination', { pagination }) %>
  <% } %>

</div>

<!-- Bulk Action Bar (floating) -->
<div id="bulkActionBar" class="bulk-action-bar">
  <div class="bulk-action-bar__info">
    <span id="bulkSelectedCount">0 images selected</span>
  </div>
  <div class="bulk-action-bar__controls">
    <button id="bulkSelectAll" class="btn btn--sm btn--secondary">Select All</button>
    <button id="bulkDeselectAll" class="btn btn--sm btn--secondary">Deselect All</button>
    <button id="bulkAddTag" class="btn btn--sm btn--primary">+ Add Tag</button>
    <button id="bulkRemoveTag" class="btn btn--sm btn--secondary">− Remove Tag</button>
    <button id="bulkDelete" class="btn btn--sm btn--danger">🗑 Delete</button>
  </div>
</div>

` }) %>