<%- include('layouts/base', { title: 'Gallery', body: `

<section class="section">
  <div class="container">

    <!-- Page Header -->
    <div class="level">
      <div class="level-left">
        <div class="level-item">
          <h1 class="title">Gallery</h1>
        </div>
      </div>
      <div class="level-right">
        <div class="level-item">
          <button id="bulk-select-toggle" class="button is-info" type="button">
            <span class="icon"><i class="fas fa-check-square"></i></span>
            <span>Select Multiple</span>
          </button>
        </div>
        <div class="level-item">
          <a href="/upload" class="button is-primary">
            <span class="icon"><i class="fas fa-upload"></i></span>
            <span>Upload</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Bulk Action Bar (hidden by default) -->
    <div id="bulk-action-bar" class="notification is-warning is-hidden bulk-action-bar">
      <div class="level">
        <div class="level-left">
          <div class="level-item">
            <strong><span id="bulk-selected-count">0</span> image(s) selected</strong>
          </div>
        </div>
        <div class="level-right">
          <div class="level-item">
            <div class="buttons">
              <button id="bulk-add-tag-btn" class="button is-success is-small" type="button">
                <span class="icon"><i class="fas fa-tag"></i></span>
                <span>Add Tag</span>
              </button>
              <button id="bulk-remove-tag-btn" class="button is-warning is-small" type="button">
                <span class="icon"><i class="fas fa-tag"></i></span>
                <span>Remove Tag</span>
              </button>
              <button id="bulk-delete-btn" class="button is-danger is-small" type="button">
                <span class="icon"><i class="fas fa-trash"></i></span>
                <span>Delete Selected</span>
              </button>
              <button id="bulk-cancel-btn" class="button is-light is-small" type="button">
                <span class="icon"><i class="fas fa-times"></i></span>
                <span>Cancel</span>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Filter Panel -->
    <%- include('partials/filter-panel') %>

    <!-- Image Grid -->
    <% if (images && images.length > 0) { %>
      <div class="columns is-multiline">
        <% images.forEach(image => { %>
          <div class="column is-3-desktop is-4-tablet is-6-mobile">
            <%- include('partials/image-card', { image }) %>
          </div>
        <% }) %>
      </div>

      <!-- Pagination -->
      <%- include('partials/pagination', { pagination: pagination || {} }) %>

    <% } else { %>
      <div class="has-text-centered py-6">
        <p class="title is-4 has-text-grey-light">No images found</p>
        <p class="subtitle has-text-grey-light">Try adjusting your filters or <a href="/upload">upload some images</a>.</p>
      </div>
    <% } %>

  </div>
</section>

` }) %>