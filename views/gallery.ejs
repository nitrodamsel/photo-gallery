<%- include('layouts/base', { title: title, body: `
<div class="gallery-page">
  <div class="gallery-header">
    <h1 class="gallery-title">Photo Gallery</h1>
    <% if (tag) { %>
    <div class="active-filter">
      <span class="filter-label">Filtered by tag:</span>
      <span class="tag-badge tag-active">
        <%= tag %>
        <a href="/gallery" class="tag-remove" aria-label="Remove tag filter">&times;</a>
      </span>
    </div>
    <% } %>
    <div class="gallery-meta">
      <span class="result-count"><%= total %> image<%= total !== 1 ? 's' : '' %></span>
    </div>
  </div>

  <% if (images && images.length > 0) { %>
  <div class="gallery-grid">
    <% images.forEach(function(image) { %>
      <%- include('partials/image-card', { image: image }) %>
    <% }); %>
  </div>

  <%- include('partials/pagination', {
    page: page,
    totalPages: totalPages,
    limit: limit,
    query: query,
    basePath: '/gallery'
  }) %>

  <% } else { %>
  <div class="gallery-empty">
    <div class="empty-icon">📷</div>
    <h2>No images found</h2>
    <% if (tag) { %>
      <p>No images with tag "<strong><%= tag %></strong>".</p>
      <a href="/gallery" class="btn btn-primary">View All Images</a>
    <% } else { %>
      <p>No images have been uploaded yet.</p>
      <a href="/upload" class="btn btn-primary">Upload Your First Image</a>
    <% } %>
  </div>
  <% } %>
</div>
` }) %>