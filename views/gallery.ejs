<% layout = 'layouts/base' %>

<div class="gallery-page">
  <div class="gallery-header">
    <h1 class="gallery-title">Photo Gallery</h1>

    <% if (typeof activeTag !== 'undefined' && activeTag) { %>
      <div class="active-filter">
        <span class="filter-label">Filtered by tag:</span>
        <span class="tag-badge tag-active"><%= activeTag %></span>
        <a href="/gallery" class="clear-filter" aria-label="Clear tag filter">&#10005; Clear filter</a>
      </div>
    <% } %>

    <div class="gallery-meta">
      <span class="image-count">
        <%= pagination.total %> image<%= pagination.total !== 1 ? 's' : '' %>
      </span>
    </div>
  </div>

  <% if (images.length === 0) { %>
    <div class="empty-state">
      <div class="empty-icon">📷</div>
      <h2>No images found</h2>
      <% if (activeTag) { %>
        <p>No images tagged with "<strong><%= activeTag %></strong>".</p>
        <a href="/gallery" class="btn btn-primary">View all images</a>
      <% } else { %>
        <p>No images have been uploaded yet.</p>
        <a href="/upload" class="btn btn-primary">Upload your first image</a>
      <% } %>
    </div>
  <% } else { %>
    <div class="image-grid">
      <% images.forEach(function(image) { %>
        <%- include('partials/image-card', { image: image, activeTag: activeTag }) %>
      <% }) %>
    </div>

    <%- include('partials/pagination', { pagination: pagination, query: query }) %>
  <% } %>
</div>