<div class="container-fluid mt-4">
  <div class="row">
    <!-- Main Gallery -->
    <div class="col-lg-9">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <h1 class="mb-1">
            <% if (typeof activeTag !== 'undefined' && activeTag) { %>
              <i class="bi bi-tag-fill me-2"></i>Tag: <%= activeTag.name %>
            <% } else { %>
              <i class="bi bi-images me-2"></i>Gallery
            <% } %>
          </h1>
          <p class="text-muted mb-0">
            <%= typeof totalCount !== 'undefined' ? totalCount : 0 %> photo<%= (typeof totalCount !== 'undefined' && totalCount !== 1) ? 's' : '' %>
            <% if (typeof activeTag !== 'undefined' && activeTag) { %>
              with tag "<%= activeTag.name %>"
            <% } %>
          </p>
        </div>
        <div class="d-flex gap-2">
          <% if (typeof activeTag !== 'undefined' && activeTag) { %>
            <a href="/gallery" class="btn btn-outline-secondary btn-sm">
              <i class="bi bi-x me-1"></i>Clear Filter
            </a>
          <% } %>
          <a href="/upload" class="btn btn-primary btn-sm">
            <i class="bi bi-upload me-1"></i>Upload
          </a>
        </div>
      </div>

      <% if (typeof images !== 'undefined' && images.length > 0) { %>
      <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-3 mb-4">
        <% images.forEach(function(image) { %>
          <div class="col">
            <%- include('partials/image-card', { image: image }) %>
          </div>
        <% }) %>
      </div>
      <% if (typeof pagination !== 'undefined') { %>
        <%- include('partials/pagination', { pagination: pagination }) %>
      <% } %>
      <% } else { %>
      <div class="text-center py-5">
        <i class="bi bi-images fs-1 text-muted d-block mb-3"></i>
        <h3 class="text-muted">No photos found</h3>
        <% if (typeof activeTag !== 'undefined' && activeTag) { %>
          <p class="text-muted">No photos tagged with "<%= activeTag.name %>"</p>
          <a href="/gallery" class="btn btn-outline-primary me-2">View All Photos</a>
        <% } else { %>
          <p class="text-muted">Start uploading to build your gallery!</p>
          <a href="/upload" class="btn btn-primary">
            <i class="bi bi-upload me-2"></i>Upload Photos
          </a>
        <% } %>
      </div>
      <% } %>
    </div>

    <!-- Sidebar -->
    <div class="col-lg-3">
      <div class="sticky-top" style="top: 80px;">
        <!-- Search/Filter -->
        <div class="card mb-3 shadow-sm">
          <div class="card-header">
            <h6 class="mb-0"><i class="bi bi-search me-1"></i>Filter</h6>
          </div>
          <div class="card-body">
            <form method="GET" action="/gallery">
              <div class="mb-2">
                <input type="text" class="form-control form-control-sm" name="search" 
                  placeholder="Search photos..." 
                  value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
              </div>
              <button type="submit" class="btn btn-outline-primary btn-sm w-100">
                <i class="bi bi-search me-1"></i>Search
              </button>
            </form>
          </div>
        </div>

        <!-- Tag Cloud -->
        <div class="card shadow-sm">
          <div class="card-header d-flex justify-content-between align-items-center">
            <h6 class="mb-0"><i class="bi bi-tags me-1"></i>Browse by Tag</h6>
            <a href="/tags" class="btn btn-outline-secondary btn-sm">Manage</a>
          </div>
          <div class="card-body">
            <%- include('partials/tag-cloud', { tags: typeof allTags !== 'undefined' ? allTags : [] }) %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>