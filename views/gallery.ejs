<%- contentFor('body') %>

<section class="section">
  <div class="container">

    <!-- Gallery Header -->
    <div class="level mb-4">
      <div class="level-left">
        <div class="level-item">
          <div>
            <h1 class="title is-4 mb-1">Gallery</h1>
            <p class="subtitle is-6 has-text-grey">
              <% if (typeof totalImages !== 'undefined') { %>
                <%= totalImages %> image<%= totalImages !== 1 ? 's' : '' %>
              <% } %>
              <% if (typeof currentTag !== 'undefined' && currentTag) { %>
                tagged with <strong><%= currentTag %></strong>
              <% } %>
            </p>
          </div>
        </div>
      </div>
      <div class="level-right">
        <div class="level-item">
          <div class="buttons">
            <a href="/upload" class="button is-primary">
              <span class="icon"><i class="fas fa-upload"></i></span>
              <span>Upload</span>
            </a>
            <button id="bulk-select-toggle" class="button is-info">
              <span class="icon"><i class="fas fa-check-square"></i></span>
              <span>Select Images</span>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Filter Panel -->
    <% if (typeof tags !== 'undefined' && tags && tags.length > 0) { %>
      <%- include('./partials/filter-panel', { tags: tags, currentTag: currentTag || null, sortBy: sortBy || 'createdAt', sortDir: sortDir || 'DESC' }) %>
    <% } %>

    <!-- Image Grid -->
    <% if (typeof images !== 'undefined' && images && images.length > 0) { %>
      <div class="columns is-multiline is-mobile">
        <% images.forEach(image => { %>
          <div class="column is-6-mobile is-4-tablet is-3-desktop">
            <%- include('./partials/image-card', { image: image }) %>
          </div>
        <% }); %>
      </div>

      <!-- Pagination -->
      <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
        <%- include('./partials/pagination', {
          currentPage: currentPage || 1,
          totalPages: totalPages,
          baseUrl: '/gallery',
          queryParams: {}
        }) %>
      <% } %>
    <% } else { %>
      <div class="has-text-centered py-6">
        <p class="has-text-grey is-size-5">No images found</p>
        <a href="/upload" class="button is-primary mt-3">Upload your first image</a>
      </div>
    <% } %>

  </div><!-- /.container -->
</section>

<!-- Bulk Action Floating Bar -->
<div id="bulk-action-bar" class="bulk-action-bar is-hidden">
  <div class="bulk-action-bar-inner">
    <span id="bulk-action-count" class="bulk-action-count">0 images selected</span>
    <div class="buttons are-small">
      <button id="bulk-add-tag" class="button is-success is-light">
        <span class="icon"><i class="fas fa-tag"></i></span>
        <span>Add Tag</span>
      </button>
      <button id="bulk-remove-tag" class="button is-warning is-light">
        <span class="icon"><i class="fas fa-tag"></i></span>
        <span>Remove Tag</span>
      </button>
      <button id="bulk-delete" class="button is-danger is-light">
        <span class="icon"><i class="fas fa-trash"></i></span>
        <span>Delete</span>
      </button>
      <button id="bulk-cancel" class="button is-light">
        <span>Cancel</span>
      </button>
    </div>
  </div>
</div>

<script src="/js/bulkSelect.js"></script>