<%- include('layouts/base', { title: 'Gallery', body: `
<div class="gallery-page">

  <div class="gallery-header">
    <h1 class="gallery-title">Gallery</h1>
    <div class="gallery-header-actions">
      <a href="/upload" class="btn btn-primary">Upload Images</a>
      <button id="btn-bulk-select" class="btn btn-secondary">Select Multiple</button>
    </div>
  </div>

  <!-- Filter Panel -->
  <%- include('partials/filter-panel', { tags, currentTag, currentSort, currentSearch }) %>

  <!-- Gallery Grid -->
  <% if (images && images.length > 0) { %>
    <div id="gallery-grid" class="gallery-grid">
      <% images.forEach(image => { %>
        <%- include('partials/image-card', { image }) %>
      <% }); %>
    </div>

    <!-- Pagination -->
    <%- include('partials/pagination', { page, totalPages, currentTag, currentSort, currentSearch }) %>
  <% } else { %>
    <div class="gallery-empty">
      <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="gallery-empty-icon">
        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
        <circle cx="8.5" cy="8.5" r="1.5"></circle>
        <polyline points="21 15 16 10 5 21"></polyline>
      </svg>
      <h2>No images found</h2>
      <p>
        <% if (currentTag || currentSearch) { %>
          No images match your current filters.
          <a href="/gallery">Clear filters</a>
        <% } else { %>
          Get started by <a href="/upload">uploading some images</a>.
        <% } %>
      </p>
    </div>
  <% } %>

  <!-- Bulk Action Bar (floating) -->
  <div id="bulk-action-bar" class="bulk-action-bar" aria-hidden="true" role="toolbar" aria-label="Bulk actions">
    <div class="bulk-action-bar-inner">
      <span class="bulk-count-label">
        <strong id="bulk-selected-count">0</strong> selected
      </span>
      <div class="bulk-action-buttons">
        <button id="bulk-btn-select-all" class="btn btn-sm btn-secondary">Select All</button>
        <button id="bulk-btn-deselect-all" class="btn btn-sm btn-secondary">Deselect All</button>
        <button id="bulk-btn-add-tag" class="btn btn-sm btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:4px;vertical-align:middle;">
            <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
            <line x1="7" y1="7" x2="7.01" y2="7"></line>
          </svg>
          Add Tag
        </button>
        <button id="bulk-btn-remove-tag" class="btn btn-sm btn-secondary">
          Remove Tag
        </button>
        <button id="bulk-btn-delete" class="btn btn-sm btn-danger">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:4px;vertical-align:middle;">
            <polyline points="3 6 5 6 21 6"></polyline>
            <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path>
            <path d="M10 11v6"></path>
            <path d="M14 11v6"></path>
            <path d="M9 6V4h6v2"></path>
          </svg>
          Delete
        </button>
        <button id="bulk-btn-cancel" class="btn btn-sm btn-ghost">Cancel</button>
      </div>
      <span id="bulk-status" class="bulk-status" style="display:none;"></span>
    </div>
  </div>

</div>

<script src="/js/bulkSelect.js"></script>
`) %>