<%- include('layouts/base', { title: 'Gallery', body: `
<section class="section">
  <div class="container">

    <!-- Page Header -->
    <div class="level mb-4">
      <div class="level-left">
        <div class="level-item">
          <h1 class="title is-4 mb-0">Gallery</h1>
        </div>
      </div>
      <div class="level-right">
        <div class="level-item">
          <div class="buttons">
            <button id="bulk-select-toggle" class="button is-light">
              <span class="icon">☑</span>
              <span>Select Images</span>
            </button>
            <a href="/upload" class="button is-primary">
              <span class="icon">+</span>
              <span>Upload</span>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Filters -->
    <%- include('partials/filter-panel') %>

    <!-- Gallery Grid -->
    <div id="gallery-grid" class="columns is-multiline is-mobile">
      <% if (images && images.length > 0) { %>
        <% images.forEach(image => { %>
          <div class="column is-6-mobile is-4-tablet is-3-desktop">
            <%- include('partials/image-card', { image }) %>
          </div>
        <% }) %>
      <% } else { %>
        <div class="column is-full">
          <div class="has-text-centered py-6">
            <p class="has-text-grey is-size-5">No images found.</p>
            <a href="/upload" class="button is-primary mt-3">Upload your first image</a>
          </div>
        </div>
      <% } %>
    </div>

    <!-- Pagination -->
    <%- include('partials/pagination') %>

  </div>
</section>

<!-- Bulk Action Bar (floating) -->
<div id="bulk-action-bar" class="bulk-action-bar is-hidden">
  <div class="bulk-action-bar-inner">
    <span id="bulk-selected-count" class="has-text-weight-semibold">0 images selected</span>
    <div class="buttons ml-4">
      <button id="bulk-add-tag" class="button is-small is-info">
        <span class="icon">🏷</span>
        <span>Add Tag</span>
      </button>
      <button id="bulk-remove-tag" class="button is-small is-warning">
        <span class="icon">✂</span>
        <span>Remove Tag</span>
      </button>
      <button id="bulk-delete" class="button is-small is-danger">
        <span class="icon">🗑</span>
        <span>Delete</span>
      </button>
      <button id="bulk-cancel" class="button is-small is-light">
        Cancel
      </button>
    </div>
  </div>
</div>

<script src="/js/bulkSelect.js"></script>
` }) %>