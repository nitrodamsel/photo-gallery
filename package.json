    "express": "^4.18.2",
    "express-ejs-layouts": "^2.5.1",
    "sequelize": "^6.35.2",
    "sqlite3": "^5.1.6",
    "umzug": "^3.4.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}